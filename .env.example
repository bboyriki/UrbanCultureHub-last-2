# ═══════════════════════════════════════════════════════════════
#  Urban Culture Hub — Environment Variables Reference
#  Copy to .env (local) or paste into Railway → Variables panel.
#  Lines marked [REQUIRED] must be set for the app to start.
#  Lines marked [OPTIONAL] enable specific features.
# ═══════════════════════════════════════════════════════════════

# ── App / Deployment ──────────────────────────────────────────
# [REQUIRED on Railway] Public HTTPS URL of your Railway service.
# Used for CSP headers, CSRF origin check, Stripe webhooks, FCM.
# Example: https://urban-culture-hub.up.railway.app
APP_URL=

# The port Railway (or Docker) binds to. Railway sets this automatically.
PORT=5000

# Node environment — Railway sets this to "production" automatically.
NODE_ENV=production

# Secure random string for Express session signing (min 32 chars).
# Generate: openssl rand -hex 32
SESSION_SECRET=

# ── Admin Configuration ───────────────────────────────────────
# [REQUIRED] Primary admin account email
ADMIN_EMAIL=
ADMIN1_EMAIL=
ADMIN2_EMAIL=
# Firebase UID for the primary admin (from Firebase Console → Authentication)
ADMIN1_FIREBASE_UID=
# Comma-separated emails exempt from login brute-force lockout
ADMIN_EXEMPT_EMAILS=

# ── Database ──────────────────────────────────────────────────
# [REQUIRED] Neon PostgreSQL connection string.
# Format: postgresql://user:password@host/dbname?sslmode=require
# On Railway: add a Neon plugin or use Railway's Postgres (change db.ts driver).
DATABASE_URL=

# ── Firebase (Auth + Push Notifications) ─────────────────────
# [REQUIRED for auth] Firebase project config — safe to expose in client.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# [OPTIONAL] Web Push VAPID key for Firebase Cloud Messaging
VITE_FIREBASE_VAPID_KEY=

# [REQUIRED for server-side Firebase Admin (push notifications, auth verify)]
# Paste the full JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_PROJECT_ID=

# ── Stripe (Payments) ─────────────────────────────────────────
# [REQUIRED for payments]
STRIPE_SECRET_KEY=sk_live_...
VITE_STRIPE_PUBLIC_KEY=pk_live_...

# [REQUIRED for webhooks on Railway]
# From Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
# Set your webhook URL to: https://<APP_URL>/api/stripe/webhook/any-value
STRIPE_WEBHOOK_SECRET=whsec_...

# [OPTIONAL] Pre-created price IDs for subscription plans
STRIPE_PREMIUM_MONTHLY_PRICE_ID=
STRIPE_PREMIUM_YEARLY_PRICE_ID=

# Alternate webhook base URL (falls back to APP_URL if not set)
WEBHOOK_BASE_URL=

# ── Cloudinary (Image & Video Uploads) ───────────────────────
# [REQUIRED for media uploads]
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── AI Services ───────────────────────────────────────────────
# [REQUIRED for AI features] Anthropic Claude
ANTHROPIC_API_KEY=
# Alternative env name used by some integrations
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# [OPTIONAL] OpenAI (image generation, GPT features)
OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# [OPTIONAL] ElevenLabs voice synthesis
ELEVENLABS_API_KEY=

# [OPTIONAL] RunwayML video generation
RUNWAY_API_SECRET=

# [OPTIONAL] Replicate (image/video models)
REPLICATE_API_TOKEN=

# [OPTIONAL] Fal.ai
FAL_KEY=

# [OPTIONAL] HuggingFace
HF_API_KEY=
HF_API_SECRET=

# ── Email (Mailgun) ───────────────────────────────────────────
# [REQUIRED for email notifications]
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_SENDING_KEY=
MAILGUN_PRIMARY_KEY=
VERIFIED_SENDER_EMAIL=noreply@yourdomain.com

# [OPTIONAL] SendGrid (fallback mailer)
SENDGRID_API_KEY=

# ── Google Services ───────────────────────────────────────────
# [OPTIONAL] Google Maps (embedded maps)
VITE_GOOGLE_MAPS_API_KEY=

# [OPTIONAL] Google OAuth (social login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# [OPTIONAL] Google Cloud (for GCP-hosted features)
GOOGLE_CLOUD_PROJECT=
GCLOUD_PROJECT=

# ── Social Integrations ───────────────────────────────────────
# Instagram
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_REDIRECT_URI=https://<APP_URL>/api/instagram/callback
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_WEBHOOK_CALLBACK_URL=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=
LINKEDIN_VERIFICATION_TOKEN=

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=

# ── Event Platforms ───────────────────────────────────────────
# [OPTIONAL]
TICKETMASTER_API_KEY=
EVENTBRITE_API_KEY=
EVENTBRITE_PRIVATE_TOKEN=
EVENTBRITE_TOKEN=
MEETUP_API_KEY=
MEETUP_TOKEN=

# ── Dutch Business Registry (KVK) ────────────────────────────
# [OPTIONAL] Only needed if Dutch company lookup is used
KVK_API_KEY=
KVK_API_USERNAME=
KVK_API_URL=https://api.kvk.nl/api/v1/

# ── WebRTC TURN Server ────────────────────────────────────────
# [OPTIONAL] For live video streaming features
TURN_URL=
TURN_USER=
TURN_PASS=

# ── Admin ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com

# ── Debug ────────────────────────────────────────────────────
# Set to "true" to enable verbose session logging
DEBUG_SESSION=false
