import React, { useState, useRef, useEffect } from 'react';
import { useAdminAiAssistant, AdminAiAssistantMessage } from '@/hooks/use-admin-ai-assistant';
import { FileExplorer } from '@/components/admin/FileExplorer';
import { Button } from '@/components/ui/button';
import { Textarea } from '@/components/ui/textarea';
import { Badge } from '@/components/ui/badge';
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card';
import { Label } from '@/components/ui/label';
import { Separator } from '@/components/ui/separator';
import { ScrollArea } from '@/components/ui/scroll-area';
import { 
  AlertCircle, 
  BrainCircuit, 
  Clock, 
  Code, 
  Copy, 
  Cpu, 
  FileCode, 
  InfoIcon, 
  MessageSquare, 
  SendHorizonal, 
  Sparkles, 
  Trash,
  FolderTree
} from 'lucide-react';
import { Alert, AlertTitle, AlertDescription } from '@/components/ui/alert';
import { formatDistanceToNow } from 'date-fns';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from '@/components/ui/select';
import { Tooltip, TooltipContent, TooltipProvider, TooltipTrigger } from '@/components/ui/tooltip';


const programmingLanguages = [
  { value: 'javascript', label: 'JavaScript' },
  { value: 'typescript', label: 'TypeScript' },
  { value: 'python', label: 'Python' },
  { value: 'java', label: 'Java' },
  { value: 'csharp', label: 'C#' },
  { value: 'cpp', label: 'C++' },
  { value: 'php', label: 'PHP' },
  { value: 'go', label: 'Go' },
  { value: 'ruby', label: 'Ruby' },
  { value: 'rust', label: 'Rust' },
  { value: 'swift', label: 'Swift' },
  { value: 'kotlin', label: 'Kotlin' },
  { value: 'sql', label: 'SQL' },
  { value: 'html', label: 'HTML' },
  { value: 'css', label: 'CSS' },
  { value: 'shell', label: 'Shell/Bash' }
];

export const AdminAiAssistant: React.FC = () => {
  const {
    isLoading,
    error,
    history,
    currentSession,
    currentMessage,
    setCurrentMessage,
    streamingResponse,
    isStreaming,
    codeLanguage,
    setCodeLanguage,
    codeSnippet,
    setCodeSnippet,
    selectedModel,
    setSelectedModel,
    sendMessage,
    createNewSession,
    selectSession,
    isAdmin
  } = useAdminAiAssistant();

  const [activeTab, setActiveTab] = useState('chat');
  const [selectedFilePath, setSelectedFilePath] = useState<string | null>(null);
  const [selectedFileContent, setSelectedFileContent] = useState<string | null>(null);
  const messagesEndRef = useRef<HTMLDivElement>(null);
  const messageInputRef = useRef<HTMLTextAreaElement>(null);
  const codeInputRef = useRef<HTMLTextAreaElement>(null);

  // Scroll to bottom when messages change
  useEffect(() => {
    if (messagesEndRef.current) {
      messagesEndRef.current.scrollIntoView({ behavior: 'smooth' });
    }
  }, [currentSession, streamingResponse]);

  // Focus input when tab changes
  useEffect(() => {
    if (activeTab === 'chat' && messageInputRef.current) {
      setTimeout(() => messageInputRef.current?.focus(), 100);
    } else if (activeTab === 'code' && codeInputRef.current) {
      setTimeout(() => codeInputRef.current?.focus(), 100);
    }
  }, [activeTab]);

  const handleSendMessage = async () => {
    if (!currentMessage.trim()) return;
    
    if (activeTab === 'chat') {
      await sendMessage(currentMessage);
    } else if (activeTab === 'code') {
      await sendMessage(currentMessage, codeSnippet || undefined, codeLanguage || undefined);
    }
  };

  const handleKeyDown = (e: React.KeyboardEvent) => {
    if (e.key === 'Enter' && e.ctrlKey) {
      e.preventDefault();
      handleSendMessage();
    }
  };

  const copyToClipboard = async (text: string) => {
    try {
      await navigator.clipboard.writeText(text);
      // You can add a toast notification here if you want
    } catch (err) {
      console.error('Failed to copy text: ', err);
    }
  };

  if (!isAdmin) {
    return (
      <div className="p-6 max-w-4xl mx-auto">
        <Alert variant="destructive">
          <AlertCircle className="h-4 w-4" />
          <AlertTitle>Access denied</AlertTitle>
          <AlertDescription>
            You need admin privileges to access the AI Assistant.
          </AlertDescription>
        </Alert>
      </div>
    );
  }

  const getChatTimestamp = (message: AdminAiAssistantMessage) => {
    if (!message.createdAt) return '';
    return formatDistanceToNow(new Date(message.createdAt), { addSuffix: true });
  };

  return (
    <div className="grid grid-cols-1 md:grid-cols-4 gap-6 p-1">
      {/* Sidebar with conversation history */}
      <div className="md:col-span-1">
        <Card className="h-[calc(100vh-210px)] flex flex-col">
          <CardHeader className="pb-3">
            <CardTitle className="text-lg flex items-center">
              <MessageSquare className="h-5 w-5 mr-2" />
              Conversations
            </CardTitle>
          </CardHeader>
          <CardContent className="flex-grow overflow-hidden">
            <div className="flex mb-4">
              <Button
                onClick={createNewSession}
                className="w-full"
                variant="outline"
              >
                <BrainCircuit className="h-4 w-4 mr-2" />
                New Conversation
              </Button>
            </div>
            <ScrollArea className="h-[calc(100vh-330px)] pr-4">
              <div className="space-y-2">
                {history.length === 0 && !isLoading && (
                  <div className="text-center p-6 text-muted-foreground">
                    No conversation history
                  </div>
                )}
                {isLoading && history.length === 0 && (
                  <div className="text-center p-6 text-muted-foreground">
                    Loading conversations...
                  </div>
                )}
                {history.map((session) => (
                  <div
                    key={session.id}
                    className={`p-3 rounded-md cursor-pointer hover:bg-muted transition-colors ${
                      currentSession?.id === session.id ? 'bg-muted border-l-4 border-primary' : ''
                    }`}
                    onClick={() => selectSession(session.id)}
                  >
                    <div className="font-medium truncate">
                      {session.messages[0]?.content.substring(0, 40) || 'New conversation'}
                      {session.messages[0]?.content.length > 40 && '...'}
                    </div>
                    <div className="text-xs text-muted-foreground flex items-center mt-1">
                      <Clock className="h-3 w-3 mr-1" />
                      {formatDistanceToNow(session.lastUpdated, { addSuffix: true })}
                      <Badge className="ml-2 text-[10px] px-1" variant="outline">
                        {session.messages.length} messages
                      </Badge>
                    </div>
                  </div>
                ))}
              </div>
            </ScrollArea>
          </CardContent>
        </Card>
      </div>

      {/* Main chat area */}
      <div className="md:col-span-3">
        <Card className="h-[calc(100vh-210px)] flex flex-col">
          <CardHeader className="pb-3">
            <div className="flex justify-between items-center">
              <CardTitle className="text-lg flex items-center">
                <Cpu className="h-5 w-5 mr-2" />
                AI Assistant
              </CardTitle>
              <div className="flex space-x-2 items-center">
                <div className="mr-4">
                  <Select value={selectedModel} onValueChange={setSelectedModel}>
                    <SelectTrigger className="w-[180px] h-8 text-xs">
                      <SelectValue placeholder="Select Model" />
                    </SelectTrigger>
                    <SelectContent>
                      <SelectItem value="openai">OpenAI GPT-4</SelectItem>
                      <SelectItem value="anthropic">Claude 3.7</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
                <TooltipProvider>
                  <Tooltip>
                    <TooltipTrigger>
                      <Badge variant="outline" className="bg-blue-50 text-blue-800 border-blue-200">
                        <InfoIcon className="h-3 w-3 mr-1" />
                        Admin Only
                      </Badge>
                    </TooltipTrigger>
                    <TooltipContent>
                      <p className="max-w-xs">This AI Assistant is only available to administrators.</p>
                    </TooltipContent>
                  </Tooltip>
                </TooltipProvider>
              </div>
            </div>
            <CardDescription>
              Ask questions about code, troubleshoot issues, or get help with development tasks.
            </CardDescription>
          </CardHeader>

          <CardContent className="flex-grow mb-6 overflow-hidden">
            <ScrollArea className="h-[calc(100vh-350px)] pr-4">
              {error && (
                <Alert variant="destructive" className="mb-4">
                  <AlertCircle className="h-4 w-4" />
                  <AlertTitle>Error</AlertTitle>
                  <AlertDescription>{error}</AlertDescription>
                </Alert>
              )}

              <div className="flex flex-col space-y-4">
                {!currentSession?.messages.length && !isStreaming && (
                  <div className="text-center p-10">
                    <Sparkles className="h-12 w-12 mx-auto mb-4 text-primary/50" />
                    <h3 className="text-lg font-semibold mb-2">Welcome to the AI Assistant</h3>
                    <p className="text-muted-foreground mb-6 max-w-md mx-auto">
                      Ask questions about code, troubleshoot issues, or get help with development tasks.
                    </p>
                    <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 max-w-lg mx-auto">
                      <Button
                        variant="outline"
                        onClick={() => {
                          setCurrentMessage("Analyze this API endpoint for security vulnerabilities");
                          setTimeout(() => messageInputRef.current?.focus(), 100);
                        }}
                        className="justify-start text-left"
                      >
                        <FileCode className="h-4 w-4 mr-2 flex-shrink-0" />
                        <span className="truncate">Analyze API security</span>
                      </Button>
                      <Button
                        variant="outline"
                        onClick={() => {
                          setActiveTab('code');
                          setCurrentMessage("Please explain what this code does and suggest improvements:");
                          setTimeout(() => codeInputRef.current?.focus(), 100);
                        }}
                        className="justify-start text-left"
                      >
                        <Code className="h-4 w-4 mr-2 flex-shrink-0" />
                        <span className="truncate">Explain code</span>
                      </Button>
                      <Button
                        variant="outline"
                        onClick={() => {
                          setCurrentMessage("Help me refactor our user authentication service for better security");
                          setTimeout(() => messageInputRef.current?.focus(), 100);
                        }}
                        className="justify-start text-left"
                      >
                        <Cpu className="h-4 w-4 mr-2 flex-shrink-0" />
                        <span className="truncate">Refactoring help</span>
                      </Button>
                      <Button
                        variant="outline"
                        onClick={() => {
                          setCurrentMessage("What's the best way to implement WebSocket notifications in our app?");
                          setTimeout(() => messageInputRef.current?.focus(), 100);
                        }}
                        className="justify-start text-left"
                      >
                        <BrainCircuit className="h-4 w-4 mr-2 flex-shrink-0" />
                        <span className="truncate">Architecture advice</span>
                      </Button>
                    </div>
                  </div>
                )}

                {currentSession?.messages.map((message, index) => (
                  <div
                    key={`${message.sessionId}-${index}`}
                    className={`flex flex-col ${
                      message.role === 'user' ? 'items-end' : 'items-start'
                    }`}
                  >
                    <div
                      className={`max-w-[80%] px-4 py-3 rounded-lg ${
                        message.role === 'user'
                          ? 'bg-primary text-primary-foreground'
                          : 'bg-muted'
                      }`}
                    >
                      <div className="flex justify-between items-start mb-1">
                        <Badge variant="outline" className="mb-2 text-xs">
                          {message.role === 'user' ? 'You' : 'AI Assistant'}
                        </Badge>
                        <div className="flex space-x-1 ml-2">
                          <Button
                            variant="ghost"
                            size="icon"
                            className="h-5 w-5 rounded-full hover:bg-background/10"
                            onClick={() => copyToClipboard(message.content)}
                          >
                            <Copy className="h-3 w-3" />
                          </Button>
                        </div>
                      </div>
                      {message.role === 'user' ? (
                        <p className="whitespace-pre-wrap">{message.content}</p>
                      ) : (
                        <div className="prose prose-sm dark:prose-invert max-w-none">
                          <pre className="whitespace-pre-wrap text-sm">{message.content}</pre>
                        </div>
                      )}
                      <div className="text-xs mt-2 opacity-70 text-right">
                        {getChatTimestamp(message)}
                      </div>
                    </div>
                  </div>
                ))}

                {isStreaming && (
                  <div className="flex flex-col items-start">
                    <div className="max-w-[80%] px-4 py-3 rounded-lg bg-muted">
                      <div className="flex justify-between items-start mb-1">
                        <Badge variant="outline" className="mb-2 text-xs">
                          AI Assistant
                        </Badge>
                      </div>
                      <div className="prose prose-sm dark:prose-invert max-w-none">
                        <pre className="whitespace-pre-wrap text-sm">{streamingResponse}</pre>
                      </div>
                      <div className="text-xs mt-2 opacity-70 flex items-center">
                        <div className="animate-pulse flex space-x-1">
                          <div className="h-1.5 w-1.5 bg-current rounded-full"></div>
                          <div className="h-1.5 w-1.5 bg-current rounded-full delay-150"></div>
                          <div className="h-1.5 w-1.5 bg-current rounded-full delay-300"></div>
                        </div>
                      </div>
                    </div>
                  </div>
                )}

                <div ref={messagesEndRef} />
              </div>
            </ScrollArea>
          </CardContent>

          <CardFooter className="pt-2 px-4">
            <div className="w-full space-y-4">
              <Tabs value={activeTab} onValueChange={setActiveTab} className="w-full">
                <TabsList className="w-full bg-background border rounded-md">
                  <TabsTrigger value="chat" className="flex-1">
                    <MessageSquare className="h-4 w-4 mr-2" />
                    Chat
                  </TabsTrigger>
                  <TabsTrigger value="code" className="flex-1">
                    <Code className="h-4 w-4 mr-2" />
                    Code Analysis
                  </TabsTrigger>
                  <TabsTrigger value="browse" className="flex-1">
                    <FolderTree className="h-4 w-4 mr-2" />
                    Browse Files
                  </TabsTrigger>
                </TabsList>

                <TabsContent value="chat" className="mt-4 space-y-4">
                  <div className="flex flex-col space-y-2">
                    <Textarea
                      ref={messageInputRef}
                      placeholder="Ask a question about code, development, or troubleshooting..."
                      value={currentMessage}
                      onChange={(e) => setCurrentMessage(e.target.value)}
                      onKeyDown={handleKeyDown}
                      className="min-h-[100px] resize-none"
                    />
                    <div className="flex justify-between items-center">
                      <div className="text-xs text-muted-foreground">
                        Press Ctrl+Enter to send
                      </div>
                      <Button 
                        type="submit" 
                        onClick={handleSendMessage}
                        disabled={isLoading || !currentMessage.trim()}
                      >
                        {isLoading ? (
                          <span className="flex items-center">
                            <div className="animate-spin h-4 w-4 mr-2 border-2 border-current border-opacity-50 border-t-transparent rounded-full"></div>
                            Processing...
                          </span>
                        ) : (
                          <span className="flex items-center">
                            <SendHorizonal className="h-4 w-4 mr-2" />
                            Send Message
                          </span>
                        )}
                      </Button>
                    </div>
                  </div>
                </TabsContent>

                <TabsContent value="code" className="mt-4 space-y-4">
                  <div className="flex flex-col space-y-3">
                    <div className="grid grid-cols-1 sm:grid-cols-4 gap-4 items-start">
                      <div className="sm:col-span-1">
                        <Label htmlFor="language-select">Language</Label>
                        <Select
                          value={codeLanguage || ""}
                          onValueChange={(value) => setCodeLanguage(value)}
                        >
                          <SelectTrigger id="language-select">
                            <SelectValue placeholder="Select language" />
                          </SelectTrigger>
                          <SelectContent>
                            {programmingLanguages.map((lang) => (
                              <SelectItem key={lang.value} value={lang.value}>
                                {lang.label}
                              </SelectItem>
                            ))}
                          </SelectContent>
                        </Select>
                      </div>
                      <div className="sm:col-span-3">
                        <Label htmlFor="prompt-input">Question or request</Label>
                        <Textarea
                          id="prompt-input"
                          placeholder="E.g., 'What does this code do?' or 'Help me optimize this function'"
                          value={currentMessage}
                          onChange={(e) => setCurrentMessage(e.target.value)}
                          className="h-[80px] resize-none"
                        />
                      </div>
                    </div>
                    
                    <Separator />
                    
                    <div>
                      <Label htmlFor="code-input" className="mb-2 block">
                        Paste your code here
                      </Label>
                      <Textarea
                        ref={codeInputRef}
                        id="code-input"
                        placeholder="// Paste your code here for analysis"
                        value={codeSnippet || ''}
                        onChange={(e) => setCodeSnippet(e.target.value)}
                        className="min-h-[200px] font-mono text-sm"
                        onKeyDown={(e) => {
                          if (e.key === 'Tab') {
                            e.preventDefault();
                            const target = e.target as HTMLTextAreaElement;
                            const start = target.selectionStart;
                            const end = target.selectionEnd;
                            const newValue = codeSnippet?.substring(0, start) + '  ' + codeSnippet?.substring(end);
                            setCodeSnippet(newValue || '');
                            // Set cursor position after the inserted tab
                            setTimeout(() => {
                              if (codeInputRef.current) {
                                codeInputRef.current.selectionStart = start + 2;
                                codeInputRef.current.selectionEnd = start + 2;
                              }
                            }, 0);
                          }
                        }}
                      />
                    </div>
                    
                    <div className="flex justify-between items-center">
                      <div className="text-xs text-muted-foreground">
                        {codeSnippet ? `${codeSnippet.length} characters` : ''}
                      </div>
                      <Button 
                        onClick={handleSendMessage}
                        disabled={isLoading || !currentMessage.trim() || !codeSnippet?.trim()}
                      >
                        {isLoading ? (
                          <span className="flex items-center">
                            <div className="animate-spin h-4 w-4 mr-2 border-2 border-current border-opacity-50 border-t-transparent rounded-full"></div>
                            Analyzing...
                          </span>
                        ) : (
                          <span className="flex items-center">
                            <SendHorizonal className="h-4 w-4 mr-2" />
                            Analyze Code
                          </span>
                        )}
                      </Button>
                    </div>
                  </div>
                </TabsContent>
                
                <TabsContent value="browse" className="mt-4 space-y-4">
                  <div className="flex flex-col space-y-4">
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div className="border rounded-md p-4 h-[400px] overflow-auto">
                        <h3 className="text-sm font-medium mb-3 flex items-center">
                          <FolderTree className="h-4 w-4 mr-2" />
                          Project Files
                        </h3>
                        <FileExplorer 
                          onSelectFile={(filePath) => {
                            setSelectedFilePath(filePath);
                            // Fetch file content when a file is selected
                            fetch(`/api/admin/files/content?path=${encodeURIComponent(filePath)}`)
                              .then(response => response.text())
                              .then(content => {
                                setSelectedFileContent(content);
                              })
                              .catch(error => {
                                console.error('Error fetching file content:', error);
                                setSelectedFileContent('Error loading file content');
                              });
                          }}
                        />
                      </div>
                      
                      <div className="border rounded-md p-4 h-[400px] overflow-auto">
                        <h3 className="text-sm font-medium mb-3 flex items-center">
                          <FileCode className="h-4 w-4 mr-2" />
                          {selectedFilePath ? `File: ${selectedFilePath}` : 'File Content'}
                        </h3>
                        {selectedFilePath ? (
                          selectedFileContent ? (
                            <pre className="text-xs font-mono whitespace-pre-wrap overflow-auto max-h-[330px]">
                              {selectedFileContent}
                            </pre>
                          ) : (
                            <div className="flex justify-center items-center h-[330px]">
                              <div className="animate-spin h-5 w-5 border-2 border-primary border-t-transparent rounded-full"></div>
                            </div>
                          )
                        ) : (
                          <div className="text-center text-muted-foreground p-6">
                            Select a file to view its content
                          </div>
                        )}
                      </div>
                    </div>
                    
                    {selectedFilePath && selectedFileContent && (
                      <div className="flex justify-between">
                        <Button
                          variant="outline"
                          onClick={() => {
                            setSelectedFilePath(null);
                            setSelectedFileContent(null);
                          }}
                        >
                          Clear Selection
                        </Button>
                        
                        <Button
                          onClick={() => {
                            setActiveTab('code');
                            setCodeSnippet(selectedFileContent || '');
                            setCurrentMessage(`Please analyze this code from ${selectedFilePath}:`);
                          }}
                        >
                          <Code className="h-4 w-4 mr-2" />
                          Analyze Selected File
                        </Button>
                      </div>
                    )}
                  </div>
                </TabsContent>
              </Tabs>
            </div>
          </CardFooter>
        </Card>
      </div>
    </div>
  );
};

export default AdminAiAssistant;