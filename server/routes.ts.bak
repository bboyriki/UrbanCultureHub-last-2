  app.post("/api/content/filter", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const userId = req.user?.id;
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      const { level, filterProfanity, filterViolence, filterHateSpeech, filterExplicit, filterSpam } = req.body;
      
      // Get existing filter or create new one
