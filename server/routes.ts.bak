  // Service Booking Routes
  
  // Generic update booking status endpoint that handles all status changes
  app.post("/api/service-bookings/:id/status", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      const { status, message } = req.body;
      
      if (!status) {
        return res.status(400).json({ message: "Status is required" });
      }
      
      // Validate the status is one of the allowed values
      if (!Object.values(BookingStatus).includes(status)) {
        return res.status(400).json({ message: "Invalid status value" });
      }
      
      // Get the booking to check current status
      const currentBooking = await storage.getServiceBooking(bookingId);
      if (!currentBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }
      
      // Update the booking status
      let updatedBooking: ServiceBooking | undefined;
      
      // Use the appropriate method based on the requested status
      switch (status) {
        case BookingStatus.APPROVED:
          updatedBooking = await storage.approveServiceBooking(bookingId);
          break;
        case BookingStatus.REJECTED:
          updatedBooking = await storage.rejectServiceBooking(bookingId, message);
          break;
        case BookingStatus.COMPLETED:
          updatedBooking = await storage.completeServiceBooking(bookingId);
          break;
        case BookingStatus.CANCELLED:
          updatedBooking = await storage.cancelServiceBooking(bookingId, message);
          break;
        default:
          // For any other status, use the general update method
          updatedBooking = await storage.updateServiceBooking(bookingId, { 
            status, 
            adminMessage: message || null 
          });
      }
      
      if (!updatedBooking) {
        return res.status(500).json({ message: "Failed to update booking status" });
      }
      
      // Get the necessary data for notifications and emails
      const service = await storage.getService(updatedBooking.serviceId);
      const user = await storage.getUser(updatedBooking.userId);
      const provider = await storage.getUser(updatedBooking.providerId);
      
      if (service && user && provider) {
        try {
          // Import required functions
          const { sendBookingStatusUpdateEmail, sendProviderStatusUpdateEmail } = await import('./email');
          const { notifyBookingStatusUpdate } = await import('./websocket');
          
          // Send email to customer
          const customerEmailSent = await sendBookingStatusUpdateEmail(user, service, updatedBooking);
          
          if (customerEmailSent) {
            console.log(`Booking status update email sent to customer (ID: ${user.id})`);
          } else {
            console.warn(`Failed to send booking status update email to customer (ID: ${user.id})`);
          }
          
          // Send email to provider
          const providerEmailSent = await sendProviderStatusUpdateEmail(provider, user, service, updatedBooking);
          
          if (providerEmailSent) {
            console.log(`Booking status update notification sent to provider (ID: ${provider.id})`);
          } else {
            console.warn(`Failed to send booking status update notification to provider (ID: ${provider.id})`);
          }
          
          // Send real-time WebSocket notifications
          const statusMessage = `Your booking for ${service.name} has been updated to ${status.toUpperCase()}${message ? `: ${message}` : ''}`;
          
          // Notify customer
          notifyBookingStatusUpdate(
            user.id,
            provider.id,
            updatedBooking, 
            service,
            statusMessage
          );
          
          console.log(`WebSocket notification sent to customer (ID: ${user.id}) for booking status update`);
          
          // Update booking to mark email as sent
          await storage.updateServiceBooking(bookingId, { emailSent: true });
        } catch (error) {
          console.error("Error sending booking status update notifications:", error);
          // Continue even if notifications fail
        }
      }
      
      res.json(updatedBooking);
    } catch (error) {
      console.error("Error updating service booking status:", error);
      res.status(500).json({ message: "Failed to update service booking status" });
    }
  });
  
  app.get("/api/service-bookings", async (req: Request, res: Response) => {
    try {
      const { userId, providerId, serviceId, status, paymentIntentId } = req.query;
      let bookings: ServiceBooking[];

      if (paymentIntentId) {
        // Handle search by paymentIntentId - this is important for payment processing after redirects
        console.log(`Searching for booking with paymentIntentId: ${paymentIntentId}`);
        
        // Use the dedicated method to get bookings by paymentIntentId
        bookings = await storage.getServiceBookingsByPaymentIntentId(paymentIntentId as string);
        
        // If serviceId is also provided, filter the result
        if (serviceId) {
          bookings = bookings.filter(booking => booking.serviceId === parseInt(serviceId as string));
        }
        
        console.log(`Found ${bookings.length} bookings matching paymentIntentId: ${paymentIntentId}`);
      } else if (userId) {
        bookings = await storage.getServiceBookingsByUser(parseInt(userId as string));
      } else if (providerId) {
        bookings = await storage.getServiceBookingsByProvider(parseInt(providerId as string));
      } else if (serviceId) {
        bookings = await storage.getServiceBookingsByService(parseInt(serviceId as string));
      } else if (status) {
        bookings = await storage.getServiceBookingsByStatus(status as string);
      } else {
        // If no filters are provided, return all bookings (primarily for admin dashboard)
        bookings = await storage.getAllServiceBookings();
      }

      // Include service and user details with bookings for more context in admin interface
      const bookingsWithDetails = await Promise.all(bookings.map(async (booking) => {
        const service = await storage.getService(booking.serviceId);
        const user = await storage.getUser(booking.userId);
        const provider = await storage.getUser(booking.providerId);

        return {
          ...booking,
          serviceDetails: service ? {
            id: service.id,
            name: service.name,
            description: service.description,
            price: service.price,
            duration: service.duration,
            location: service.location,
            category: service.category,
            type: service.type
          } : null,
          userDetails: user ? {
            id: user.id,
            displayName: user.displayName,
            email: user.email,
            profilePicture: user.profilePicture,
            role: user.role
          } : null,
          providerDetails: provider ? {
            id: provider.id,
            displayName: provider.displayName,
            email: provider.email,
            profilePicture: provider.profilePicture,
            role: provider.role
          } : null
        };
      }));

      res.json(bookingsWithDetails);
    } catch (error) {
      console.error("Error fetching service bookings:", error);
      res.status(500).json({ message: "Failed to fetch service bookings" });
    }
  });

  app.get("/api/service-bookings/:id", async (req: Request, res: Response) => {
    try {
      const booking = await storage.getServiceBooking(parseInt(req.params.id));
      if (!booking) {
        return res.status(404).json({ message: "Service booking not found" });
      }
      res.json(booking);
    } catch (error) {
      console.error("Error fetching service booking:", error);
      res.status(500).json({ message: "Failed to fetch service booking" });
    }
  });

  app.post("/api/service-bookings", async (req: Request, res: Response) => {
    try {
      console.log("BOOKING REQUEST BODY:", req.body);
      
      // Extract emailTrigger before schema validation (it's not part of the schema)
      const emailTrigger = req.body.emailTrigger === true;
      console.log(`Email trigger flag from client: ${emailTrigger}`);
      
      const bookingData = insertServiceBookingSchema.parse(req.body);
      console.log("PARSED BOOKING DATA:", bookingData);

      // Enhanced debugging for iDEAL payments
      const isDirectPayment = !!(bookingData.paymentIntentId && bookingData.isPaid);
      console.log(`BOOKING PAYMENT TYPE: ${isDirectPayment ? 'Direct payment with paymentIntent' : 'Standard booking'}`);
      if (isDirectPayment || emailTrigger) {
        console.log('DIRECT PAYMENT DETAILS:', {
          paymentIntentId: bookingData.paymentIntentId,
          isPaid: bookingData.isPaid,
          userId: bookingData.userId,
          providerId: bookingData.providerId,
          serviceId: bookingData.serviceId,
          emailTrigger
        });
        
        // If this is a direct payment with iDEAL, validate the SendGrid API key to ensure emails can be sent
        try {
          console.log("Validating SendGrid API key before processing booking...");
          const { checkSendGridApiKey, emailSystem } = await import('./email');
          const isApiKeyValid = await checkSendGridApiKey();
          console.log(`SendGrid API key validation result: ${isApiKeyValid ? 'Valid' : 'Invalid'}`);
          
          if (!isApiKeyValid) {
            console.warn("SendGrid API key validation failed. Email sending might not work properly.");
            console.log("Email system status:", {
              isConfigured: emailSystem.isConfigured,
              isApiKeyWorking: emailSystem.isApiKeyWorking,
              errorMessage: emailSystem.errorMessage,
              hasCredits: emailSystem.hasCredits,
              maxCreditsExceeded: emailSystem.maxCreditsExceeded
            });
          }
        } catch (apiKeyValidationError) {
          console.error("Error during SendGrid API key validation:", apiKeyValidationError);
          // Continue with booking process even if validation fails
        }
      }

      // Get the service to calculate price
      const service = await storage.getService(bookingData.serviceId);
      const user = await storage.getUser(bookingData.userId);
      const provider = await storage.getUser(bookingData.providerId);

      if (!service || !user || !provider) {
        console.error("Missing required data:", {
          serviceFound: !!service,
          userFound: !!user,
          providerFound: !!provider
        });
        return res.status(400).json({ message: "Missing service, user, or provider data" });
      }
      
      console.log("USER DATA FOUND:", {
        userId: user.id,
        userEmail: user.email,
        displayName: user.displayName
      });
      
      console.log("SERVICE DATA FOUND:", {
        serviceId: service.id,
        serviceName: service.name,
        providerId: service.providerId
      });

      // Check if this is a direct payment (paymentIntentId and isPaid should be provided)
      // or if emailTrigger flag is set 
      if ((bookingData.paymentIntentId && bookingData.isPaid) || emailTrigger) {
        // This is a direct payment - create booking with payment_successful status
        // Remove images field if it exists since it's not in the service_bookings table
        console.log("Removing images field for database compatibility");
        const { images, ...bookingDataWithoutImages } = bookingData as any;
        
        console.log("Processing booking data for database");
        
        const directBookingData = {
          ...bookingDataWithoutImages,
          status: BookingStatus.PAYMENT_SUCCESSFUL, // Use payment_successful status
          paymentIntentId: bookingData.paymentIntentId,
          isPaid: true,
          emailSent: false // Initialize as false
        };

        // Create booking with direct payment
        const booking = await storage.createServiceBooking(directBookingData);

        // Prepare detailed logging
        console.log(`BOOKING ID ${booking.id}: Payment data received:`, {
          serviceId: service.id,
          serviceName: service.name,
          userEmail: user.email,
          providerEmail: provider.email,
          paymentIntentId: booking.paymentIntentId,
          isPaid: booking.isPaid,
          status: booking.status
        });
        
        // Send confirmation emails to both customer and provider
        let customerEmailSent = false;
        let providerEmailSent = false;
        
        try {
          // Send confirmation to the customer with PDF attachment
          console.log(`BOOKING ID ${booking.id}: Attempting to send confirmation email to customer ${user.email} (ID: ${user.id})`);
          try {
            customerEmailSent = await sendBookingConfirmationEmail(user, service, booking);
            if (customerEmailSent) {
              console.log(`BOOKING ID ${booking.id}: Booking confirmation email sent successfully to customer ${user.email} (ID: ${user.id})`);
            } else {
              console.error(`BOOKING ID ${booking.id}: Failed to send booking confirmation email to customer ${user.email} (ID: ${user.id}) - No error thrown but email not sent`);
              
              // Try one more time after a short delay
              console.log(`BOOKING ID ${booking.id}: Retrying customer email after 1 second delay...`);
              await new Promise(resolve => setTimeout(resolve, 1000));
              customerEmailSent = await sendBookingConfirmationEmail(user, service, booking);
              console.log(`BOOKING ID ${booking.id}: Retry attempt for customer email ${customerEmailSent ? 'successful' : 'failed'}`);
            }
          } catch (emailError) {
            console.error(`BOOKING ID ${booking.id}: Error sending confirmation email to customer:`, emailError);
            // Try one more time after a short delay
            try {
              console.log(`BOOKING ID ${booking.id}: Retrying customer email after error occurred...`);
              await new Promise(resolve => setTimeout(resolve, 1000));
              customerEmailSent = await sendBookingConfirmationEmail(user, service, booking);
              console.log(`BOOKING ID ${booking.id}: Retry attempt for customer email ${customerEmailSent ? 'successful' : 'failed'}`);
            } catch (retryError) {
              console.error(`BOOKING ID ${booking.id}: Retry attempt failed:`, retryError);
            }
          }
          
          // Send notification to the provider
          console.log(`BOOKING ID ${booking.id}: Attempting to send notification email to provider ${provider.email} (ID: ${provider.id})`);
          try {
            providerEmailSent = await sendProviderNotificationEmail(provider, user, service, booking);
            if (providerEmailSent) {
              console.log(`BOOKING ID ${booking.id}: Booking notification email sent successfully to provider ${provider.email} (ID: ${provider.id})`);
            } else {
              console.warn(`BOOKING ID ${booking.id}: Failed to send booking notification email to provider ${provider.email} (ID: ${provider.id})`);
              
              // Try one more time after a short delay
              console.log(`BOOKING ID ${booking.id}: Retrying provider email after 1 second delay...`);
              await new Promise(resolve => setTimeout(resolve, 1000));
              providerEmailSent = await sendProviderNotificationEmail(provider, user, service, booking);
              console.log(`BOOKING ID ${booking.id}: Retry attempt for provider email ${providerEmailSent ? 'successful' : 'failed'}`);
            }
          } catch (emailError) {
            console.error(`BOOKING ID ${booking.id}: Error sending notification email to provider:`, emailError);
            
            // Try one more time
            try {
              console.log(`BOOKING ID ${booking.id}: Retrying provider email after error occurred...`);
              await new Promise(resolve => setTimeout(resolve, 1000));
              providerEmailSent = await sendProviderNotificationEmail(provider, user, service, booking);
              console.log(`BOOKING ID ${booking.id}: Retry attempt for provider email ${providerEmailSent ? 'successful' : 'failed'}`);
            } catch (retry2Error) {
              console.error(`BOOKING ID ${booking.id}: Second retry attempt failed:`, retry2Error);
            }
          }
          
          // Mark booking as having emails sent if at least one email was successful
          if (customerEmailSent || providerEmailSent) {
            await storage.updateServiceBooking(booking.id, { emailSent: true });
            console.log(`Booking ${booking.id} marked as having emails sent`);
          } else {
            console.error(`BOOKING ID ${booking.id}: Neither customer nor provider email sent successfully`);
          }
        } catch (emailError) {
          console.error("Error sending booking confirmation emails:", emailError);
          // Continue with the process even if emails fail
        }

        // Create notification for the provider
        await storage.createAdminNotification({
          toUserId: provider.id,
          title: "New Service Booking",
          message: `${user.displayName} has booked and paid for ${service.name}.`,
          type: "booking",
          actionLink: "/bookings",
          actionText: "View Booking",
          metadata: JSON.stringify({
            bookingId: booking.id,
            serviceId: service.id,
            userId: user.id
          })
        });

        // Send real-time notification via WebSocket
        try {
          const { notifyServiceBooking } = await import('./websocket');
          notifyServiceBooking(provider.id, booking, user, service);
          console.log(`WebSocket notification sent to provider (ID: ${provider.id}) for booking ${booking.id}`);
        } catch (wsError) {
          console.error(`Error sending WebSocket notification for booking ${booking.id}:`, wsError);
          // Continue even if WebSocket notification fails
        }

        return res.status(201).json({
          booking,
          success: true,
          message: "Booking created and confirmed with payment!"
        });
      } else {
        // Legacy flow (create payment intent first)
        const amount = Math.round(parseFloat(service.price) * 100); // Convert to cents

        try {
          const paymentIntent = await createPaymentIntent({
            amount,
            metadata: {
              serviceId: service.id.toString(),
              userId: user.id.toString(),
              providerId: provider.id.toString()
            }
          });

          // Create booking with payment intent and pending approval status
          // Remove images field if it exists since it's not in the service_bookings table
          console.log("Removing images field for database compatibility (legacy flow)");
          const { images, ...bookingDataWithoutImages } = bookingData as any;
          
          console.log("Processing booking data for database (legacy flow)");
          
          const bookingDataWithPayment = {
            ...bookingDataWithoutImages,
            status: BookingStatus.PENDING_APPROVAL,
            paymentIntentId: paymentIntent.id,
            isPaid: true
          };

          const booking = await storage.createServiceBooking(bookingDataWithPayment);

          // Create admin notification
          await storage.createAdminNotification({
            toUserId: provider.id,
            title: "New Service Purchase",
            message: `${user.displayName} has purchased ${service.name}. Pending admin approval.`,
            type: "purchase",
            actionLink: "/admin/purchases",
            actionText: "Review Purchase",
            metadata: JSON.stringify({
              bookingId: booking.id,
              serviceId: service.id,
              userId: user.id
            })
          });

          return res.status(201).json({
            booking,
            clientSecret: paymentIntent.client_secret
          });
        } catch (paymentError) {
          console.error("Error creating payment intent:", paymentError);
          return res.status(500).json({
            message: "Failed to process payment",
            error: paymentError
          });
        }
      }
    } catch (error) {
      console.error("Error creating service booking:", error);
      return res.status(400).json({ message: "Failed to create service booking", error });
    }
  });

  app.post("/api/service-bookings/:id/approve", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);

      // First check if the booking exists and is paid
      const booking = await storage.getServiceBooking(bookingId);

      if (!booking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      if (!booking.isPaid) {
        return res.status(400).json({ message: "Cannot approve unpaid booking" });
      }

      const updatedBooking = await storage.approveServiceBooking(bookingId);

      if (!updatedBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      // Get necessary data for emails
      const service = await storage.getService(updatedBooking.serviceId);
      const user = await storage.getUser(updatedBooking.userId);
      const provider = await storage.getUser(updatedBooking.providerId);

      if (service && user && provider) {
        // Send booking confirmation emails
        try {
          // Send confirmation to the customer
          const customerEmailSent = await sendBookingConfirmationEmail(user, service, updatedBooking);
          console.log(`Customer booking confirmation email sent: ${customerEmailSent}`);
          
          // Send notification to the provider
          const providerEmailSent = await sendProviderNotificationEmail(provider, user, service, updatedBooking);
          console.log(`Provider booking notification email sent: ${providerEmailSent}`);

          if (customerEmailSent && providerEmailSent) {
            await storage.updateServiceBooking(bookingId, { emailSent: true });
            console.log(`Booking ${bookingId} marked as having emails sent`);
          }
          
          // Send real-time notifications via WebSocket
          try {
            const { notifyBookingStatusUpdate } = await import('./websocket');
            notifyBookingStatusUpdate(
              user.id,
              provider.id,
              updatedBooking,
              service,
              "Your booking has been approved and confirmed!"
            );
            console.log(`WebSocket notification sent for booking approval (Booking ID: ${bookingId})`);
          } catch (wsError) {
            console.error(`Error sending WebSocket notification for booking approval:`, wsError);
            // Continue even if WebSocket notification fails
          }
        } catch (emailError) {
          console.error("Error sending confirmation emails:", emailError);
          // Continue with the process even if emails fail
        }
      }

      res.json(updatedBooking);
    } catch (error) {
      console.error("Error approving service booking:", error);
      res.status(500).json({ message: "Failed to approve service booking" });
    }
  });

  app.post("/api/service-bookings/:id/reject", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      const { message } = req.body;
      const updatedBooking = await storage.rejectServiceBooking(bookingId, message);

      if (!updatedBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      // Send status update emails
      try {
        // Get the necessary data for emails
        const service = await storage.getService(updatedBooking.serviceId);
        const user = await storage.getUser(updatedBooking.userId);
        const provider = await storage.getUser(updatedBooking.providerId);

        if (service && user && provider) {
          // Send email to customer
          const emailSent = await sendBookingStatusUpdateEmail(user, service, updatedBooking);

          if (emailSent) {
            console.log(`Booking rejection email sent to customer (ID: ${user.id})`);
            
            // Send notification to provider
            const providerEmailSent = await sendProviderStatusUpdateEmail(provider, user, service, updatedBooking);
            
            if (providerEmailSent) {
              console.log(`Booking rejection notification sent to provider (ID: ${provider.id})`);
            } else {
              console.warn(`Failed to send booking rejection notification to provider (ID: ${provider.id})`);
            }

            // Update booking to mark email as sent
            await storage.updateServiceBooking(bookingId, { emailSent: true });
            
            // Send real-time WebSocket notifications
            try {
              const { notifyBookingStatusUpdate } = await import('./websocket');
              // Notify customer
              notifyBookingStatusUpdate(
                user.id,
                provider.id,
                updatedBooking,
                service,
                `Your booking for ${service.name} has been rejected: ${message || 'No reason provided'}`
              );
              console.log(`WebSocket notification sent to customer (ID: ${user.id}) for booking rejection`);
            } catch (wsError) {
              console.error(`Error sending WebSocket notification for booking rejection:`, wsError);
              // Continue even if WebSocket notification fails
            }
          } else {
            console.warn(`Failed to send booking rejection email to customer (ID: ${user.id})`);
          }
        } else {
          console.warn(`Missing data for email notification: service=${!!service}, user=${!!user}, provider=${!!provider}`);
        }
      } catch (emailError) {
        console.error("Error sending booking rejection emails:", emailError);
        // Continue with the response even if email sending fails
      }

      res.json(updatedBooking);
    } catch (error) {
      console.error("Error rejecting service booking:", error);
      res.status(500).json({ message: "Failed to reject service booking" });
    }
  });

  app.post("/api/service-bookings/:id/payment", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      console.log("PAYMENT UPDATE REQUEST BODY:", req.body);
      const { paymentIntentId, status, isPaid } = req.body; // Extract isPaid from request

      const { createRefund } = await import('./stripe');
      const stripe = await import('stripe').then(module => new module.default(process.env.STRIPE_SECRET_KEY!));

      // Retrieve the payment intent from Stripe to verify its status
      const paymentIntent = await stripe.paymentIntents.retrieve(paymentIntentId);

      if (paymentIntent.status !== 'succeeded') {
        return res.status(400).json({ 
          message: "Payment verification failed", 
          paymentStatus: paymentIntent.status 
        });
      }

      // Update the booking status
      const updatedBooking = await storage.updateServiceBooking(bookingId, { 
        isPaid: true,
        paymentIntentId: paymentIntent.id
      });

      if (!updatedBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      // Get related data for email
      const service = await storage.getService(updatedBooking.serviceId);
      const user = await storage.getUser(updatedBooking.userId);
      const provider = await storage.getUser(updatedBooking.providerId);

      console.log("Email preparation data:", {
        hasService: !!service,
        hasUser: !!user,
        hasProvider: !!provider,
        booking: {
          id: updatedBooking.id,
          status: updatedBooking.status,
          isPaid: updatedBooking.isPaid
        }
      });

      if (service && user && provider) {
        try {
          // Send booking confirmation to customer with PDF attached
          let customerEmailSent = await sendBookingConfirmationEmail(user, service, updatedBooking);
          
          if (customerEmailSent) {
            console.log(`Payment confirmation email sent to customer (ID: ${user.id})`);
          } else {
            console.warn(`Failed to send payment confirmation email to customer (ID: ${user.id})`);
            // Retry once after delay
            console.log("Retrying customer email after 1 second delay...");
            await new Promise(resolve => setTimeout(resolve, 1000));
            customerEmailSent = await sendBookingConfirmationEmail(user, service, updatedBooking);
            console.log(`Customer email retry ${customerEmailSent ? 'successful' : 'failed'}`);
          }

          // Send notification to provider
          let providerEmailSent = await sendProviderNotificationEmail(provider, user, service, updatedBooking);
          
          if (providerEmailSent) {
            console.log(`Payment notification email sent to provider (ID: ${provider.id})`);
          } else {
            console.warn(`Failed to send payment notification email to provider (ID: ${provider.id})`);
            // Retry once after delay
            console.log("Retrying provider email after 1 second delay...");
            await new Promise(resolve => setTimeout(resolve, 1000));
            providerEmailSent = await sendProviderNotificationEmail(provider, user, service, updatedBooking);
            console.log(`Provider email retry ${providerEmailSent ? 'successful' : 'failed'}`);
          }
          
          // Notify admins about the new booking that needs approval
          try {
            // Create notifications for all admins
            const admins = await storage.getUsersByRole("admin");
            if (admins && admins.length > 0) {
              // Send WebSocket notification to admins
              const { notifyServiceBooking } = await import('./websocket');
              
              // Notify via WebSocket
              notifyServiceBooking(
                provider.id,
                updatedBooking,
                user,
                service
              );
              
              // Create persistent notifications for each admin
              for (const admin of admins) {
                await storage.createUserNotification({
                  userId: admin.id,
                  type: "SERVICE_BOOKING",
                  title: "New Service Booking Requires Approval",
                  message: `${user.displayName} has booked service "${service.name}" and payment has been completed. This booking requires admin approval.`,
                  actionLink: `/admin/service-bookings/${updatedBooking.id}`,
                  actionText: "Review Booking",
                  isPinned: true, // Pin this notification so it stands out
                });
              }
              console.log(`Notifications sent to ${admins.length} admin(s) about new service booking #${updatedBooking.id}`);
            }
          } catch (notifyError) {
            console.error("Error notifying admins about new service booking:", notifyError);
            // Continue even if notification fails
          }

          // Mark booking as having emails sent if at least one succeeded
          if (customerEmailSent || providerEmailSent) {
            await storage.updateServiceBooking(bookingId, { emailSent: true });
            console.log(`Booking ${bookingId} marked as having emails sent`);
          } else {
            console.error(`Neither customer nor provider email sent successfully for booking ${bookingId}`);
          }
        } catch (emailError) {
          console.error("Error sending payment confirmation emails:", emailError);
          // Continue with the process even if emails fail
        }
      } else {
        console.warn(`Missing data for email notification: service=${!!service}, user=${!!user}, provider=${!!provider}`);
      }

      res.json({ 
        success: true, 
        message: "Payment verified and booking updated",
        booking: updatedBooking
      });
    } catch (error) {
      console.error("Error updating booking payment status:", error);
      res.status(500).json({ message: "Failed to update booking payment status" });
    }
  });

  app.post("/api/service-bookings/:id/payment-intent", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      const booking = await storage.getServiceBooking(bookingId);

      if (!booking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      if (booking.isPaid) {
        return res.status(400).json({ message: "Booking is already paid" });
      }

      // Get service data for the price
      const service = await storage.getService(booking.serviceId);
      if (!service) {
        return res.status(404).json({ message: "Service not found" });
      }

      // Calculate amount to charge
      const priceInCents = parseInt(parseFloat(service.price) * 100);

      // Create or retrieve a payment intent
      try {
        const { createPaymentIntent } = await import('./stripe');

        // If there's already a payment intent ID stored, use that
        if (booking.paymentIntentId) {
          // Retrieve existing payment intent
          const stripe = await import('stripe').then(module => new module.default(process.env.STRIPE_SECRET_KEY!));
          const paymentIntent = await stripe.paymentIntents.retrieve(booking.paymentIntentId);

          // Return the client secret for the frontend to use
          res.json({ clientSecret: paymentIntent.client_secret });
        } else {
          // Create a new payment intent
          const paymentIntent = await createPaymentIntent({
            amount: priceInCents,
            metadata: {
              bookingId: booking.id.toString(),
              serviceId: service.id.toString(),
              userId: booking.userId.toString(),
              providerId: service.providerId.toString()
            }
          });

          // Update the booking with the payment intent ID
          await storage.updateServiceBooking(bookingId, { 
            paymentIntentId: paymentIntent.id 
          });

          // Return the client secret for the frontend to use
          res.json({ clientSecret: paymentIntent.client_secret });
        }
      } catch (stripeError) {
        console.error("Error creating/retrieving payment intent:", stripeError);
        res.status(500).json({ message: "Failed to create payment intent" });
      }
    } catch (error) {
      console.error("Error creating payment intent for booking:", error);
      res.status(500).json({ message: "Failed to create payment intent for booking" });
    }
  });
  
  // New endpoint for direct payment intents (without prior booking creation)
  app.post("/api/service-bookings/direct-payment-intent", async (req: Request, res: Response) => {
    try {
      const { serviceId, amount, metadata } = req.body;
      
      if (!serviceId || !amount) {
        return res.status(400).json({ message: "Missing required parameters: serviceId and amount" });
      }
      
      // Get service data
      const service = await storage.getService(parseInt(serviceId));
      if (!service) {
        return res.status(404).json({ message: "Service not found" });
      }
      
      // Create a new direct payment intent
      try {
        const { createPaymentIntent } = await import('./stripe');
        
        const paymentIntent = await createPaymentIntent({
          amount: amount, // Already provided in cents from the client
          metadata: {
            serviceId: serviceId.toString(),
            directPayment: "true",
            ...metadata
          },
          description: `Direct payment for ${service.name}`
        });
        
        // Return the client secret for the frontend to use
        res.json({ 
          clientSecret: paymentIntent.client_secret,
          data: {
            serviceId,
            serviceName: service.name,
            amount
          }
        });
      } catch (stripeError) {
        console.error("Error creating direct payment intent:", stripeError);
        res.status(500).json({ message: "Failed to create direct payment intent" });
      }
    } catch (error) {
      console.error("Error processing direct payment intent request:", error);
      res.status(500).json({ message: "Failed to process direct payment request" });
    }
  });

  // This endpoint is implemented more comprehensively elsewhere in the file
  // The duplicate endpoint has been removed to fix routing issues
  
  // Special endpoint specifically for iDEAL payment verification
  // Special endpoint for handling iDEAL payment redirects
  app.get("/api/ideal-payment-redirect/:id", async (req: Request, res: Response) => {
    try {
      const paymentIntentId = req.params.id;
      
      if (!paymentIntentId) {
        return res.status(400).json({ message: "Missing payment intent ID" });
      }
      
      console.log(`[iDEAL] Processing redirect for payment intent: ${paymentIntentId}`);
      
      // Redirect the user to the payment redirect page with the payment intent ID
      res.redirect(`/payment-redirect?payment_intent=${paymentIntentId}&redirect_status=returned&source=ideal`);
    } catch (error) {
      console.error("[iDEAL] Error processing payment redirect:", error);
      res.redirect('/payment-redirect?error=true&message=Failed+to+process+payment+redirect');
    }
  });

  app.get("/api/ideal-payment-status/:id", async (req: Request, res: Response) => {
    try {
      const paymentIntentId = req.params.id;
      
      if (!paymentIntentId) {
        return res.status(400).json({ message: "Missing payment intent ID" });
      }
      
      console.log(`[iDEAL] Checking status for payment intent: ${paymentIntentId}`);
      
      try {
        // Import Stripe and retrieve the payment intent with expanded details for better debugging
        const stripe = await import('stripe').then(module => new module.default(process.env.STRIPE_SECRET_KEY!));
        const paymentIntent = await stripe.paymentIntents.retrieve(paymentIntentId, {
          expand: ['latest_charge', 'payment_method']
        });
        
        console.log(`[iDEAL] Payment intent status: ${paymentIntent.status}`);
        
        if (paymentIntent.payment_method_types.includes('ideal')) {
          console.log("[iDEAL] Confirmed this is an iDEAL payment");
        }
        
        // Look for any bookings with this payment intent
        const allBookings = await storage.getAllServiceBookings();
        const matchingBookings = allBookings.filter(booking => 
          booking.paymentIntentId === paymentIntentId
        );
        
        console.log(`[iDEAL] Found ${matchingBookings.length} bookings with this payment intent ID`);
        
        // Get charges for additional details
        let chargeData = null;
        if (paymentIntent.latest_charge) {
          // Use the expanded charge data
          const charge = paymentIntent.latest_charge as any;
          console.log(`[iDEAL] Latest charge status: ${charge.status}`);
          chargeData = {
            id: charge.id,
            status: charge.status,
            outcome: charge.outcome
          };
        }
        
        // Return payment intent status and any associated bookings
        res.json({
          paymentIntentId,
          status: paymentIntent.status,
          amount: paymentIntent.amount,
          currency: paymentIntent.currency,
          paymentMethod: paymentIntent.payment_method_types,
          metadata: paymentIntent.metadata,
          created: new Date(paymentIntent.created * 1000).toISOString(),
          hasBooking: matchingBookings.length > 0,
          chargeData,
          bookingDetails: matchingBookings.length > 0 ? {
            bookingId: matchingBookings[0].id,
            status: matchingBookings[0].status,
            serviceId: matchingBookings[0].serviceId,
            isPaid: matchingBookings[0].isPaid,
            createdAt: matchingBookings[0].createdAt
          } : null
        });
      } catch (stripeError: any) {
        console.error("[iDEAL] Error retrieving payment intent:", stripeError);
        
        // Additional logging for network errors which can be common with external APIs
        if (stripeError.type === 'StripeConnectionError') {
          console.error("[iDEAL] Stripe connection error - possible network issue");
        }
        
        res.status(404).json({ 
          message: "Payment intent not found or error retrieving",
          error: stripeError.message,
          type: stripeError.type || 'unknown'
        });
      }
    } catch (error) {
      console.error("[iDEAL] Server error checking payment intent status:", error);
      res.status(500).json({ message: "Server error checking payment status" });
    }
  });

  app.post("/api/service-bookings/:id/complete", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      const updatedBooking = await storage.completeServiceBooking(bookingId);

      if (!updatedBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      // Send status update emails
      try {
        // Get the necessary data for emails
        const service = await storage.getService(updatedBooking.serviceId);
        const user = await storage.getUser(updatedBooking.userId);
        const provider = await storage.getUser(updatedBooking.providerId);

        if (service && user && provider) {
          // Import email functions
          const { sendBookingStatusUpdateEmail, sendProviderStatusUpdateEmail } = await import('./email');

          // Send email to customer
          const customerEmailSent = await sendBookingStatusUpdateEmail(user, service, updatedBooking);

          if (customerEmailSent) {
            console.log(`Booking completion email sent to customer (ID: ${user.id})`);
          } else {
            console.warn(`Failed to send booking completion email to customer (ID: ${user.id})`);
          }

          // Send email to provider
          const providerEmailSent = await sendProviderStatusUpdateEmail(provider, user, service, updatedBooking);

          if (providerEmailSent) {
            console.log(`Booking completion notification sent to provider (ID: ${provider.id})`);
          } else {
            console.warn(`Failed to send booking completion notification to provider (ID: ${provider.id})`);
          }

          // Update booking to mark email as sent
          await storage.updateServiceBooking(bookingId, { emailSent: true });
        } else {
          console.warn(`Missing data for email notification: service=${!!service}, user=${!!user}, provider=${!!provider}`);
        }
      } catch (emailError) {
        console.error("Error sending booking completion emails:", emailError);
        // Continue with the response even if email sending fails
      }

      res.json(updatedBooking);
    } catch (error) {
      console.error("Error completing service booking:", error);
      res.status(500).json({ message: "Failed to complete service booking" });
    }
  });

  app.post("/api/service-bookings/:id/cancel", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      const { message } = req.body;
      const updatedBooking = await storage.cancelServiceBooking(bookingId, message);

      if (!updatedBooking) {
        return res.status(404).json({ message: "Service booking not found" });
      }

      // Send status update emails
      try {
        // Get the necessary data for emails
        const service = await storage.getService(updatedBooking.serviceId);
        const user = await storage.getUser(updatedBooking.userId);
        const provider = await storage.getUser(updatedBooking.providerId);

        if (service && user && provider) {
          // Import email functions
          const { sendBookingStatusUpdateEmail, sendProviderStatusUpdateEmail } = await import('./email');

          // Send email to customer
          const customerEmailSent = await sendBookingStatusUpdateEmail(user, service, updatedBooking);

          if (customerEmailSent) {
            console.log(`Booking cancellation email sent to customer (ID: ${user.id})`);
          } else {
            console.warn(`Failed to send booking cancellation email to customer (ID: ${user.id})`);
          }

          // Send email to provider
          const providerEmailSent = await sendProviderStatusUpdateEmail(provider, user, service, updatedBooking);

          if (providerEmailSent) {
            console.log(`Booking cancellation notification sent to provider (ID: ${provider.id})`);
          } else {
            console.warn(`Failed to send booking cancellation notification to provider (ID: ${provider.id})`);
          }

          // Update booking to mark email as sent
          await storage.updateServiceBooking(bookingId, { emailSent: true });
        } else {
          console.warn(`Missing data for email notification: service=${!!service}, user=${!!user}, provider=${!!provider}`);
        }
      } catch (emailError) {
        console.error("Error sending booking cancellation emails:", emailError);
        // Continue with the response even if email sending fails
      }

      // If the booking has a payment intent, issue a refund
      if (updatedBooking.paymentIntentId && updatedBooking.isPaid) {
        try {
          const { createRefund } = await import('./stripe');
          const refund = await createRefund(updatedBooking.paymentIntentId);

          if (refund) {
            console.log(`Refund issued for booking ${bookingId}, payment intent: ${updatedBooking.paymentIntentId}`);

            // Mark the booking as refunded
            await storage.updateServiceBooking(bookingId, { isRefunded: true });
          }
        } catch (refundError) {
          console.error(`Error issuing refund for booking ${bookingId}:`, refundError);
        }
      }

      res.json(updatedBooking);
    } catch (error) {
      console.error("Error cancelling service booking:", error);
      res.status(500).json({ message: "Failed to cancel service booking" });
    }
  });

  app.delete("/api/service-bookings/:id", async (req: Request, res: Response) => {
    try {
      const bookingId = parseInt(req.params.id);
      
      // First check if the booking exists
      const booking = await storage.getServiceBooking(bookingId);
      
      if (!booking) {
        return res.status(404).json({ message: "Service booking not found" });
      }
      
      // Check if user has permission to delete this booking
      // Only the provider, customer, or an admin can delete a booking
      const currentUser = req.user as User;
      if (currentUser.id !== booking.providerId && 
          currentUser.id !== booking.userId && 
          currentUser.role !== "admin") {
        return res.status(403).json({ message: "You don't have permission to delete this booking" });
      }
      
      // If the booking is paid and not refunded, issue a refund first
      if (booking.paymentIntentId && booking.isPaid && !booking.isRefunded) {
        try {
          const { createRefund } = await import('./stripe');
          await createRefund(booking.paymentIntentId);
          console.log(`Refund issued for booking ${bookingId} before deletion`);
        } catch (refundError) {
          console.error(`Error issuing refund for booking ${bookingId} before deletion:`, refundError);
          // Continue with deletion even if refund fails, but notify the admin
          await storage.createAdminNotification({
            title: "Refund Failed on Booking Deletion",
            message: `Failed to issue refund for booking ${bookingId} during deletion. Payment intent: ${booking.paymentIntentId}`,
            type: "error",
            toUserId: null // Send to all admins
          });
        }
      }
      
      // Now delete the booking
      const success = await storage.deleteServiceBooking(bookingId);
      
      if (success) {
        // Log admin action if an admin deleted the booking
        if (currentUser.role === "admin") {
          await storage.createAdminAction({
            adminId: currentUser.id,
            actionType: "booking_deletion",
            targetId: bookingId,
            targetType: "booking",
            details: `Admin deleted service booking #${bookingId}`
          });
        }
        
        res.json({ message: "Service booking deleted successfully" });
      } else {
        res.status(400).json({ message: "Failed to delete service booking" });
      }
    } catch (error) {
      console.error("Error deleting service booking:", error);
      res.status(500).json({ message: "Failed to delete service booking", error });
    }
  });

  // Enhanced iDEAL-specific payment status endpoint with metadata and booking verification
  // This endpoint is kept as a fallback for the other implementation 
  // to prevent duplicate routes it redirects to the primary implementation
  // This endpoint was duplicated - removing the simplified version since we already have
  // a more comprehensive implementation earlier in the file
  
  // Standard payment intent status endpoint with enhanced cache controls
  app.get('/api/payment-intent-status/:id', async (req: Request, res: Response) => {
    try {
      const { id } = req.params;
      
      if (!id) {
        return res.status(400).json({ message: 'Payment intent ID is required' });
      }
      
      console.log(`Checking status for payment intent ${id}`);
      
      const { getPaymentIntentStatus } = await import('./stripe');
      const paymentIntent = await getPaymentIntentStatus(id);
      
      console.log(`Payment intent ${id} status: ${paymentIntent.status}`);
      
      // Check if this payment intent already has an associated booking
      const existingBookings = await storage.getServiceBookingsByPaymentIntentId(id);
      const hasBooking = existingBookings && existingBookings.length > 0;
      
      // Set cache control headers to prevent caching
      res.setHeader('Cache-Control', 'no-store, no-cache, must-revalidate, proxy-revalidate');
      res.setHeader('Pragma', 'no-cache');
      
      return res.json({
        id: paymentIntent.id,
        status: paymentIntent.status,
        metadata: paymentIntent.metadata || {},
        hasBooking,
        bookingDetails: hasBooking ? {
          bookingId: existingBookings[0].id,
          serviceId: existingBookings[0].serviceId
        } : null
      });
    } catch (error: any) {
      console.error('Error getting payment intent status:', error);
      return res.status(500).json({ 
        message: 'Failed to retrieve payment intent status',
        error: error.message 
      });
    }
  });
  
  // Legacy payment intent status endpoint - for backwards compatibility
  app.get('/api/payment-intents/:id/status', async (req: Request, res: Response) => {
    try {
      const { id } = req.params;
      
      if (!id) {
        return res.status(400).json({ message: 'Payment intent ID is required' });
      }
      
      console.log(`[Legacy] Checking status for payment intent ${id}`);
      
      const { getPaymentIntentStatus } = await import('./stripe');
      const paymentIntent = await getPaymentIntentStatus(id);
      
      console.log(`[Legacy] Payment intent ${id} status: ${paymentIntent.status}`);
      
      return res.json(paymentIntent);
    } catch (error: any) {
      console.error('[Legacy] Error getting payment intent status:', error);
      return res.status(500).json({ 
        message: 'Failed to retrieve payment intent status',
        error: error.message 
      });
    }
  });

  // Email System Status and Reset Endpoint
  app.get("/api/email-status", async (req: Request, res: Response) => {
    try {
      const { emailSystem, checkSendGridApiKey, setEmailDebugMode, sendTestEmail } = await import('./email');
      
      // If reset parameter is provided, attempt to reset email system
      if (req.query.reset === 'true') {
        console.log("Resetting email system and validating API key...");
        
        // Reset error counters
        emailSystem.totalAttempts = 0;
        emailSystem.successfulAttempts = 0;
        emailSystem.failedAttempts = 0;
        emailSystem.maxCreditsExceeded = false;
        emailSystem.hasCredits = true;
        emailSystem.errorMessage = '';
        emailSystem.lastError = null;
        emailSystem.debugLogs = [];
        
        // Always enable debug mode when we reset
        setEmailDebugMode(true);
        console.log("Email debug mode enabled during system reset");
        
        // Re-validate API key
        const apiKeyValid = await checkSendGridApiKey();
        console.log(`SendGrid API key validation result after reset: ${apiKeyValid}`);
      }
      
      // If test parameter is provided, send a test email
      if (req.query.test === 'true') {
        console.log("Sending test email to verify email system...");
        
        // Try to get the test destination from query params
        const testEmail = req.query.email as string || process.env.ADMIN_EMAIL;
        
        if (!testEmail) {
          console.warn("No test email address provided and no admin email configured");
          return res.status(400).json({
            message: "Cannot send test email - no destination address provided and no admin email configured",
            emailSystem: {
              isConfigured: emailSystem.isConfigured,
              isEnabled: emailSystem.isEnabled,
              hasErrors: !!emailSystem.errorMessage
            }
          });
        }
        
        // Determine the test type - 'booking' parameter sends a full booking test with PDF
        const testType = req.query.type as string || 'simple'; 
        
        try {
          console.log(`Sending ${testType} test email to ${testEmail}...`);
          const testResult = await sendTestEmail(testEmail, testType);
          console.log(`Test email result: ${testResult ? 'Success' : 'Failed'}`);
        } catch (testError) {
          console.error("Error sending test email:", testError);
          return res.status(500).json({
            message: "Failed to send test email",
            error: testError instanceof Error ? testError.message : String(testError)
          });
        }
      }
      
      // If enable_debug parameter is provided, set debug mode
      if (req.query.enable_debug !== undefined) {
        const enableDebug = req.query.enable_debug === 'true';
        console.log(`Setting email debug mode to: ${enableDebug}`);
        setEmailDebugMode(enableDebug);
      }
      
      // Return current status
      return res.json({
        emailSystem: {
          isConfigured: emailSystem.isConfigured,
          isEnabled: emailSystem.isEnabled,
          hasCredits: emailSystem.hasCredits,
          maxCreditsExceeded: emailSystem.maxCreditsExceeded,
          isApiKeyWorking: emailSystem.isApiKeyWorking,
          lastApiKeyCheck: emailSystem.lastApiKeyCheck,
          errorMessage: emailSystem.errorMessage,
          stats: {
            totalAttempts: emailSystem.totalAttempts,
            successfulAttempts: emailSystem.successfulAttempts,
            failedAttempts: emailSystem.failedAttempts,
            lastSuccessfulSendTime: emailSystem.lastSuccessfulSendTime
          },
          debug: emailSystem.debug,
          recentLogs: emailSystem.debugLogs.slice(0, 10) // Only return the 10 most recent logs
        },
        environment: {
          sendgridApiKeyPresent: !!process.env.SENDGRID_API_KEY,
          sendgridApiKeyLength: process.env.SENDGRID_API_KEY ? process.env.SENDGRID_API_KEY.length : 0,
          verifiedSenderEmail: process.env.VERIFIED_SENDER_EMAIL || null,
          adminEmail: process.env.ADMIN_EMAIL || null
        }
      });
    } catch (error) {
      console.error("Error getting email system status:", error);
      return res.status(500).json({
        message: "Failed to retrieve email system status",
        error: error instanceof Error ? error.message : String(error)
      });
    }
  });

  // Service Time Slot Routes
  app.get("/api/service-time-slots/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const timeSlot = await storage.getServiceTimeSlot(id);
      
      if (!timeSlot) {
        return res.status(404).json({ error: "Time slot not found" });
      }
      
      res.json(timeSlot);
    } catch (error) {
      console.error("Error fetching time slot:", error);
      res.status(500).json({ error: "Failed to fetch time slot" });
    }
  });

  app.get("/api/service-time-slots", async (req: Request, res: Response) => {
    try {
      // Check for authentication
      const user = await getCurrentUser(req);
      
      // If unauthorized and requesting specific provider's slots, reject
      if (!user && req.query.providerId) {
        return res.status(401).json({ error: "Authentication required to view provider time slots" });
      }
      
      const { serviceId, providerId, date } = req.query;
      let timeSlots: ServiceTimeSlot[] = [];
      
      if (serviceId) {
        const id = parseInt(serviceId as string);
        if (req.query.available === 'true') {
          timeSlots = await storage.getAvailableServiceTimeSlots(id);
        } else {
          // If requesting all slots for a service, require auth if not available=true
          if (req.query.available !== 'true' && !user) {
            return res.status(401).json({ error: "Authentication required to view all service time slots" });
          }
          timeSlots = await storage.getServiceTimeSlotsByService(id);
        }
      } else if (providerId) {
        const id = parseInt(providerId as string);
        
        // For provider-specific slots, verify the user is the provider or an admin
        if (user && (user.id === id || user.role === 'admin')) {
          if (date) {
            const dateObj = new Date(date as string);
            timeSlots = await storage.getServiceTimeSlotsByDate(id, dateObj);
          } else {
            timeSlots = await storage.getServiceTimeSlotsByProvider(id);
          }
        } else {
          return res.status(403).json({ error: "You can only view your own time slots" });
        }
      } else {
        return res.status(400).json({ error: "serviceId or providerId parameter is required" });
      }
      
      res.json(timeSlots);
    } catch (error) {
      console.error("Error fetching time slots:", error);
      res.status(500).json({ error: "Failed to fetch time slots" });
    }
  });

  app.post("/api/service-time-slots", async (req: Request, res: Response) => {
    try {
      // Authenticate user and check if they're the service provider
      const user = await getCurrentUser(req);
      if (!user) {
        return res.status(401).json({ error: "Unauthorized" });
      }
      
      const { serviceId, providerId, date, startTime, endTime, maxBookings, notes } = req.body;
      
      // Validate that providerId matches the current user
      if (providerId !== user.id) {
        return res.status(403).json({ error: "You can only create time slots for your own services" });
      }
      
      // Get the service to verify ownership
      const service = await storage.getService(serviceId);
      if (!service) {
        return res.status(404).json({ error: "Service not found" });
      }
      
      if (service.providerId !== user.id) {
        return res.status(403).json({ error: "You can only create time slots for your own services" });
      }
      
      // Process date and time strings to create Date objects
      const timeSlotDate = new Date(date);
      const startTimeDate = new Date(startTime);
      const endTimeDate = new Date(endTime);
      
      // Validate the timeSlot data
      const now = new Date();
      if (timeSlotDate < now) {
        return res.status(400).json({ error: "Time slot date cannot be in the past" });
      }
      
      // Validate that endTime is after startTime
      if (endTimeDate <= startTimeDate) {
        return res.status(400).json({ error: "End time must be after start time" });
      }
      
      // Create time slot
      const timeSlot = await storage.createServiceTimeSlot({
        serviceId,
        providerId,
        date: timeSlotDate,
        startTime: startTimeDate,
        endTime: endTimeDate,
        status: TimeSlotStatus.AVAILABLE,
        maxBookings: maxBookings || 1,
        currentBookings: 0,
        notes: notes || null
      });
      
      res.status(201).json(timeSlot);
    } catch (error) {
      console.error("Error creating time slot:", error);
      res.status(500).json({ error: "Failed to create time slot" });
    }
  });

  app.patch("/api/service-time-slots/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const timeSlot = await storage.getServiceTimeSlot(id);
      
      if (!timeSlot) {
        return res.status(404).json({ error: "Time slot not found" });
      }
      
      // Authenticate user and check if they're the service provider
      const user = await getCurrentUser(req);
      if (!user) {
        return res.status(401).json({ error: "Unauthorized" });
      }
      
      // Check if the user owns this time slot
      if (timeSlot.providerId !== user.id) {
        return res.status(403).json({ error: "You can only update your own time slots" });
      }
      
      // Only allow certain fields to be updated
      const { startTime, endTime, status, maxBookings, notes } = req.body;
      
      // Convert date strings to Date objects if provided
      const updateData: Partial<InsertServiceTimeSlot> = {};
      
      if (startTime) {
        updateData.startTime = new Date(startTime);
      }
      
      if (endTime) {
        updateData.endTime = new Date(endTime);
      }
      
      if (status) {
        updateData.status = status;
      }
      
      if (notes !== undefined) {
        updateData.notes = notes;
      }
      
      // Don't allow reducing maxBookings below currentBookings
      if (maxBookings !== undefined) {
        if (maxBookings < timeSlot.currentBookings) {
          return res.status(400).json({ 
            error: "Cannot reduce maximum bookings below current booking count" 
          });
        }
        updateData.maxBookings = maxBookings;
      }
      
      // Validate that if both start and end times are provided, end is after start
      if (updateData.startTime && updateData.endTime) {
        if (updateData.endTime <= updateData.startTime) {
          return res.status(400).json({ error: "End time must be after start time" });
        }
      }
      
      // Update the time slot
      const updatedTimeSlot = await storage.updateServiceTimeSlot(id, updateData);
      
      res.json(updatedTimeSlot);
    } catch (error) {
      console.error("Error updating time slot:", error);
      res.status(500).json({ error: "Failed to update time slot" });
    }
  });

  app.delete("/api/service-time-slots/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const timeSlot = await storage.getServiceTimeSlot(id);
      
      if (!timeSlot) {
        return res.status(404).json({ error: "Time slot not found" });
      }
      
      // Authenticate user and check if they're the service provider
      const user = await getCurrentUser(req);
      if (!user) {
        return res.status(401).json({ error: "Unauthorized" });
      }
      
      // Check if the user owns this time slot
      if (timeSlot.providerId !== user.id) {
        return res.status(403).json({ error: "You can only delete your own time slots" });
      }
      
      // Don't allow deletion if there are already bookings
      if (timeSlot.currentBookings > 0) {
        return res.status(400).json({ 
          error: "Cannot delete time slot with existing bookings. Cancel the bookings first." 
        });
      }
      
      // Delete the time slot
      const success = await storage.deleteServiceTimeSlot(id);
      
      if (success) {
        res.status(200).json({ message: "Time slot deleted successfully" });
      } else {
        res.status(500).json({ error: "Failed to delete time slot" });
      }
    } catch (error) {
      console.error("Error deleting time slot:", error);
      res.status(500).json({ error: "Failed to delete time slot" });
    }
  });

