  // Orders routes
  app.get("/api/orders", async (req: Request, res: Response) => {
    try {
      const status = req.query.status as string | undefined;
      const buyerId = req.query.buyerId ? parseInt(req.query.buyerId as string) : undefined;
      // Get userId from local storage if available
      const userId = req.query.userId ? parseInt(req.query.userId as string) : undefined;

      let orders;
      if (status) {
        orders = await storage.getOrdersByStatus(status);
      } else if (buyerId) {
        orders = await storage.getOrdersByBuyer(buyerId);
      } else if (userId) {
        // If userId is provided, return orders for that user
        orders = await storage.getOrdersByBuyer(userId);
      } else {
        // For payment intent lookups, return all orders
        if (req.query.payment_intent) {
          orders = await storage.getAllOrders();
          
          // Filter orders by payment intent
          const paymentIntentId = req.query.payment_intent as string;
          orders = orders.filter(order => order.paymentIntentId === paymentIntentId);
        } else {
          // Default: Return all orders for admins, empty for others
          const adminId = req.query.adminId ? parseInt(req.query.adminId as string) : null;
          
          if (adminId) {
            const admin = await storage.getUser(adminId);
            if (admin && admin.role === "admin") {
              orders = await storage.getAllOrders();
            } else {
              orders = [];
            }
          } else {
            orders = [];
          }
        }
      }

      res.json(orders);
    } catch (error) {
      res.status(500).json({ message: "Failed to fetch orders" });
    }
  });

  app.get("/api/orders/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const order = await storage.getOrder(id);

      if (!order) {
        return res.status(404).json({ message: "Order not found" });
      }      // Get order items
      const orderItems = await storage.getOrderItemsByOrder(id);

      res.json({
        ...order,
        items: orderItems
      });
    } catch (error) {
      res.status(500).json({ message: "Failed to fetch order" });
    }
  });

  app.post("/api/orders", async (req: Request, res: Response) => {
    try {
      console.log("Order creation request received:", req.body);
      
      // Extract items before parsing to schema
      const orderItems = req.body.items || [];
      
      // Log explicitly for digital product debugging
      console.log("======================================");
      console.log("ORDER CREATION DIGITAL PRODUCT CHECK:");
      console.log("Items to check:", orderItems.length);
      
      // Get base order data (without items that are not in the schema)
      let orderData = {
        buyerId: req.body.buyerId,
        totalAmount: req.body.totalAmount,
        subtotalAmount: req.body.subtotalAmount || req.body.totalAmount,
        shippingCost: req.body.shippingCost || req.body.shippingAmount || "0.00", // Accept both shippingCost and shippingAmount
        paymentIntentId: req.body.paymentIntentId,
        trackingNumber: req.body.trackingNumber,
        shippingAddress: req.body.shippingAddress,
        shippingPostalCode: req.body.shippingPostalCode,
        shippingCity: req.body.shippingCity,
        shippingCountry: req.body.shippingCountry || "Netherlands",
        customerNotes: req.body.customerNotes || req.body.notes, // Accept both customerNotes and notes
        sellerNotes: req.body.sellerNotes,
        // Handle the status field for free orders (0.00 price)
        status: parseFloat(req.body.totalAmount) === 0 ? "completed" : "pending"
      };
      
      // Parse the order data through the schema
      const validatedOrderData = insertOrderSchema.parse(orderData);
      console.log("Validated order data:", validatedOrderData);
      
      // Create the order
      const order = await storage.createOrder(validatedOrderData);
      console.log("Order created:", order);
      
      const createdItems = [];
      const productDetails = [];

      // Flag to check if this is a digital-only order
      let hasDigitalProducts = false;
      let allItemsAreDigital = true;
      
      for (const item of orderItems) {
        try {
          console.log("Processing order item:", item);
          
          // Make sure priceAtPurchase is formatted correctly for free products
          if (!item.priceAtPurchase || 
              item.priceAtPurchase === 0 || 
              item.priceAtPurchase === "0" || 
              item.priceAtPurchase === "0.00") {
            item.priceAtPurchase = "0.00";
          }
          
          const orderItemData = {
            orderId: order.id,
            productId: item.productId,
            quantity: item.quantity || 1,
            priceAtPurchase: item.priceAtPurchase
          };
          
          console.log("Creating order item with data:", orderItemData);
          const createdItem = await storage.createOrderItem(orderItemData);
          console.log("Order item created:", createdItem);
          createdItems.push(createdItem);
          
          // Get product details for email
          if (item.productId) {
            const product = await storage.getProduct(item.productId);
            if (product) {
              productDetails.push(product);
              
              // Add more extensive, visible detailed logging for product properties
              console.log("******************************************");
              console.log("PRODUCT DETAILS FOR ORDER PROCESSING:", {
                id: product.id,
                name: product.name || "Unnamed product",
                price: product.price,
                isDigital: product.isDigital,
                isDigitalType: typeof product.isDigital,
                isDigitalValue: String(product.isDigital),
                hasDigitalUrl: !!product.digitalContentUrl,
                fullProduct: JSON.stringify(product)
              });
              console.log("******************************************");
              
              // Check if this is a digital product (using multiple methods to detect)
              // Also treat products with price strictly less than €1 as digital products (per user request)
              const productPrice = product.price ? parseFloat(product.price) : 0;
              const isLowPriceProduct = productPrice < 1.0;
              
              const isDigitalProduct = product.isDigital === true || 
                                       product.isDigital === 'true' || 
                                       product.isDigital === 't' ||
                                       product.digitalContentUrl || 
                                       isLowPriceProduct;
                                       
              if (isDigitalProduct) {
                hasDigitalProducts = true;
                console.log(`Product ${product.name || "Unnamed product"} (${product.id}) is digital`);
              } else {
                allItemsAreDigital = false;
                console.log(`Product ${product.name || "Unnamed product"} (${product.id}) is physical`);
              }
            }
          }
        } catch (itemError) {
          console.error("Error creating order item:", itemError);
          // Continue with other items instead of failing the entire order
        }
      }
      
      // For digital-only orders with 0.00 price, automatically mark as completed
      if (hasDigitalProducts && (allItemsAreDigital || parseFloat(order.totalAmount) === 0)) {
        try {
          console.log("Digital product order detected - updating status to completed");
          const updatedOrder = await storage.updateOrder(order.id, { status: "completed" });
          // Use the updated order for subsequent processing if available
          const orderForProcessing = updatedOrder || order;
          
          // Send digital product notifications
          try {
            if (order.buyerId) {
              for (const product of productDetails) {
                // Check if this is a digital product (using same method as above)
                // Also treat products with price strictly less than €1 as digital products
                const productPrice = product.price ? parseFloat(product.price) : 0;
                const isLowPriceProduct = productPrice < 1.0;
                
                const isDigitalProduct = product.isDigital === true || 
                                         product.isDigital === 'true' || 
                                         product.isDigital === 't' ||
                                         product.digitalContentUrl ||
                                         isLowPriceProduct;
                
                if (isDigitalProduct) {
                  // Import the notification function
                  const { notifyDigitalProductReady } = await import('./websocket');
                  
                  // Send notification for each digital product
                  notifyDigitalProductReady(
                    order.buyerId,
                    order.id,
                    product.id,
                    product.name || `Product #${product.id}`
                  );
                  
                  console.log(`Sent digital product notification for ${product.name || `Product #${product.id}`}`);
                  
                  // Create user notification in database as well
                  await storage.createUserNotification({
                    userId: order.buyerId,
                    type: "DIGITAL_PRODUCT_READY",
                    title: "Digital Product Ready",
                    message: `Your digital product "${product.name || `Product #${product.id}`}" is ready for download.`,
                    actionLink: `/orders/${order.id}`,
                    actionText: "View Product"
                  });
                }
              }
            }
          } catch (notifyError) {
            console.error("Error sending digital product notifications:", notifyError);
          }
        } catch (updateError) {
          console.error("Error updating digital order status:", updateError);
        }
      }

      // Send order confirmation email if buyer exists
      if (order.buyerId) {
        try {
          const buyer = await storage.getUser(order.buyerId);
          if (buyer && buyer.email) {
            // Send order confirmation email to buyer
            await sendOrderConfirmationEmail(
              buyer, 
              order, 
              createdItems, 
              productDetails
            );
            console.log(`Order confirmation email sent to buyer: ${buyer.email}`);
            
            // For each unique seller, send notification email
            const sellerIds = [...new Set(productDetails.map(p => p.sellerId))];
            for (const sellerId of sellerIds) {
              if (sellerId) {
                const seller = await storage.getUser(sellerId);
                if (seller && seller.email && seller.email !== buyer.email) {
                  // Create a filtered list of products for this seller
                  const sellerProducts = productDetails.filter(p => p.sellerId === sellerId);
                  const sellerOrderItems = createdItems.filter(item => 
                    sellerProducts.some(p => p.id === item.productId)
                  );
                  
                  // Send seller notification
                  // TODO: Implement a dedicated seller notification email function
                  console.log(`Order notification would be sent to seller: ${seller.email}`);
                }
              }
            }
          }
        } catch (emailError) {
          // Log email error but don't fail the order creation
          console.error('Failed to send order confirmation email:', emailError);
        }
      }

      res.status(201).json({
        ...order,
        items: createdItems
      });
    } catch (error) {
      console.error("Error in order creation:", error);
      
      if (error instanceof z.ZodError) {
        console.log("Validation errors:", error.errors);
        return res.status(400).json({ 
          message: "Invalid order data", 
          errors: error.errors,
          details: error.format() 
        });
      }
      
      // Provide more detailed error information in the response
      res.status(500).json({ 
        message: "Failed to create order", 
        error: error instanceof Error ? error.message : String(error),
        errorType: error instanceof Error ? error.name : 'Unknown'
      });
    }
  });

