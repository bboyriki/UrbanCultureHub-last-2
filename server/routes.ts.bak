  app.get("/api/users/:userId/orders", async (req: Request, res: Response) => {
    try {
      const userId = parseInt(req.params.userId);
      console.log(`Fetching orders for user ${userId}`);
      const orders = await storage.getOrdersByBuyer(userId);
      console.log(`Found ${orders.length} orders`);
      
      // For each order, get its items
      const ordersWithItems = await Promise.all(
        orders.map(async (order) => {
          const items = await storage.getOrderItemsByOrder(order.id);
          
          // For each item, try to get the product information
          const itemsWithProducts = await Promise.all(
            items.map(async (item) => {
              if (item.productId) {
                const product = await storage.getProduct(item.productId);
                return {
                  ...item,
                  product: product || undefined
                };
              }
              return item;
            })
          );
          
          return {
            ...order,
            items: itemsWithProducts
          };
        })
      );
      
      res.json(ordersWithItems);
    } catch (error) {
      console.error("Error fetching user orders:", error);
      res.status(500).json({ message: "Failed to fetch user orders" });
    }
  });

  // Helper function to process payment intent events (both verified and unverified)
  const processPaymentIntent = async (event: any, req: Request, res: Response) => {
    const paymentIntent = event.data.object;
    
    try {
      // Extract metadata from payment intent
      const { eventId, ticketQuantity, productId, quantity, userId, type, customerName, customerEmail, serviceId, directPayment } = paymentIntent.metadata || {};

      // Debug log the payment intent metadata for diagnostics
      console.log("Payment intent metadata in webhook:", {
        id: paymentIntent.id,
        status: paymentIntent.status,
        metadata: paymentIntent.metadata,
        amount: paymentIntent.amount,
        created: new Date(paymentIntent.created * 1000).toISOString()
      });
      
      // Handle service booking direct payments (iDEAL, etc.)
      if (directPayment === "true" && serviceId) {
        console.log(`Processing direct service booking payment: ${paymentIntent.id}, Service: ${serviceId}, User: ${userId || 'Unknown'}`);
        
        try {
          // Verify the service exists
          const service = await storage.getService(parseInt(serviceId));
          if (!service) {
            console.error(`Service not found for ID: ${serviceId}`);
            return res.json({ received: true, error: "Service not found" });
          }
          
          // For iDEAL and other redirect-based payment methods, the client will attempt to
          // create the booking after redirect, but we should check if a booking with this
          // payment intent already exists to avoid duplicates
          const existingBookings = await storage.getServiceBookingsByPaymentIntentId(paymentIntent.id);
          
          if (existingBookings && existingBookings.length > 0) {
            console.log(`Booking already exists for payment intent ${paymentIntent.id}. Skipping duplicate creation.`);
            return res.json({ received: true, success: true, bookingExists: true });
          }
          
          // For iDEAL payments processed via webhook, we can't create the booking here
          // since we don't have all the booking details like startTime, endTime, etc.
          // The client will create the booking when it detects the completed payment.
          console.log(`Direct service booking payment ${paymentIntent.id} confirmed. Client will create booking.`);
          return res.json({ received: true, success: true });
        } catch (error) {
          console.error(`Error processing direct service booking payment: ${error}`);
          return res.json({ received: true, error: "Error processing direct service booking" });
        }
      }
      
      // Handle different payment types
      if (type === "product_purchase" || type === "cart_purchase") {
        // Process product purchase or cart purchase
        if (type === "cart_purchase") {
          console.log("Processing cart purchase from webhook");
          // For cart purchases, productIds and productQuantities are comma-separated lists
          const productIds = paymentIntent.metadata.productIds ? paymentIntent.metadata.productIds.split(',') : [];
          const productQuantities = paymentIntent.metadata.productQuantities ? paymentIntent.metadata.productQuantities.split(',') : [];
          const subtotalAmount = paymentIntent.metadata.subtotalAmount;
          const shippingCost = paymentIntent.metadata.shippingCost;
          const buyerName = paymentIntent.metadata.buyerName;
          const buyerEmail = paymentIntent.metadata.buyerEmail;
          
          // Check if we have all required data
          if (!productIds.length || !productQuantities.length || !userId) {
            console.error("Missing cart purchase metadata in payment intent:", paymentIntent.id);
            return res.json({ received: true });
          }
          
          console.log(`Processing cart purchase: ${productIds.join(', ')}, User: ${userId}`);
          
          try {
            // Get user details
            const user = await storage.getUser(parseInt(userId));
            if (!user) {
              console.error(`User not found for ID: ${userId}`);
              return res.json({ received: true });
            }
            
            // Calculate or use provided total amount
            const totalAmount = paymentIntent.metadata.totalAmount || 
              ((parseFloat(subtotalAmount || "0") + parseFloat(shippingCost || "0"))).toString();
            
            // Get shipping information
            const shippingAddress = paymentIntent.metadata.shippingAddress;
            
            // Create the order
            const order = await storage.createOrder({
              buyerId: parseInt(userId),
              totalAmount,
              subtotalAmount: subtotalAmount || totalAmount,
              shippingCost: shippingCost || "0.00",
              paymentIntentId: paymentIntent.id,
              status: "completed",
              shippingAddress: shippingAddress || null
            });
            
            console.log(`Cart order created: ${order.id}`);
            
            // Fetch products and create order items
            const orderItems = [];
            const products = [];
            
            for (let i = 0; i < productIds.length; i++) {
              const prodId = parseInt(productIds[i]);
              const qty = parseInt(productQuantities[i] || "1");
              
              // Get the product details
              const product = await storage.getProduct(prodId);
              if (!product) {
                console.error(`Product not found for ID: ${prodId}`);
                continue;
              }
              
              products.push(product);
              
              // Create order item
              const orderItem = await storage.createOrderItem({
                orderId: order.id,
                productId: prodId,
                quantity: qty,
                priceAtPurchase: product.price
              });
              
              orderItems.push(orderItem);
              console.log(`Cart order item created for product ${prodId}: ${orderItem.id}`);
            }
            
            // Send confirmation email
            try {
              await sendOrderConfirmationEmail(user, order, orderItems, products);
              console.log(`Cart order confirmation email sent to ${user.email}`);
              
              // Mark order as email sent
              await storage.updateOrder(order.id, { emailSent: true });
              
              // Send seller notifications
              // Create a map of sellerIds to their products
              const sellerProducts = new Map();
              for (const product of products) {
                if (product.sellerId && product.sellerId !== user.id) {
                  if (!sellerProducts.has(product.sellerId)) {
                    sellerProducts.set(product.sellerId, []);
                  }
                  sellerProducts.get(product.sellerId).push(product);
                }
              }
              
              // Send notification to each seller
              for (const [sellerId, sellerProds] of sellerProducts.entries()) {
                const seller = await storage.getUser(sellerId);
                if (seller && seller.email) {
                  // TODO: Implement dedicated seller notification email
                  console.log(`Order notification would be sent to seller: ${seller.email} for ${sellerProds.length} products`);
                }
              }
            } catch (emailError) {
              console.error("Failed to send direct cart order confirmation email via webhook:", emailError);
              
              // Try our dedicated endpoint as a backup method
              try {
                console.log(`Webhook: Attempting to send email via the dedicated endpoint as a backup for cart order ${order.id}...`);
                const axios = require('axios');
                const host = req.headers.host || 'localhost:5000';
                const protocol = req.headers['x-forwarded-proto'] || 'http';
                const baseUrl = `${protocol}://${host}`;
                
                const backupResponse = await axios.post(`${baseUrl}/api/orders/send-confirmation`, {
                  orderId: order.id,
                  userId: parseInt(userId)
                });
                
                if (backupResponse.data && backupResponse.data.success) {
                  console.log(`Webhook: Backup email successfully sent for cart order ${order.id} to user ID ${userId}`);
                } else {
                  console.error(`Webhook: Backup request completed but may have failed. Response:`, backupResponse.data);
                }
              } catch (backupError) {
                console.error("Webhook: Backup email request failed:", backupError);
                // Don't need to rethrow - just log the error
              }
            }
            
            return res.json({ success: true, orderId: order.id });
          } catch (orderError) {
            console.error("Error creating cart order:", orderError);
            return res.status(500).json({ error: "Error processing cart order" });
          }
        } else {
          // Regular single product purchase
          if (!productId || !quantity || !userId) {
            console.error("Missing product purchase metadata in payment intent:", paymentIntent.id);
            return res.json({ received: true });
          }
          
          console.log(`Processing product purchase: ${productId}, Quantity: ${quantity}, User: ${userId}`);
          
          try {
            // Get the product details
            const product = await storage.getProduct(parseInt(productId));
            if (!product) {
              console.error(`Product not found for ID: ${productId}`);
              return res.json({ received: true });
            }
            
            // Get user details
            const user = await storage.getUser(parseInt(userId));
            if (!user) {
              console.error(`User not found for ID: ${userId}`);
              return res.json({ received: true });
            }
            
            // Calculate total amount
            const totalAmount = (parseFloat(product.price) * parseInt(quantity)).toString();
            
            // Create the order
            const order = await storage.createOrder({
              buyerId: parseInt(userId),
              totalAmount,
              paymentIntentId: paymentIntent.id,
              status: "completed"
            });
            
            console.log(`Order created: ${order.id}`);
            
            // Create order item
            const orderItem = await storage.createOrderItem({
              orderId: order.id,
              productId: parseInt(productId),
              quantity: parseInt(quantity),
              priceAtPurchase: product.price
            });
            
            console.log(`Order item created: ${orderItem.id}`);
            
            // Send confirmation email
            try {
              const orderItems = [orderItem];
              const products = [product];
              
              await sendOrderConfirmationEmail(user, order, orderItems, products);
              console.log(`Order confirmation email sent to ${user.email}`);
              
              // Mark order as email sent
              await storage.updateOrder(order.id, { emailSent: true });
            } catch (emailError) {
              console.error("Failed to send direct order confirmation email:", emailError);
              // Don't need to rethrow - just log the error
            }
            
            return res.json({ success: true, orderId: order.id });
          } catch (orderError) {
            console.error("Error creating order:", orderError);
            return res.status(500).json({ error: "Error processing order" });
          }
        }
      } else if (type === "event_ticket") {
        // Event ticket purchase logic here
        return res.json({ received: true });
      } else {
        console.log(`Unknown payment type: ${type}`);
        return res.json({ received: true });
      }
    } catch (error) {
      console.error("Error processing payment intent:", error);
      return res.status(500).json({ error: "Error processing payment intent" });
    }
  };
  
  app.post("/api/webhook", express.raw({ type: "application/json" }), async (req: Request, res: Response) => {
    const signature = req.headers["stripe-signature"] as string;

    try {
      // Check if webhook secret is configured
      if (!process.env.STRIPE_WEBHOOK_SECRET) {
        console.log("WARNING: STRIPE_WEBHOOK_SECRET is not configured. Using raw payload data without signature verification.");
        // Extract the raw payload data
        try {
          // Parse the payload directly if no webhook secret
          const payloadData = JSON.parse(req.body.toString());
          if (payloadData.type === 'payment_intent.succeeded') {
            console.log("Processing unverified payment_intent.succeeded event:", payloadData.id);
            
            // Use raw payload data as event
            const event = {
              type: payloadData.type,
              data: {
                object: payloadData.data.object
              }
            };
            
            // Continue processing with this event
            // But make sure to ask for webhook secret later
            console.log("WARNING: Using unverified webhook payload. Please set STRIPE_WEBHOOK_SECRET for proper verification.");
            
            // Handle the rest of the webhook logic
            // Return early to use this data
            return processPaymentIntent(event, req, res);
          }
        } catch (parseError) {
          console.error("Error parsing unverified webhook payload:", parseError);
          return res.status(400).json({ message: "Invalid payload and no webhook secret configured" });
        }
      }
      
      // Regular verified webhook flow
      const event = await handleWebhook(
        signature,
        req.body,
        process.env.STRIPE_WEBHOOK_SECRET!
      );

      // Handle the event
      switch (event.type) {
        case "payment_intent.succeeded":
          // Process the successful payment using our common function
          return processPaymentIntent(event, req, res);
        case "payment_intent.succeeded_legacy":
          // Keep the old code path as fallback
          const paymentIntent = event.data.object;
          // Process the successful payment
          try {
            // Extract metadata from payment intent
            const { eventId, ticketQuantity, productId, quantity, userId, type, customerName, customerEmail } = paymentIntent.metadata || {};

            // Handle different payment types
            if (type === "product_purchase" || type === "cart_purchase") {
              // Process product purchase or cart purchase
              if (type === "cart_purchase") {
                console.log("Processing cart purchase from webhook");
                // For cart purchases, productIds and productQuantities are comma-separated lists
                const productIds = paymentIntent.metadata.productIds ? paymentIntent.metadata.productIds.split(',') : [];
                const productQuantities = paymentIntent.metadata.productQuantities ? paymentIntent.metadata.productQuantities.split(',') : [];
                const subtotalAmount = paymentIntent.metadata.subtotalAmount;
                const shippingCost = paymentIntent.metadata.shippingCost;
                const buyerName = paymentIntent.metadata.buyerName;
                const buyerEmail = paymentIntent.metadata.buyerEmail;
                
                // Check if we have all required data
                if (!productIds.length || !productQuantities.length || !userId) {
                  console.error("Missing cart purchase metadata in payment intent:", paymentIntent.id);
                  break;
                }
                
                console.log(`Processing cart purchase: ${productIds.join(', ')}, User: ${userId}`);
                
                try {
                  // Get user details
                  const user = await storage.getUser(parseInt(userId));
                  if (!user) {
                    console.error(`User not found for ID: ${userId}`);
                    break;
                  }
                  
                  // Calculate or use provided total amount
                  const totalAmount = paymentIntent.metadata.totalAmount || 
                    ((parseFloat(subtotalAmount || "0") + parseFloat(shippingCost || "0"))).toString();
                  
                  // Get shipping information
                  const shippingAddress = paymentIntent.metadata.shippingAddress;
                  
                  // Create the order
                  const order = await storage.createOrder({
                    buyerId: parseInt(userId),
                    totalAmount,
                    subtotalAmount: subtotalAmount || totalAmount,
                    shippingCost: shippingCost || "0.00",
                    paymentIntentId: paymentIntent.id,
                    status: "completed",
                    shippingAddress: shippingAddress || null
                  });
                  
                  console.log(`Cart order created: ${order.id}`);
                  
                  // Fetch products and create order items
                  const orderItems = [];
                  const products = [];
                  
                  for (let i = 0; i < productIds.length; i++) {
                    const prodId = parseInt(productIds[i]);
                    const qty = parseInt(productQuantities[i] || "1");
                    
                    // Get the product details
                    const product = await storage.getProduct(prodId);
                    if (!product) {
                      console.error(`Product not found for ID: ${prodId}`);
                      continue;
                    }
                    
                    products.push(product);
                    
                    // Create order item
                    const orderItem = await storage.createOrderItem({
                      orderId: order.id,
                      productId: prodId,
                      quantity: qty,
                      priceAtPurchase: product.price
                    });
                    
                    orderItems.push(orderItem);
                    console.log(`Cart order item created for product ${prodId}: ${orderItem.id}`);
                    
                    // Update product stock for physical products
                    if (!product.isDigital && product.stock !== null && product.stock !== undefined) {
                      const newStock = Math.max(0, product.stock - qty);
                      console.log(`Updating product ${prodId} stock from ${product.stock} to ${newStock}`);
                      
                      try {
                        await storage.updateProduct(prodId, { stock: newStock });
                      } catch (stockError) {
                        console.error(`Error updating stock for product ${prodId}:`, stockError);
                      }
                    }
                  }
                  
                  // Send confirmation email
                  try {
                    await sendOrderConfirmationEmail(user, order, orderItems, products);
                    console.log(`Cart order confirmation email sent to ${user.email}`);
                    
                    // Mark order as email sent
                    await storage.updateOrder(order.id, { emailSent: true });
                    
                    // Send seller notifications
                    // Create a map of sellerIds to their products
                    const sellerProducts = new Map();
                    for (const product of products) {
                      if (product.sellerId && product.sellerId !== user.id) {
                        if (!sellerProducts.has(product.sellerId)) {
                          sellerProducts.set(product.sellerId, []);
                        }
                        sellerProducts.get(product.sellerId).push(product);
                      }
                    }
                    
                    // Send notification to each seller
                    for (const [sellerId, sellerProds] of sellerProducts.entries()) {
                      const seller = await storage.getUser(sellerId);
                      if (seller && seller.email) {
                        // TODO: Implement dedicated seller notification email
                        console.log(`Order notification would be sent to seller: ${seller.email} for ${sellerProds.length} products`);
                      }
                    }
                  } catch (emailError) {
                    console.error("Failed to send direct cart order confirmation email via webhook:", emailError);
                    
                    // Try our dedicated endpoint as a backup method
                    try {
                      console.log(`Webhook: Attempting to send email via the dedicated endpoint as a backup for cart order ${order.id}...`);
                      const axios = require('axios');
                      const host = req.headers.host || 'localhost:5000';
                      const protocol = req.headers['x-forwarded-proto'] || 'http';
                      const baseUrl = `${protocol}://${host}`;
                      
                      const backupResponse = await axios.post(`${baseUrl}/api/orders/send-confirmation`, {
                        orderId: order.id,
                        userId: parseInt(userId)
                      });
                      
                      if (backupResponse.data && backupResponse.data.success) {
                        console.log(`Webhook: Backup email successfully sent for cart order ${order.id} to user ID ${userId}`);
                      } else {
                        console.error(`Webhook: Backup request completed but may have failed. Response:`, backupResponse.data);
                      }
                    } catch (backupError) {
                      console.error("Webhook: Backup email request failed:", backupError);
                      
                      // Log detailed diagnostic info to help debug the issue
                      console.error("Webhook: Cart order creation succeeded but ALL email delivery methods failed");
                      console.error(`Webhook: Order ID: ${order.id}, User ID: ${userId}`);
                      
                      if (backupError.response) {
                        // The request was made and the server responded with a status code
                        // that falls out of the range of 2xx
                        console.error("Webhook: Email backup error response data:", backupError.response.data);
                        console.error("Webhook: Email backup error response status:", backupError.response.status);
                      } else if (backupError.request) {
                        // The request was made but no response was received
                        console.error("Webhook: Email backup error - no response received");
                      } else {
                        // Something happened in setting up the request that triggered an Error
                        console.error("Webhook: Email backup setup error:", backupError.message);
                      }
                    }
                  }
                } catch (orderError) {
                  console.error("Error creating cart order:", orderError);
                }
              } else {
                // Regular single product purchase
                if (!productId || !quantity || !userId) {
                  console.error("Missing product purchase metadata in payment intent:", paymentIntent.id);
                  break;
                }
                
                console.log(`Processing product purchase: ${productId}, Quantity: ${quantity}, User: ${userId}`);
                
                try {
                  // Get the product details
                  const product = await storage.getProduct(parseInt(productId));
                  if (!product) {
                    console.error(`Product not found for ID: ${productId}`);
                    break;
                  }
                  
                  // Get user details
                  const user = await storage.getUser(parseInt(userId));
                  if (!user) {
                    console.error(`User not found for ID: ${userId}`);
                    break;
                  }
                  
                  // Calculate total amount
                  const totalAmount = (parseFloat(product.price) * parseInt(quantity)).toString();
                  
                  // Create the order
                  const order = await storage.createOrder({
                    buyerId: parseInt(userId),
                    totalAmount,
                    paymentIntentId: paymentIntent.id,
                    status: "completed"
                  });
                  
                  console.log(`Order created: ${order.id}`);
                  
                  // Create order item
                  const orderItem = await storage.createOrderItem({
                    orderId: order.id,
                    productId: parseInt(productId),
                    quantity: parseInt(quantity),
                    priceAtPurchase: product.price
                  });
                  
                  console.log(`Order item created: ${orderItem.id}`);
                  
                  // Update product stock for physical products
                  if (!product.isDigital && product.stock !== null && product.stock !== undefined) {
                    const quantityNum = parseInt(quantity);
                    const newStock = Math.max(0, product.stock - quantityNum);
                    console.log(`Updating product ${productId} stock from ${product.stock} to ${newStock}`);
                    
                    try {
                      await storage.updateProduct(parseInt(productId), { stock: newStock });
                      
                      // Send a stock update notification via WebSocket if stock is low or out
                      if (newStock <= 5) {
                        try {
                          const { notifyStockUpdate } = await import('./websocket');
                          notifyStockUpdate({
                            productId: parseInt(productId),
                            productName: product.name || `Product #${productId}`,
                            newStock,
                            isOutOfStock: newStock === 0
                          });
                        } catch (notifyError) {
                          console.error(`Failed to send stock update notification:`, notifyError);
                        }
                      }
                    } catch (stockError) {
                      console.error(`Error updating stock for product ${productId}:`, stockError);
                    }
                  }
                  
                  // Send confirmation email
                  try {
                    const orderItems = [orderItem];
                    const products = [product];
                    
                    await sendOrderConfirmationEmail(user, order, orderItems, products);
                    console.log(`Order confirmation email sent to ${user.email}`);
                    
                    // Mark order as email sent
                    await storage.updateOrder(order.id, { emailSent: true });
                    
                    // If the seller is different from the buyer, send seller notification
                    if (product.sellerId && product.sellerId !== user.id) {
                      const seller = await storage.getUser(product.sellerId);
                      if (seller && seller.email) {
                        // TODO: Implement dedicated seller notification email
                        console.log(`Order notification would be sent to seller: ${seller.email}`);
                      }
                    }
                  } catch (emailError) {
                    console.error("Failed to send direct order confirmation email via webhook:", emailError);
                    
                    // Try our dedicated endpoint as a backup method
                    try {
                      console.log(`Webhook: Attempting to send email via the dedicated endpoint as a backup for order ${order.id}...`);
                      // Make a server-to-server request to our own endpoint
                      const axios = require('axios');
                      const host = req.headers.host || 'localhost:5000';
                      const protocol = req.headers['x-forwarded-proto'] || 'http';
                      const baseUrl = `${protocol}://${host}`;
                      
                      const backupResponse = await axios.post(`${baseUrl}/api/orders/send-confirmation`, {
                        orderId: order.id,
                        userId: parseInt(userId)
                      });
                      
                      if (backupResponse.data && backupResponse.data.success) {
                        console.log(`Webhook: Backup email successfully sent for order ${order.id} to user ID ${userId}`);
                      } else {
                        console.error(`Webhook: Backup request completed but may have failed. Response:`, backupResponse.data);
                      }
                    } catch (backupError) {
                      console.error("Webhook: Backup email request failed:", backupError);
                      
                      // Log detailed diagnostic info to help debug the issue
                      console.error("Webhook: Order creation succeeded but ALL email delivery methods failed");
                      console.error(`Webhook: Order ID: ${order.id}, User ID: ${userId}`);
                      
                      if (backupError.response) {
                        // The request was made and the server responded with a status code
                        // that falls out of the range of 2xx
                        console.error("Webhook: Email backup error response data:", backupError.response.data);
                        console.error("Webhook: Email backup error response status:", backupError.response.status);
                      } else if (backupError.request) {
                        // The request was made but no response was received
                        console.error("Webhook: Email backup error - no response received");
                      } else {
                        // Something happened in setting up the request that triggered an Error
                        console.error("Webhook: Email backup setup error:", backupError.message);
                      }
                    }
                  }
                } catch (orderError) {
                  console.error("Error creating order:", orderError);
                }
              }
              
              break;
            } else if (eventId && ticketQuantity) {
              // Process ticket purchase
              console.log(`Processing ticket purchase: ${eventId}, Quantity: ${ticketQuantity}`);
            } else {
              console.error("Unknown payment type or missing metadata in payment intent:", paymentIntent.id);
              break;
            }

            // Get user by email
            const email = customerEmail;
            let user = await storage.getUserByEmail(email);

            if (!user) {
              // Create a temporary user if they don't exist
              console.log(`Creating temporary user for email: ${email}`);
              user = await storage.createUser({
                email,
                displayName: customerName || email.split('@')[0],
                password: null,
                role: "guest",
                status: "active",
              });
            }

            // Create the ticket record with unique number
            const eventIdNum = parseInt(eventId);
            const ticketQtyNum = parseInt(ticketQuantity);
            const amountNum = paymentIntent.amount;

            // Get the event for the email
            const event = await storage.getEvent(eventIdNum);
            if (!event) {
              console.error(`Event ${eventIdNum} not found for ticket creation`);
              break;
            }

            const ticketNumber = `TKT-${new Date().toISOString().slice(0,10).replace(/-/g,'')}-${Math.random().toString().slice(2,5)}`;

            // Create ticket and send confirmation immediately
            const ticket = await createTicketWithQR({
              userId: user.id,
              eventId: eventIdNum,
              paymentIntentId: paymentIntent.id,
              purchaseAmount: amountNum,
              ticketQuantity: ticketQtyNum,
              ticketNumber,
              isPaid: true,
              isValid: true
            });

            // Add ticket to user's tickets immediately
            if (ticket) {
              await storage.addTicketToUser(user.id, ticket.id);
              console.log(`Ticket ${ticket.id} added to user ${user.id}'s tickets`);
            }

            // Redirect URL for frontend
            const redirectUrl = `/tickets?success=true&ticketId=${ticketNumber}`;

            console.log(`Ticket ${ticketNumber} created successfully for payment: ${paymentIntent.id}`);

            // Return redirect URL in payment intent metadata
            await storage.updatePaymentIntent(paymentIntent.id, {
              metadata: {
                ...paymentIntent.metadata,
                redirectUrl,
                ticketId: ticket ? ticket.id.toString() : undefined
              }
            });
          } catch (error) {
            console.error("Error processing payment success:", error);
          }
          break;

        case "payment_intent.payment_failed":
          const failedPayment = event.data.object;
          console.log("Payment failed:", failedPayment.id);
          break;

        // Handle subscription lifecycle events
        case "customer.subscription.created":
          const newSubscription = event.data.object;
          console.log("New subscription created:", newSubscription.id);
          break;

        case "customer.subscription.updated":
          const updatedSubscription = event.data.object;
          console.log("Subscription updated:", updatedSubscription.id);

          // Handle subscription status changes
          if (updatedSubscription.status === 'active') {
            const metadata = updatedSubscription.metadata || {};
            const userId = metadata.userId ? parseInt(metadata.userId) : null;

            if (userId) {
              try {
                // Get the membership for this user and update it to active
                const membership = await storage.getMembershipByUser(userId);

                if (membership && membership.stripeSubscriptionId === updatedSubscription.id) {
                  await storage.updateMembership(membership.id, {
                    isActive: true,
                    status: "active",
                    startDate: new Date(),
                    // Set end date based on current period end
                    endDate: new Date(updatedSubscription.current_period_end * 1000)
                  });
                  console.log(`Activated membership for user ${userId}`);
                }
              } catch (error) {
                console.error("Error updating membership status:", error);
              }
            }
          }
          break;

        case "customer.subscription.deleted":
          const cancelledSubscription = event.data.object;
          console.log("Subscription cancelled:", cancelledSubscription.id);

          // Handle subscription cancellation
          try {
            // Find membership by subscription ID
            const membership = await storage.getMembershipByStripeSubscriptionId(cancelledSubscription.id);

            if (membership) {
              await storage.updateMembership(membership.id, {
                isActive: false,
                status: "cancelled",
                autoRenew: false
              });
              console.log(`Cancelled membership for subscription ${cancelledSubscription.id}`);
            }
          } catch (error) {
            console.error("Error handling subscription cancellation:", error);
          }
          break;

        case "invoice.payment_succeeded":
          const invoice = event.data.object;
          console.log("Invoice payment succeeded:", invoice.id);

          // If this is a subscription invoice, update the membership
          if (invoice.subscription) {
            try {
              // Extract the subscription ID as a string
              const subscriptionId = typeof invoice.subscription === 'string' 
                ? invoice.subscription 
                : invoice.subscription.id;
              const membership = await storage.getMembershipByStripeSubscriptionId(subscriptionId);

              if (membership) {
                // Get the subscription to get the current period end
                // Import Stripe here for the webhook handler
                const stripeInstance = new (require('stripe'))(process.env.STRIPE_SECRET_KEY!, {
                  apiVersion: "2023-10-16",
                });
                const subscription = await stripeInstance.subscriptions.retrieve(
                  typeof invoice.subscription === 'string' 
                    ? invoice.subscription 
                    : invoice.subscription.id
                );

                await storage.updateMembership(membership.id, {
                  isActive: true,
                  status: "active",
                  // Update end date based on current period end
                  endDate: new Date(subscription.current_period_end * 1000)
                });
                console.log(`Updated membership end date for subscription ${invoice.subscription}`);
              }
            } catch (error) {
              console.error("Error updating membership after invoice payment:", error);
            }
          }
          break;

        default:
          console.log(`Unhandled event type ${event.type}`);
      }

      res.json({ received: true });
    } catch (error) {
      console.error("Error handling webhook:", error);
      res.status(400).json({ message: "Webhook signature verification failed" });
    }
  });

  // QR code ticket validation endpoint
  app.post("/api/tickets/validate", async (req: Request, res: Response) => {
    try {
      const { qrCode, scannerInfo } = req.body;
      const requestTimestamp = new Date().toISOString();
      
      // Add base debug information for all responses
      const baseDebugInfo = {
        requestTimestamp,
        endpoint: '/api/tickets/validate',
        scannerInfoProvided: !!scannerInfo,
        scannerType: scannerInfo?.deviceType || 'unknown'
      };

      if (!qrCode) {
        return res.status(400).json({ 
          message: "QR code is required",
          valid: false,
          debug: {
            ...baseDebugInfo,
            error: 'missing_qr_code',
            errorType: 'validation_error'
          }
        });
      }

      // Pass scanner info if available - this can include location, device info, etc.
      const validationResult = await validateTicket(qrCode, scannerInfo);

      if (validationResult.valid) {
        // If ticket is valid, get additional details for display
        let ticketDetails = null;

        if (validationResult.ticketId) {
          const ticket = await storage.getTicket(validationResult.ticketId);

          if (ticket && ticket.eventId && ticket.userId) {
            const event = await storage.getEvent(ticket.eventId);
            const user = await storage.getUser(ticket.userId);

            ticketDetails = {
              ticket,
              event,
              user
            };
            
            // Create admin action for ticket validation
            if (req.session?.user?.id) {
              try {
                const isAdmin = req.session.user.role === UserRole.ADMIN;
                await storage.createAdminAction({
                  adminId: req.session.user.id,
                  actionType: isAdmin ? AdminActionType.TICKET_VALIDATION : AdminActionType.TICKET_SCAN,
                  targetId: validationResult.ticketId,
                  targetType: "ticket",
                  details: JSON.stringify({
                    message: `Ticket ${validationResult.ticketNumber || ticket.ticketNumber} validated for event ${event.title}`,
                    scannerInfo,
                    timestamp: requestTimestamp,
                    debug: validationResult.debug || {
                      ticketFound: true,
                      validationSuccessful: true,
                      scanHistory: {
                        previousScans: ticket.scanCount || 0,
                        lastScanned: ticket.lastScanned
                      }
                    }
                  })
                });
              } catch (adminActionErr) {
                console.error("Error creating admin action:", adminActionErr);
                // Non-critical error, continue processing
              }
            }
            
            // Update system stats for ticket validations
            try {
              await storage.updateDailyStats();
            } catch (statsErr) {
              console.error("Error updating system stats:", statsErr);
              // Non-critical error, continue processing
            }
          }
        }

        // Ensure debug info is included in the response
        return res.json({
          ...validationResult,
          details: ticketDetails,
          debug: validationResult.debug || {
            ...baseDebugInfo,
            validationSuccessful: true,
            ticketFound: true,
            ticketInfo: {
              ticketId: validationResult.ticketId,
              ticketNumber: validationResult.ticketNumber,
              scanCount: validationResult.scanCount
            }
          }
        });
      } else {
        // For already used tickets, still record the scan attempt
        if (validationResult.alreadyUsed && validationResult.ticketId && req.session?.user?.id) {
          try {
            await storage.createAdminAction({
              adminId: req.session.user.id,
              actionType: AdminActionType.TICKET_SCAN,
              targetId: validationResult.ticketId,
              targetType: "ticket",
              details: JSON.stringify({
                message: `Attempted to validate already used ticket ${validationResult.ticketNumber}`,
                scannerInfo,
                timestamp: requestTimestamp,
                scanCount: validationResult.scanCount,
                debug: validationResult.debug || {
                  ticketFound: true,
                  invalidReason: 'already_used',
                  scanHistory: {
                    scanCount: validationResult.scanCount
                  }
                }
              })
            });
          } catch (adminActionErr) {
            console.error("Error creating admin action for used ticket:", adminActionErr);
          }
        }
        
        // For invalid tickets due to format, data or lookup issues, log diagnostic info
        if (!validationResult.valid && !validationResult.alreadyUsed && req.session?.user?.id && validationResult.ticketId) {
          try {
            await storage.createAdminAction({
              adminId: req.session.user.id,
              actionType: AdminActionType.TICKET_SCAN,
              targetId: validationResult.ticketId,
              targetType: "ticket",
              details: JSON.stringify({
                message: `Invalid ticket scan attempt: ${validationResult.message}`,
                scannerInfo,
                timestamp: requestTimestamp,
                debug: validationResult.debug || {
                  ticketFound: true,
                  invalidReason: validationResult.message.toLowerCase().replace(/\s+/g, '_'),
                  validationError: true
                }
              })
            });
          } catch (adminActionErr) {
            console.error("Error creating admin action for invalid ticket:", adminActionErr);
          }
        }
        
        // Ensure debug info is included in the response for failed validations too
        return res.json({
          ...validationResult,
          debug: validationResult.debug || {
            ...baseDebugInfo,
            validationSuccessful: false,
            invalidReason: validationResult.alreadyUsed ? 'already_used' : 
                           validationResult.message ? validationResult.message.toLowerCase().replace(/\s+/g, '_') : 
                           'unknown_validation_error',
            ticketFound: !!validationResult.ticketId,
            scanCount: validationResult.scanCount
          }
        });
      }
    } catch (error) {
      console.error("Error validating ticket:", error);
      res.status(500).json({ 
        message: "Failed to validate ticket",
        valid: false,
        debug: { 
          errorType: error instanceof Error ? error.name : "Unknown",
          errorMessage: error instanceof Error ? error.message : String(error),
          timestamp: new Date().toISOString(),
          requestPath: '/api/tickets/validate',
          scannerInfo: !!req.body.scannerInfo
        }
      });
    }
  });

  // Products routes
  app.get("/api/products", async (req: Request, res: Response) => {
    try {
      console.log("Products API request received with query:", req.query);
      const category = req.query.category as string | undefined;
      const sellerId = req.query.sellerId ? parseInt(req.query.sellerId as string) : undefined;

      let products;
      if (category) {
        console.log("Fetching products by category:", category);
        products = await storage.getProductsByCategory(category);
      } else if (sellerId) {
        console.log("Fetching products by seller:", sellerId);
        products = await storage.getProductsBySeller(sellerId);
      } else {
        console.log("Fetching all products");
        products = await storage.getAllProducts();
      }

      console.log("Products fetched successfully:", products.length);
      res.json(products);
    } catch (error) {
      console.error("Error fetching products:", error);
      res.status(500).json({ message: "Failed to fetch products" });
    }
  });

  app.get("/api/products/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      console.log(`Fetching product with ID: ${id}`);
      
      const product = await storage.getProduct(id);

      if (!product) {
        console.log(`Product ${id} not found in database`);
        return res.status(404).json({ message: "Product not found" });
      }

      // Log the full product details for debugging
      console.log(`Product ${id} details:`, JSON.stringify(product));
      
      // Add additional debugging info for image data
      console.log(`Product ${id} image details:`, {
        imagesType: typeof product.images,
        imagesValue: product.images,
        isArray: Array.isArray(product.images),
        length: Array.isArray(product.images) ? product.images.length : null
      });
      
      // Also debug stock information
      console.log(`Product ${id} stock details:`, {
        stockType: typeof product.stock,
        stockValue: product.stock,
        isNull: product.stock === null,
        isUndefined: product.stock === undefined
      });
      
      // Ensure we're sending back a clean response
      const enhancedProduct = {
        ...product,
        // If images is a string that looks like JSON, parse it correctly 
        images: typeof product.images === 'string' ? 
          (product.images.trim().startsWith('[') ? 
            JSON.parse(product.images) : 
            [product.images]
          ) : product.images
      };
      
      console.log(`Enhanced product for ID ${id}:`, enhancedProduct);
      
      res.json(enhancedProduct);
    } catch (error) {
      console.error(`Error fetching product ${req.params.id}:`, error);
      res.status(500).json({ 
        message: "Failed to fetch product",
        error: error instanceof Error ? error.message : String(error)
      });
    }
  });
  
