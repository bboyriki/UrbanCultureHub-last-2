      if (filter) {
        // Update existing filter
        filter = await storage.updateContentFilter(filter.id, {
          level: level || filter.level,
          filterProfanity: filterProfanity !== undefined ? filterProfanity : filter.filterProfanity,
          filterViolence: filterViolence !== undefined ? filterViolence : filter.filterViolence,
          filterHateSpeech: filterHateSpeech !== undefined ? filterHateSpeech : filter.filterHateSpeech,
