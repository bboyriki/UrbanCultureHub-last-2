  app.post("/api/comments", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const userId = req.user?.id;
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      // Parse and validate comment data
      const commentData = insertCommentSchema.parse(req.body);
      
      // Get user's content filter settings to determine strictness level for moderation
      const filterSettings = await storage.getContentFilterByUser(userId);
      let filterLevel = ContentFilterLevel.MEDIUM; // Default
      
      if (filterSettings) {
        filterLevel = filterSettings.level;
      }
      
      // Check if the comment content passes the content filter
      const isContentAllowed = await storage.isContentAllowed(commentData.content, filterLevel);
      
      if (!isContentAllowed) {
        console.log(`[DEBUG] Comment from user ${userId} was blocked by content filter: "${commentData.content.substring(0, 50)}..."`);
        return res.status(400).json({ 
          message: "Your comment contains content that violates our community guidelines. Please revise and try again.",
          filteredContent: true
        });
      }
      
      // If we reach here, content passed the filter
      const comment = await storage.createComment({
        ...commentData,
        userId: userId // Ensure the comment is associated with the authenticated user
      });
      
      // If this is a reply to another comment, notify the parent comment owner
      if (comment.parentCommentId) {
        try {
          const parentComment = await storage.getComment(comment.parentCommentId);
          if (parentComment && parentComment.userId && parentComment.userId !== userId) {
            // Create notification for parent comment owner
            await storage.createUserNotification({
              userId: parentComment.userId,
              type: "comment_reply",
              message: `Someone replied to your comment`,
              title: "New Reply",
              actionLink: `/posts/${comment.postId}`
            });
          }
        } catch (notifyError) {
          console.error("Error sending reply notification:", notifyError);
          // Continue anyway - notification is not critical
        }
      } else if (comment.postId) {
        // This is a new top-level comment - notify post owner
        try {
          const post = await storage.getPost(comment.postId);
          if (post && post.userId && post.userId !== userId) {
            // Create notification for post owner
            await storage.createUserNotification({
              userId: post.userId,
              type: "post_comment",
              message: `Someone commented on your post`,
              title: "New Comment",
              actionLink: `/posts/${comment.postId}`
            });
          }
        } catch (notifyError) {
          console.error("Error sending comment notification:", notifyError);
          // Continue anyway - notification is not critical
        }
      }
      
      res.status(201).json(comment);
    } catch (error) {
      if (error instanceof z.ZodError) {
        return res.status(400).json({ message: "Invalid comment data", errors: error.errors });
      }
      console.error("Error creating comment:", error);
      res.status(500).json({ message: "Failed to create comment" });
    }
  });
  
  // Update an existing comment
  app.patch("/api/comments/:id", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const commentId = parseInt(req.params.id);
      const { content } = req.body;
      const userId = req.user?.id;
      
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      // Verify the comment exists
      const existingComment = await storage.getComment(commentId);
      
      if (!existingComment) {
        return res.status(404).json({ message: "Comment not found" });
      }
      
      // Verify the user owns the comment or is an admin
      const isAdmin = req.user?.role === 'admin';
      if (existingComment.userId !== userId && !isAdmin) {
        return res.status(403).json({ message: "You can only edit your own comments" });
      }
      
      // Get user's content filter settings to determine strictness level for moderation
      const filterSettings = await storage.getContentFilterByUser(userId);
      let filterLevel = ContentFilterLevel.MEDIUM; // Default
      
      if (filterSettings) {
        filterLevel = filterSettings.level;
      }
      
      // Check if the updated content passes the content filter
      const isContentAllowed = await storage.isContentAllowed(content, filterLevel);
      
      if (!isContentAllowed) {
        console.log(`[DEBUG] Comment update from user ${userId} was blocked by content filter: "${content.substring(0, 50)}..."`);
        return res.status(400).json({ 
          message: "Your comment contains content that violates our community guidelines. Please revise and try again.",
          filteredContent: true
        });
      }
      
      // Update the comment
      const updatedComment = await storage.updateComment(commentId, { content });
      
      res.status(200).json(updatedComment);
    } catch (error) {
      console.error("Error updating comment:", error);
      res.status(500).json({ message: "Failed to update comment" });
    }
  });
  
  // Delete a comment
  app.delete("/api/comments/:id", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const commentId = parseInt(req.params.id);
      const userId = req.user?.id;
      const userRole = req.user?.role;
      
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      console.log(`Attempting to delete comment ${commentId}. User ID: ${userId}, Role: ${userRole}`);
      
      // Verify the comment exists
      const existingComment = await storage.getComment(commentId);
      
      if (!existingComment) {
        return res.status(404).json({ message: "Comment not found" });
      }
      
      // Only allow the comment owner or admins to delete the comment
      const isAdmin = userRole === 'admin';
      if (existingComment.userId !== userId && !isAdmin) {
        console.log(`Permission denied. Comment userId: ${existingComment.userId}, Current userId: ${userId}, Role: ${userRole}`);
        return res.status(403).json({ message: "You don't have permission to delete this comment" });
      }
      
      // If this is an admin deleting a comment, log the action
      if (isAdmin && existingComment.userId !== userId) {
        try {
          const moderationReason = "Violation of community guidelines";
          
          // Log admin action
          await storage.createAdminAction({
            adminId: userId,
            actionType: "delete_comment",
            targetId: commentId,
            targetType: "comment",
            details: `Admin deleted comment ID ${commentId} by user ${existingComment.userId}. Reason: ${moderationReason}`
          });
          
          // Send real-time WebSocket notification to the comment owner
          try {
            notifyCommentDeleted(
              existingComment.userId, 
              commentId, 
              moderationReason,
              true // Deleted by admin
            );
          } catch (wsError) {
            console.error("Error sending WebSocket notification:", wsError);
            // Continue anyway - WebSocket notification is not critical
          }
          
          // Create database notification as backup
          await storage.createUserNotification({
            userId: existingComment.userId,
            type: "comment_deleted",
            message: "Your comment was removed by a moderator for violating community guidelines",
            title: "Comment Removed"
          });
        } catch (notifyError) {
          console.error("Error logging admin action:", notifyError);
          // Continue anyway - logging is not critical
        }
      } else if (existingComment.userId === userId) {
        // This is a user deleting their own comment
        // Send a notification for client-side updates
        try {
          notifyCommentDeleted(
            existingComment.userId,
            commentId,
            "You deleted this comment",
            false // Not deleted by admin
          );
        } catch (wsError) {
          console.error("Error sending WebSocket notification for self-deletion:", wsError);
          // Continue anyway - WebSocket notification is not critical
        }
      } else {
        // This is a case where a non-admin is somehow deleting someone else's comment
        // This shouldn't happen due to our permission check above, but logging just in case
        console.warn(`Unusual deletion: User ${userId} (non-admin) is deleting comment ${commentId} owned by ${existingComment.userId}`);
      }
      
      // Delete the comment and its replies
      const success = await storage.deleteComment(commentId);
      
      if (success) {
        console.log(`Comment ${commentId} deleted successfully by user ${userId}`);
        res.status(200).json({ success: true, message: "Comment deleted successfully" });
      } else {
        res.status(500).json({ message: "Failed to delete comment" });
      }
    } catch (error) {
      console.error("Error deleting comment:", error);
      res.status(500).json({ message: "Failed to delete comment" });
    }
  });

