      res.status(200).json({ success: true, message: "Image deleted successfully" });
    } catch (error) {
      console.error("Error deleting media:", error);
      res.status(500).json({ message: "Failed to delete media" });
    }
  });

  app.post("/api/media/upload-signature", async (req: Request, res: Response) => {
    try {
      const { params = {}, folder = "urban-culture" } = req.body;
      const timestamp = Math.round(Date.now() / 1000);
      
      // Log Cloudinary credentials availability (without revealing secrets)
      console.log("Cloudinary credentials check for signature generation:");
      console.log("- API Key present:", !!process.env.CLOUDINARY_API_KEY);
      console.log("- API Secret present:", !!process.env.CLOUDINARY_API_SECRET);
      console.log("- Cloud Name present:", !!process.env.CLOUDINARY_CLOUD_NAME);
      
      // Ensure folder is included in the params for signature generation
      const paramsWithFolder = { ...params, folder };
      
      console.log("Generating signature with params:", JSON.stringify(paramsWithFolder));
      const signature = generateUploadSignature(paramsWithFolder, timestamp);

      if (!signature) {
        console.error("Failed to generate signature - null result returned from generateUploadSignature");
        return res.status(500).json({ message: "Failed to generate upload signature - check server logs" });
      }

      // Create the response object with all necessary data for Cloudinary upload
      const response = {
        signature,
        timestamp,
        apiKey: process.env.CLOUDINARY_API_KEY,
        cloudName: process.env.CLOUDINARY_CLOUD_NAME,
        folder
      };

      console.log("Generated signature successfully");
      res.json(response);
    } catch (error) {
      console.error("Error generating upload signature:", error);
      res.status(500).json({ 
        message: "Failed to generate upload signature", 
        error: error instanceof Error ? error.message : "Unknown error" 
      });
    }
  });

  app.get("/api/media/transform", async (req: Request, res: Response) => {
    try {
      const { publicId, width, height, crop, quality } = req.query;

      if (!publicId) {
        return res.status(400).json({ message: "No public ID provided" });
      }

      const transformations: Record<string, any> = {};

      if (width) transformations.width = width;
      if (height) transformations.height = height;
      if (crop) transformations.crop = crop;
      if (quality) transformations.quality = quality;

      const imageUrl = buildImageUrl(publicId as string, transformations);

      res.json({ url: imageUrl });
    } catch (error) {
      console.error("Error transforming image:", error);
      res.status(500).json({ message: "Failed to transform image" });
    }
  });

