  // Get a single explore page image by ID
  app.get("/api/explore-images/id/:id", async (req: Request, res: Response) => {
    try {
      // Disable caching to ensure we always get fresh data
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const id = parseInt(req.params.id);
      if (isNaN(id)) {
        return res.status(400).json({ message: "Invalid image ID" });
      }

      const timestamp = new Date().getTime();
      console.log(`Fetching explore image with ID ${id} and timestamp: ${timestamp}`);
      
      const image = await storage.getExplorePageImage(id);
      if (!image) {
        return res.status(404).json({ message: "Explore page image not found" });
      }

      res.json(image);
    } catch (error) {
      console.error(`Error fetching explore page image with ID ${req.params.id}:`, error);
      res.status(500).json({ message: "Failed to fetch explore page image" });
    }
  });

  // Admin API endpoints for managing explore page images
  
  // Create a new explore page image
  app.post("/api/admin/explore-images", requireAdmin, upload.single('image'), async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      const { section, title, description, sortOrder, isActive, isCoverImage } = req.body;
      let imageUrl = req.body.imageUrl;
      let imagePublicId = req.body.imagePublicId;
      
      // Validate required fields
      if (!section || !title || !description) {
        return res.status(400).json({ message: "Missing required fields (section, title, description)" });
      }
      
      // Check if we have a file to upload
      if (req.file) {
        // Convert file buffer to base64
        const imageBase64 = `data:${req.file.mimetype};base64,${req.file.buffer.toString('base64')}`;
        
        // Upload to Cloudinary
        const folder = `urban_culture/explore/${section}`;
        const resourceType = "image";
        
        const uploadResult = await uploadImage(imageBase64, folder, resourceType);
        
        if (!uploadResult.success) {
          console.error("Cloudinary upload failed:", uploadResult.error);
          return res.status(500).json({ message: "Failed to upload image to cloud storage" });
        }
        
        imageUrl = uploadResult.imageUrl;
        imagePublicId = uploadResult.publicId;
      }
      
      // Validate that we have image info either from the upload or provided in the request
      if (!imageUrl || !imagePublicId) {
        return res.status(400).json({ message: "Image information is required. Either upload an image or provide imageUrl and imagePublicId." });
      }
      
      // If this is being set as a cover image, we need to unset any existing cover images for this section
      if (isCoverImage === 'true' || isCoverImage === true) {
        // Get all images for this section
        const sectionImages = await storage.getExplorePageImagesBySection(section);
        
        // Find any existing cover images
        const existingCoverImages = sectionImages.filter(img => img.isCoverImage === true);
        
        // Unset the cover image flag for all other images in this section
        for (const coverImage of existingCoverImages) {
          await storage.updateExplorePageImage(coverImage.id, {
            isCoverImage: false
          });
        }
      }
      
      // Parse sortOrder as number if provided as string
      let parsedSortOrder = 0;
      if (sortOrder !== undefined) {
        parsedSortOrder = typeof sortOrder === 'string' ? parseInt(sortOrder, 10) : sortOrder;
        if (isNaN(parsedSortOrder)) {
          parsedSortOrder = 0;
        }
      }
      
      // Convert string 'true'/'false' to boolean for isActive and isCoverImage
      const boolIsActive = isActive === 'true' || isActive === true;
      const boolIsCoverImage = isCoverImage === 'true' || isCoverImage === true;

      const newImage = await storage.createExplorePageImage({
        section,
        imageUrl,
        imagePublicId,
        title,
        description,
        sortOrder: parsedSortOrder,
        isActive: boolIsActive,
        isCoverImage: boolIsCoverImage,
        createdBy: currentUser.id
      });

      // Log admin action
      await storage.createAdminAction({
        adminId: currentUser.id,
        actionType: "create_explore_image",
        targetId: newImage.id,
        targetType: "explore_page_image",
        details: `Created explore page image "${title}" for section "${section}"`
      });

      // Send WebSocket notification about new explore image
      notifyExploreImageUpdate(section, 'add', currentUser.id);
      
      res.status(201).json(newImage);
    } catch (error) {
      console.error("Error creating explore page image:", error);
      res.status(500).json({ message: "Failed to create explore page image" });
    }
  });

  // Update an explore page image
  app.put("/api/admin/explore-images/:id", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      const id = parseInt(req.params.id);
      if (isNaN(id)) {
        return res.status(400).json({ message: "Invalid image ID" });
      }

      const { section, imageUrl, imagePublicId, title, description, sortOrder, isActive, isCoverImage } = req.body;
      
      // Check if the image exists
      const existingImage = await storage.getExplorePageImage(id);
      if (!existingImage) {
        return res.status(404).json({ message: "Explore page image not found" });
      }

      // If setting this image as cover image, check if section changed
      const imageSection = section !== undefined ? section : existingImage.section;
      
      // If this is being set as a cover image, we need to unset any existing cover images for this section
      if (isCoverImage) {
        // Get all images for this section
        const sectionImages = await storage.getExplorePageImagesBySection(imageSection);
        
        // Find any existing cover images (not including this one)
        const existingCoverImages = sectionImages.filter(img => 
          img.isCoverImage === true && img.id !== id
        );
        
        // Unset the cover image flag for all other images in this section
        for (const coverImage of existingCoverImages) {
          await storage.updateExplorePageImage(coverImage.id, {
            isCoverImage: false
          });
        }
      }

      // Update the image
      const updatedImage = await storage.updateExplorePageImage(id, {
        section: section !== undefined ? section : undefined,
        imageUrl: imageUrl !== undefined ? imageUrl : undefined,
        imagePublicId: imagePublicId !== undefined ? imagePublicId : undefined,
        title: title !== undefined ? title : undefined,
        description: description !== undefined ? description : undefined,
        sortOrder: sortOrder !== undefined ? sortOrder : undefined,
        isActive: isActive !== undefined ? isActive : undefined,
        isCoverImage: isCoverImage !== undefined ? isCoverImage : undefined
      });

      // Log admin action
      await storage.createAdminAction({
        adminId: currentUser.id,
        actionType: "update_explore_image",
        targetId: id,
        targetType: "explore_page_image",
        details: `Updated explore page image "${existingImage.title}"`
      });

      // Send WebSocket notification about updated explore image
      notifyExploreImageUpdate(existingImage.section, 'update', currentUser.id);

      res.json(updatedImage);
    } catch (error) {
      console.error(`Error updating explore page image with ID ${req.params.id}:`, error);
      res.status(500).json({ message: "Failed to update explore page image" });
    }
  });

  // Delete an explore page image
  app.delete("/api/admin/explore-images/:id", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      const id = parseInt(req.params.id);
      if (isNaN(id)) {
        return res.status(400).json({ message: "Invalid image ID" });
      }

      // Check if the image exists
      const existingImage = await storage.getExplorePageImage(id);
      if (!existingImage) {
        return res.status(404).json({ message: "Explore page image not found" });
      }

      // Delete from Cloudinary first
      if (existingImage.imagePublicId) {
        try {
          await deleteImage(existingImage.imagePublicId);
        } catch (cloudinaryError) {
          console.error(`Error deleting image from Cloudinary: ${cloudinaryError}`);
          // Continue anyway, we'll delete from the database
        }
      }

      // Delete from our database
      const deletedImage = await storage.deleteExplorePageImage(id);

      // Log admin action
      await storage.createAdminAction({
        adminId: currentUser.id,
        actionType: "delete_explore_image",
        targetId: id,
        targetType: "explore_page_image",
        details: `Deleted explore page image "${existingImage.title}" from section "${existingImage.section}"`
      });

      // Send WebSocket notification about deleted explore image
      notifyExploreImageUpdate(existingImage.section, 'delete', currentUser.id);

      res.json({ 
        message: "Explore page image deleted successfully", 
        deletedImage 
      });
    } catch (error) {
      console.error(`Error deleting explore page image with ID ${req.params.id}:`, error);
      res.status(500).json({ message: "Failed to delete explore page image" });
    }
  });

  // Update the position of an image within a section
  app.put("/api/admin/explore-images/:section/position", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      const section = req.params.section;
      const { imageId, position } = req.body;
      
      if (!imageId || position === undefined || isNaN(Number(position))) {
        return res.status(400).json({ message: "Invalid position update data" });
      }

      // Get the image to update
      const imageToUpdate = await storage.getExplorePageImage(Number(imageId));
      if (!imageToUpdate) {
        return res.status(404).json({ message: "Image not found" });
      }

      // Make sure the image belongs to the specified section
      if (imageToUpdate.section !== section) {
        return res.status(400).json({ message: "Image does not belong to the specified section" });
      }

      // Update the image position
      const updatedImage = await storage.updateExplorePageImage(Number(imageId), {
        sortOrder: Number(position)
      });

      // Log admin action
      await storage.createAdminAction({
        adminId: currentUser.id,
        actionType: "update_explore_image_position",
        targetId: Number(imageId),
        targetType: "explore_page_image",
        details: `Updated position of explore page image "${imageToUpdate.title}" to position ${position}`
      });

      // Send WebSocket notification about position update
      notifyExploreImageUpdate(section, 'update', currentUser.id);

      res.json({
        message: "Image position updated successfully",
        updatedImage
      });
    } catch (error) {
      console.error(`Error updating image position:`, error);
      res.status(500).json({ message: "Failed to update image position" });
    }
  });

  // Upload image for explore page (returns Cloudinary URL)
  app.post("/api/admin/explore-images/upload", requireAdmin, upload.single('image'), async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      // Get section from body
      const section = req.body.section;
      
      if (!section) {
        return res.status(400).json({ message: "Section is required" });
      }

      // Check if we have a file
      if (!req.file) {
        return res.status(400).json({ message: "Image file is required" });
      }

      // Convert file buffer to base64
      const imageBase64 = `data:${req.file.mimetype};base64,${req.file.buffer.toString('base64')}`;
      
      // Upload to Cloudinary
      const folder = `urban_culture/explore/${section}`;
      const resourceType = "image";
      
      const uploadResult = await uploadImage(imageBase64, folder, resourceType);
      
      if (!uploadResult.success) {
        console.error("Cloudinary upload failed:", uploadResult.error);
        return res.status(500).json({ message: "Failed to upload image to cloud storage" });
      }
      
      res.json({
        imageUrl: uploadResult.imageUrl,
        imagePublicId: uploadResult.publicId
      });
    } catch (error) {
      console.error("Error uploading explore page image:", error);
      res.status(500).json({ message: "Failed to upload explore page image" });
    }
  });

  // Reorder explore page images within a section
  app.post("/api/admin/explore-images/reorder", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Disable caching for all admin explore image endpoints
      res.set({
        'Cache-Control': 'no-store, no-cache, must-revalidate, proxy-revalidate',
        'Pragma': 'no-cache',
        'Expires': '0',
        'Surrogate-Control': 'no-store'
      });
      
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }

      const { section, imageOrder } = req.body;
      
      if (!section || !imageOrder || !Array.isArray(imageOrder)) {
        return res.status(400).json({ message: "Invalid reorder request data" });
      }

      // Get all images for this section
      const sectionImages = await storage.getExplorePageImagesBySection(section);
      
      // Map of existing image IDs for validation
      const existingImageIds = new Set(sectionImages.map(img => img.id));
      
      // Validate that all IDs in the order array exist in this section
      for (const id of imageOrder) {
        if (!existingImageIds.has(id)) {
          return res.status(400).json({ 
            message: `Image ID ${id} not found in section ${section}` 
          });
        }
      }

      // Update the sort order for each image
      const updatePromises = imageOrder.map((id, index) => 
        storage.updateExplorePageImage(id, { sortOrder: index })
      );
      
      await Promise.all(updatePromises);

      // Log admin action
      await storage.createAdminAction({
        adminId: currentUser.id,
        actionType: "reorder_explore_images",
        targetType: "explore_page_images",
        details: `Reordered explore page images in section "${section}"`
      });

      // Get updated images
      const updatedImages = await storage.getExplorePageImagesBySection(section);
      
      // Send WebSocket notification about reordered explore images
      notifyExploreImageUpdate(section, 'reorder', currentUser.id);
      
      res.json(updatedImages);
    } catch (error) {
      console.error("Error reordering explore page images:", error);
      res.status(500).json({ message: "Failed to reorder explore page images" });
    }
  });

  // Admin endpoint to send system messages and terms prompts to users
  app.post("/api/admin/system-message", requireAdmin, async (req: Request, res: Response) => {
    try {
      const currentUser = await getCurrentUser(req);
      if (!currentUser) {
        return res.status(401).json({ message: "Unauthorized" });
      }
      
      const { type, title, message, requireAction, recipientType, termsVersion } = req.body;
      const adminId = currentUser.id;
      
      // Check that we have the minimum required fields
      if (!type || !title || !message || !recipientType) {
        return res.status(400).json({ 
          message: "Missing required fields: type, title, message, and recipientType are required" 
        });
      }
      
      // Handle different types of messages
      if (type === "terms-prompt") {
        // Send terms of service prompt
        const requireActionBool = typeof requireAction === 'string' 
          ? requireAction === 'true'
          : !!requireAction;
          
        notifyTermsOfServicePrompt(
          recipientType,
          title,
          message,
          requireActionBool,
          adminId,
          termsVersion || 'current'
        );
        
        // Log the admin action
        await storage.createAdminAction({
          adminId,
          actionType: "send_terms_prompt",
          targetType: "users",
          details: JSON.stringify({
            recipientType,
            title,
            message,
            requireAction: requireActionBool,
            termsVersion
          })
        });
        
        return res.json({ 
          success: true, 
          message: `Terms of service prompt sent to ${recipientType} users`
        });
      } 
      else if (type === "notification") {
        // Send system notification
        // Here we could implement sending a general notification
        // to users without requiring action
        
        // Log the admin action
        await storage.createAdminAction({
          adminId,
          actionType: "send_system_notification",
          targetType: "users",
          details: JSON.stringify({
            recipientType,
            title,
            message
          })
        });
        
        return res.json({ 
          success: true, 
          message: `System notification sent to ${recipientType} users` 
        });
      } 
      else {
        return res.status(400).json({ 
          message: `Unsupported message type: ${type}` 
        });
      }
    } catch (error) {
      console.error("Error sending system message:", error);
      res.status(500).json({ message: "Failed to send system message" });
    }
  });

  // AI Integration Endpoints
  // Import AI functions
  const { 
    generateCompletion, 
    generateContentSuggestion, 
    analyzeContent, 
    generateRecommendations 
  } = require("./ai");

  // Generate content suggestions for events, posts, or services
  app.post("/api/ai/suggest-content", async (req: Request, res: Response) => {
    try {
      const { contentType, keywords, style } = req.body;
      
      if (!contentType || !keywords || !Array.isArray(keywords)) {
        return res.status(400).json({ 
          message: "Missing required fields: contentType and keywords array" 
        });
      }

      if (!["event", "post", "service"].includes(contentType)) {
        return res.status(400).json({ 
          message: "Invalid contentType: must be 'event', 'post', or 'service'" 
        });
      }

      const suggestion = await generateContentSuggestion(
        contentType, 
        keywords, 
        style || "engaging"
      );
      
      res.json({ suggestion });
    } catch (error: any) {
      console.error("AI content suggestion error:", error);
      res.status(500).json({ 
        message: "Failed to generate content suggestion", 
        error: error.message 
      });
    }
  });

  // Analyze text content for sentiment, topics, and keywords
  app.post("/api/ai/analyze", async (req: Request, res: Response) => {
    try {
      const { text } = req.body;
      
      if (!text || typeof text !== 'string') {
        return res.status(400).json({ 
          message: "Missing required field: text" 
        });
      }

      const analysis = await analyzeContent(text);
      
      res.json(analysis);
    } catch (error: any) {
      console.error("AI analysis error:", error);
      res.status(500).json({ 
        message: "Failed to analyze content", 
        error: error.message 
      });
    }
  });

  // Generate personalized recommendations based on user interests
  app.post("/api/ai/recommendations", authenticateJWT, async (req: Request, res: Response) => {
    try {
      const { userInterests, itemType, count } = req.body;
      const userId = (req as any).userId;
      
      if (!userInterests || !Array.isArray(userInterests)) {
        return res.status(400).json({ 
          message: "Missing required field: userInterests array" 
        });
      }

      let items = [];
      
      // Get available items based on the specified type
      if (itemType === "events") {
        const events = await storage.getAllEvents();
        items = events.map(event => ({
          id: event.id,
          title: event.title,
          description: event.description,
          category: event.category
        }));
      } else if (itemType === "services") {
        const services = await storage.getServices();
        items = services.map(service => ({
          id: service.id,
          title: service.name,
          description: service.description,
          category: service.category
        }));
      } else if (itemType === "products") {
        const products = await storage.getProducts();
        items = products.map(product => ({
          id: product.id,
          title: product.name,
          description: product.description,
          category: product.category
        }));
      } else {
        return res.status(400).json({ 
          message: "Invalid itemType: must be 'events', 'services', or 'products'" 
        });
      }

      // If no items available, return empty result
      if (items.length === 0) {
        return res.json({ recommendations: [] });
      }

      const recommendedIds = await generateRecommendations(
        userInterests, 
        items, 
        count || 3
      );
      
      // Get the actual items from the IDs
      const recommendations = items.filter(item => 
        recommendedIds.includes(Number(item.id))
      );
      
      res.json({ recommendations });
    } catch (error: any) {
      console.error("AI recommendation error:", error);
      res.status(500).json({ 
        message: "Failed to generate recommendations", 
        error: error.message 
      });
    }
  });

  // Direct AI completion endpoint
  app.post("/api/ai/completion", async (req: Request, res: Response) => {
    try {
      const { prompt, maxTokens, temperature, model } = req.body;
      
      if (!prompt || typeof prompt !== 'string') {
        return res.status(400).json({ 
          message: "Missing required field: prompt" 
        });
      }

      const completion = await generateCompletion({
        prompt,
        maxTokens,
        temperature,
        model
      });
      
      res.json({ completion });
    } catch (error: any) {
      console.error("AI completion error:", error);
      res.status(500).json({ 
        message: "Failed to generate AI completion", 
        error: error.message 
      });
    }
  });

  const httpServer = createServer(app);
  
  // Initialize the WebSocket server on the HTTP server
  const wss = initializeWebSocketServer(httpServer, storage);
  
  // AI API Routes
  app.post("/api/ai/suggest-content", async (req: Request, res: Response) => {
    try {
      const { contentType, keywords, style } = req.body;
      
      if (!contentType || !keywords || !Array.isArray(keywords) || keywords.length === 0) {
        return res.status(400).json({ 
          message: "Invalid request. Required: contentType (string) and keywords (array)" 
        });
      }
      
      const suggestion = await createContentSuggestion({
        contentType,
        keywords,
        style
      });
      
      res.json({ suggestion });
    } catch (error) {
      console.error("Error generating content suggestion:", error);
      res.status(500).json({ message: "Failed to generate content suggestion" });
    }
  });
  
  app.post("/api/ai/analyze", async (req: Request, res: Response) => {
    try {
      const { text } = req.body;
      
      if (!text || typeof text !== "string" || text.trim().length === 0) {
        return res.status(400).json({ message: "Text is required for analysis" });
      }
      
      const analysis = await analyzeContent(text);
      res.json(analysis);
    } catch (error) {
      console.error("Error analyzing content:", error);
      res.status(500).json({ message: "Failed to analyze content" });
    }
  });
  
  app.post("/api/ai/recommendations", async (req: Request, res: Response) => {
    try {
      const { userInterests, itemType, count } = req.body;
      
      if (!userInterests || !Array.isArray(userInterests) || userInterests.length === 0) {
        return res.status(400).json({ message: "User interests are required" });
      }
      
      if (!itemType || !['events', 'services', 'products'].includes(itemType)) {
        return res.status(400).json({ 
          message: "Item type must be one of: events, services, products" 
        });
      }
      
      const recommendations = await getPersonalizedRecommendations({
        userInterests,
        itemType,
        count
      });
      
      res.json({ recommendations });
    } catch (error) {
      console.error("Error getting recommendations:", error);
      res.status(500).json({ message: "Failed to get recommendations" });
    }
  });
  
  app.post("/api/ai/completion", async (req: Request, res: Response) => {
    try {
      const { prompt, maxTokens, temperature, model } = req.body;
      
      if (!prompt || typeof prompt !== "string" || prompt.trim().length === 0) {
        return res.status(400).json({ message: "Prompt is required" });
      }
      
      const completion = await getCompletion({
        prompt,
        maxTokens,
        temperature,
        model
      });
      
      res.json({ completion });
    } catch (error) {
      console.error("Error getting AI completion:", error);
      res.status(500).json({ message: "Failed to get AI completion" });
    }
  });

  return httpServer;
}