                      if (user) {
                        console.log("Authenticated user via Firebase token for terms acceptance:", user.id);
                        userId = user.id;
                      }
                    }
                  } catch (decodeError) {
                    console.error("Error decoding token payload for terms acceptance:", decodeError);
                  }
                }
              } catch (tokenError) {
                console.error("Error processing Firebase token for terms acceptance:", tokenError);
              }
            }
          }
        } catch (error) {
          console.error("Error parsing authorization header for terms acceptance:", error);
        }
      }
      // Try to get from request body
      else if (req.body && req.body.userId) {
        userId = parseInt(req.body.userId);
      }
