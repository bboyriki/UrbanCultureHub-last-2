// Authentication middleware
const authenticateJWT = async (req: Request, res: Response, next: NextFunction) => {
  try {
    // Check for authorization header
    const authHeader = req.headers.authorization;
    
    // Check for user from different sources (headers, session, etc.)
    const userId = 
      req.headers['x-user-id'] ? parseInt(req.headers['x-user-id'] as string) : 
      req.query.userId ? parseInt(req.query.userId as string) : 
      (req.session as any)?.userId;
    
    const userRole = 
      req.headers['x-user-role'] as string || 
      req.query.userRole as string || 
      (req.session as any)?.userRole;
    
    // If we have user info from headers or query, attach it to the request
    if (userId) {
      // Attach the user info to the request
      (req as any).user = {
        id: userId,
        role: userRole
      };
      return next();
    }
    
    // If no auth header and no user info in headers/query, authentication is required
    if (!authHeader) {
      return res.status(401).json({ message: "Authentication required" });
    }

    // Extract the token (Bearer token format)
    const token = authHeader.split(' ')[1];
    if (!token) {
      return res.status(401).json({ message: "Authentication token missing" });
    }

    try {
      // Try to decode base64 sections of the JWT to extract the payload
      const tokenParts = token.split('.');
      if (tokenParts.length === 3) {
        // Try to decode the payload (middle part)
        const payloadBase64 = tokenParts[1];
        // Make base64 URL safe by replacing chars and adding padding
        const base64 = payloadBase64.replace(/-/g, '+').replace(/_/g, '/');
        const padding = '='.repeat((4 - base64.length % 4) % 4);
        const paddedBase64 = base64 + padding;
        
        // Decode the payload
        const jsonPayload = Buffer.from(paddedBase64, 'base64').toString('utf8');
        const payload = JSON.parse(jsonPayload);
        
        // Check if the payload contains user info
        if (payload.user_id || payload.uid) {
          // Get the user from the database based on Firebase UID
          const firebaseUid = payload.user_id || payload.uid;
          const user = await storage.getUserByFirebaseUid(firebaseUid);
          
          if (user) {
            // Add the user object to the request
            (req as any).user = user;
            
            // Continue to the next middleware or route handler
            return next();
          }
        }
      }
      
      // If we couldn't decode the token or find a matching user
      return res.status(401).json({ message: "Invalid authentication token" });
    } catch (decodeError) {
      console.error("Error decoding JWT:", decodeError);
      return res.status(401).json({ message: "Invalid token format" });
    }
  } catch (error) {
    console.error("Authentication error:", error);
    return res.status(500).json({ message: "Authentication error" });
  }
};

// JWT authentication middleware (second implementation)
const authenticateJWT2 = async (req: Request, res: Response, next: NextFunction) => {
  try {
    // Check for authorization header
    const authHeader = req.headers.authorization;
    if (!authHeader) {
      return res.status(401).json({ message: "Authentication required" });
    }

    // Extract the token (Bearer token format)
    const token = authHeader.split(' ')[1];
    if (!token) {
      return res.status(401).json({ message: "Authentication token missing" });
    }

    try {
      // Try to decode base64 sections of the JWT to extract the payload
      const tokenParts = token.split('.');
      if (tokenParts.length === 3) {
        // Try to decode the payload (middle part)
        const payloadBase64 = tokenParts[1];
        // Make base64 URL safe by replacing chars and adding padding
        const base64 = payloadBase64.replace(/-/g, '+').replace(/_/g, '/');
        const padding = '='.repeat((4 - base64.length % 4) % 4);
        const paddedBase64 = base64 + padding;
        
        try {
          // Decode the payload
          const decodedPayload = Buffer.from(paddedBase64, 'base64').toString('utf8');
          const payload = JSON.parse(decodedPayload);
          
          // Extract the sub (subject) field which contains the Firebase UID
          if (payload && payload.sub) {
            // Look up the user by Firebase UID
            const user = await storage.getUserByFirebaseUid(payload.sub);
            if (user) {
              // Attach the user to the request object
              (req as any).user = user;
              return next();
            }
          } else if (payload && payload.user_id) {
            // Some Firebase tokens might use user_id instead of sub
            // Look up the user by Firebase UID
            const user = await storage.getUserByFirebaseUid(payload.user_id);
            if (user) {
              // Attach the user to the request object
              (req as any).user = user;
              return next();
            }
          }
        } catch (decodeError) {
          console.error("Error decoding token payload:", decodeError);
        }
      }
    } catch (tokenError) {
      console.error("Error processing token:", tokenError);
    }

    return res.status(401).json({ message: "Invalid or expired authentication token" });
  } catch (error) {
    console.error("Authentication error:", error);
    return res.status(500).json({ message: "Authentication error" });
  }
};

// Helper function to get the current user from the request
async function getCurrentUser(req: Request) {
  // Try to get user from session
  if (req.session?.user) {
    return req.session.user;
  }
  
  // Try to get user from authorization header (Firebase token)
  if (req.headers.authorization) {
    try {
      const authHeader = req.headers.authorization;
      if (authHeader.startsWith('Bearer ')) {
        const token = authHeader.substring(7);
        
        // Check if this is a Firebase token
        // Firebase tokens are JWT and quite long, typically 500+ characters
        if (token.length > 100) {
          try {
            // For debugging, log token length
            console.log(`Received token of length ${token.length}`);
            
            // Try to decode base64 sections of the JWT to extract the payload
            // JWT format is header.payload.signature
            const tokenParts = token.split('.');
            if (tokenParts.length === 3) {
              // Try to decode the payload (middle part)
              const payloadBase64 = tokenParts[1];
              // Make base64 URL safe by replacing chars and adding padding
              const base64 = payloadBase64.replace(/-/g, '+').replace(/_/g, '/');
              const padding = '='.repeat((4 - base64.length % 4) % 4);
              const paddedBase64 = base64 + padding;
              
              try {
                // Decode the payload
                const decodedPayload = Buffer.from(paddedBase64, 'base64').toString('utf8');
                const payload = JSON.parse(decodedPayload);
                
                // Extract the sub (subject) field which contains the Firebase UID
                if (payload && payload.sub) {
                  console.log("Found Firebase UID in token:", payload.sub);
                  
                  // Look up the user by Firebase UID
                  const user = await storage.getUserByFirebaseUid(payload.sub);
                  if (user) {
                    console.log("Authenticated user via Firebase token:", user.id);
                    return user;
                  }
                } else if (payload && payload.user_id) {
                  // Some Firebase tokens might use user_id instead of sub
                  console.log("Found Firebase UID in token (user_id):", payload.user_id);
                  
                  // Look up the user by Firebase UID
                  const user = await storage.getUserByFirebaseUid(payload.user_id);
                  if (user) {
                    console.log("Authenticated user via Firebase token:", user.id);
                    return user;
                  }
                }
              } catch (decodeError) {
                console.error("Error decoding token payload:", decodeError);
              }
            }
            
            // Fallback: check if token contains a Firebase UID we have in database
            const users = await storage.getAllUsers();
            for (const user of users) {
              if (user.firebaseUid && token.includes(user.firebaseUid)) {
                console.log("Authenticated user via Firebase token (fallback method):", user.id);
                return user;
              }
            }
          } catch (tokenError) {
            console.error("Error processing Firebase token:", tokenError);
          }
          
          // If we couldn't match a Firebase UID, we'll log it and fall through to other methods
          console.log("Could not find matching user for provided Firebase token");
        } else {
          // Simple token format: "userId:role" (legacy)
          const [userIdStr, role] = token.split(':');
          const userId = parseInt(userIdStr, 10);
          
          if (!isNaN(userId)) {
            const user = await storage.getUser(userId);
            if (user) {
              return user;
            }
          }
        }
      }
    } catch (error) {
      console.error("Error parsing authorization header:", error);
    }
  }
  
  // Try to get user from query parameters
  if (req.query.userId) {
    const userId = parseInt(req.query.userId as string, 10);
    if (!isNaN(userId)) {
      const user = await storage.getUser(userId);
      if (user) {
        return user;
      }
    }
  }
  
  // Try to get user from firebase uid in query parameters
  if (req.query.firebaseUid) {
    const firebaseUid = req.query.firebaseUid as string;
    const user = await storage.getUserByFirebaseUid(firebaseUid);
    if (user) {
      return user;
    }
  }
  
  // Try to get user from request body
  if (req.body?.userId) {
    const userId = parseInt(req.body.userId, 10);
    if (!isNaN(userId)) {
      const user = await storage.getUser(userId);
      if (user) {
        return user;
      }
    }
  }
  
  // Try to get user from firebase uid in request body
  if (req.body?.firebaseUid) {
    const user = await storage.getUserByFirebaseUid(req.body.firebaseUid);
    if (user) {
      return user;
    }
  }
  
  return null;
}

// Authentication middleware
const requireAuth = async (req: Request, res: Response, next: NextFunction) => {
  try {
    const user = await getCurrentUser(req);
    
    if (!user) {
      return res.status(401).json({ message: "Authentication required" });
    }
    
    // Store user in the request object for use in route handlers
    (req as any).user = user;
    next();
  } catch (error) {
    console.error("Authentication error:", error);
    res.status(500).json({ message: "Authentication failed due to server error" });
  }
};
