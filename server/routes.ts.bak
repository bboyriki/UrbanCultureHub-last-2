  // Content Moderation
  // Content flagging route - allows users to report inappropriate content
  app.post("/api/content-flags", async (req: Request, res: Response) => {
    try {
      // Validate required fields
      if (!req.body.contentType || !req.body.contentId || !req.body.reason) {
        return res.status(400).json({ 
          message: "Missing required fields: contentType, contentId, and reason are required" 
        });
      }
      
      // Set up flag data with proper defaults
      const flagData = {
        contentType: req.body.contentType,
        contentId: req.body.contentId,
        reason: req.body.reason,
        reporterId: req.body.reporterId || null,
        status: ContentFlagStatus.PENDING,
        reviewerId: null,
        notes: null
      };

      console.log(`Creating content flag: ${JSON.stringify(flagData)}`);
      const contentFlag = await storage.createContentFlag(flagData);
      
      if (!contentFlag) {
        return res.status(500).json({ message: "Failed to create content flag - database error" });
      }
      
      // Get reporter information if available for real-time notification
      let reporter = null;
      if (flagData.reporterId) {
        try {
          reporter = await storage.getUser(flagData.reporterId);
        } catch (userError) {
          console.error("Failed to get reporter user details:", userError);
        }
      }
      
      // Send real-time WebSocket notification to admins
      try {
        const { notifyContentReported } = require('./websocket');
        notifyContentReported(contentFlag, reporter);
        console.log('Real-time notification sent to admins for content flag');
      } catch (wsError) {
        console.error("Failed to send real-time notification for content flag:", wsError);
        // Continue despite WebSocket error - the flag was created successfully
      }
      
      // Also create admin notification about new flag (persistent notification)
      try {
        await storage.createAdminNotification({
          message: `New content flag: ${flagData.reason}`,
          type: "content_flag",
          targetType: flagData.contentType,
          targetId: flagData.contentId,
          fromUserId: flagData.reporterId,
        });
      } catch (notifyError) {
        console.error("Failed to create admin notification for content flag:", notifyError);
        // Continue despite notification error - the flag was created successfully
      }

      // Update system stats for flagged content
      try {
        const stats = await storage.getLatestSystemStats();
        if (stats) {
          await storage.updateSystemStat(stats.id, {
            flaggedContent: (stats.flaggedContent || 0) + 1
          });
        }
      } catch (statsError) {
        console.error("Failed to update stats for flagged content:", statsError);
      }

      res.status(201).json({
        ...contentFlag,
        message: "Thank you for your report. Our moderation team will review it within 24 hours."
      });
    } catch (error) {
      console.error("Failed to create content flag:", error);
      res.status(500).json({ 
        message: "Failed to create content flag", 
        error: error instanceof Error ? error.message : "Unknown error" 
      });
    }
  });

  app.get("/api/admin/content-flags", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Check for admin authentication from request
      const adminId = (req as any).admin?.id;
      
      if (!adminId) {
        console.log('Admin authentication failed: No adminId provided');
        return res.status(401).json({ message: "Admin authentication required" });
      }
      
      console.log(`Authenticating admin with ID: ${adminId}`);
      
      // Fetch user info to confirm admin status
      const adminUser = await storage.getUser(adminId);
      if (!adminUser || adminUser.role !== 'admin') {
        console.log(`Admin authentication failed: User ${adminId} is not an admin`);
        return res.status(403).json({ message: "Not authorized as admin" });
      }
      
      console.log(`Admin authenticated successfully: ${adminUser.displayName} (${adminUser.role})`);
      
      const status = req.query.status as string | undefined;
      let flags;

      if (status) {
        console.log(`Fetching content flags with status: ${status}`);
        flags = await storage.getContentFlagsByStatus(status);
      } else {
        console.log('Fetching pending content flags');
        flags = await storage.getPendingContentFlags();
      }

      console.log(`Retrieved ${flags?.length || 0} content flags`);
      res.json(flags || []);
    } catch (error) {
      console.error("Error fetching content flags:", error);
      res.status(500).json({ 
        message: "Failed to fetch content flags",
        error: error instanceof Error ? error.message : "Unknown error"
      });
    }
  });

  app.post("/api/admin/content-flags/:id/review", requireAdmin, async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const { status, notes, reviewerId: bodyReviewerId } = req.body;
      
      // Get admin ID from multiple sources for redundancy
      const adminId = (req as any).admin?.id;
      
      // Get the reviewer ID with multiple fallbacks for reliability
      const reviewerId = bodyReviewerId
        ? (typeof bodyReviewerId === 'string' ? parseInt(bodyReviewerId) : bodyReviewerId)
        : req.query.adminId 
          ? parseInt(req.query.adminId as string) 
          : adminId || 1; // Final fallback to admin ID 1
      
      // Ensure we have a valid flag ID
      if (isNaN(id)) {
        return res.status(400).json({ 
          message: "Invalid flag ID format",
          success: false
        });
      }
      
      // Ensure we have a valid status
      if (!status || (status !== 'approved' && status !== 'rejected')) {
        return res.status(400).json({ 
          message: "Invalid status - must be 'approved' or 'rejected'",
          success: false
        });
      }
      
      console.log(`Content flag review: Flag ID ${id}, reviewer ID ${reviewerId}, status ${status}`);
      console.log(`Review notes: ${notes || "No notes provided"}`);
      
      const updatedFlag = await storage.reviewContentFlag(id, reviewerId, status, notes);

      if (!updatedFlag) {
        return res.status(404).json({ 
          message: "Content flag not found", 
          success: false 
        });
      }
      
      // If report is approved, take appropriate action based on content type
      if (status === 'approved') {
        try {
          // For posts, automatically delete them
          if (updatedFlag.contentType === 'post') {
            const postId = Number(updatedFlag.contentId);
            if (isNaN(postId)) {
              console.error(`Invalid post ID format in content flag: ${updatedFlag.contentId}`);
            } else {
              console.log(`Admin approved post report: Automatically deleting post #${postId}`);
              
              try {
                // First verify the post exists
                const post = await storage.getPost(postId);
                if (!post) {
                  console.error(`Post #${postId} not found for deletion after report approval`);
                } else {
                  // Post exists, proceed with deletion
                  const deleteResult = await storage.deletePost(postId);
                  console.log(`Post deletion result:`, deleteResult);
                  
                  if (!deleteResult) {
                    console.error(`Failed to delete post #${postId} after report approval`);
                  }
                }
              } catch (deleteError) {
                console.error(`Exception when deleting post #${postId}:`, deleteError);
              }
            }
          }
          
          // Send real-time WebSocket notification to reporter and admins
          try {
            const { notifyContentModerationAction } = require('./websocket');
            notifyContentModerationAction(updatedFlag, reviewerId, 'approved');
            console.log('Real-time content moderation approval notification sent');
          } catch (wsError) {
            console.error('Failed to send WebSocket notification for flag approval:', wsError);
          }
          
          // Create persistent notification for the reporter
          if (updatedFlag.reporterId) {
            await storage.createUserNotification({
              userId: updatedFlag.reporterId,
              type: NotificationType.CONTENT_MODERATION,
              title: "Report Action Taken",
              message: `Your report about ${updatedFlag.contentType} #${updatedFlag.contentId} has been reviewed and approved. The reported content has been removed.`,
            });
          }
        } catch (actionError) {
          console.error(`Error taking action on approved flag ${id}:`, actionError);
          // Continue with the response even if the action fails
        }
      } else if (status === 'rejected') {
        // If rejected, send real-time WebSocket notification
        try {
          const { notifyContentModerationAction } = require('./websocket');
          notifyContentModerationAction(updatedFlag, reviewerId, 'rejected');
          console.log('Real-time content moderation rejection notification sent');
        } catch (wsError) {
          console.error('Failed to send WebSocket notification for flag rejection:', wsError);
        }
        
        // Create persistent notification for the reporter
        try {
          if (updatedFlag.reporterId) {
            await storage.createUserNotification({
              userId: updatedFlag.reporterId,
              type: NotificationType.CONTENT_MODERATION,
              title: "Report Decision",
              message: `Your report about ${updatedFlag.contentType} #${updatedFlag.contentId} has been reviewed but did not require action at this time.`,
            });
          }
        } catch (notifyError) {
          console.error(`Error notifying reporter for rejected flag ${id}:`, notifyError);
        }
      }

      res.json({
        flag: updatedFlag,
        success: true,
        message: `Content flag successfully ${status}`
      });
    } catch (error) {
      console.error("Failed to review content flag:", error);
      res.status(500).json({ 
        message: "Failed to review content flag", 
        success: false,
        error: error instanceof Error ? error.message : "Unknown error"
      });
    }
  });

