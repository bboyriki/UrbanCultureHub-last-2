  // Media upload routes with Cloudinary integration
  app.post("/api/media/upload", async (req: Request, res: Response) => {
    try {
      // Handle both direct upload notification and base64 image upload
      const { imageData, publicId, imageUrl, folder = "urban-culture", resourceType = "image" } = req.body;

      // Case 1: Front-end already uploaded to Cloudinary and is just notifying the server
      if (publicId && imageUrl) {
        console.log(`Server notified of direct upload to Cloudinary: ${publicId}`);
        return res.status(201).json({ 
          url: imageUrl,
          publicId: publicId,
          success: true
        });
      }
      
      // Case 2: Server-side upload with base64 data
      if (!imageData) {
        return res.status(400).json({ message: "No image data provided" });
      }

      console.log(`Attempting to upload image to Cloudinary with folder: ${folder}, resourceType: ${resourceType}`);
      const uploadResult = await uploadImage(imageData, folder, resourceType);

      if (!uploadResult || !uploadResult.success) {
        console.error("Upload failed:", uploadResult?.error || "No result returned from Cloudinary");
        return res.status(500).json({ 
          message: "Failed to upload image", 
          error: uploadResult?.error || "Unknown error"
        });
      }

      console.log("Image successfully uploaded to Cloudinary");
      res.status(201).json(uploadResult);
    } catch (error) {
      console.error("Error uploading media:", error);
      res.status(500).json({ message: "Failed to upload media", error: String(error) });
    }
  });

