  // Block management for specific user (admin/moderator route)
  app.post("/api/users/:userId/block", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const requesterId = req.user?.id;
      if (!requesterId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      // Check if user has permission to modify blocks for this user
      const requester = await storage.getUser(requesterId);
      const isAdminOrMod = requester && (requester.role === 'admin' || requester.role === 'moderator');
      
      if (!isAdminOrMod && requesterId !== parseInt(req.params.userId)) {
        return res.status(403).json({ message: "Permission denied" });
      }
      
      const blockerId = parseInt(req.params.userId);
      const { blockedId, reason } = req.body;
      
      if (!blockedId) {
        return res.status(400).json({ message: "User ID to block is required" });
      }
      
      // Check if block already exists
      const existingBlock = await storage.getUserBlockByUsers(blockerId, blockedId);
      if (existingBlock) {
        return res.status(400).json({ message: "User is already blocked" });
      }
      
      // Create the block
      const block = await storage.createUserBlock({
        blockerId,
        blockedId,
        reason: reason || null
      });
      
      res.status(201).json({ message: "User blocked successfully", block });
    } catch (error) {
      console.error("Error blocking user:", error);
      res.status(500).json({ message: "Failed to block user" });
    }
  });
  
  app.delete("/api/users/:userId/block/:blockedId", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const requesterId = req.user?.id;
      if (!requesterId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      // Check if user has permission to modify blocks for this user
      const requester = await storage.getUser(requesterId);
      const isAdminOrMod = requester && (requester.role === 'admin' || requester.role === 'moderator');
      
      // Validate userId parameter
      let blockerId: number;
      try {
        blockerId = parseInt(req.params.userId);
        if (isNaN(blockerId)) {
          return res.status(400).json({ message: "Invalid user ID format" });
        }
      } catch (parseError) {
        console.error("Error parsing userId:", parseError);
        return res.status(400).json({ message: "Invalid user ID format" });
      }
      
      // Validate blockedId parameter
      let blockedId: number;
      try {
        blockedId = parseInt(req.params.blockedId);
        if (isNaN(blockedId)) {
          return res.status(400).json({ message: "Invalid blocked user ID format" });
        }
      } catch (parseError) {
        console.error("Error parsing blockedId:", parseError);
        return res.status(400).json({ message: "Invalid blocked user ID format" });
      }
      
      // Permission check
      if (!isAdminOrMod && requesterId !== blockerId) {
        console.log(`Permission denied: requester ${requesterId} attempted to modify blocks for user ${blockerId}`);
        return res.status(403).json({ message: "Permission denied - you can only unblock users from your own block list" });
      }
      
      console.log(`Processing unblock request: User ${blockerId} unblocking user ${blockedId}`);
      
      // Find the block entry
      const existingBlock = await storage.getUserBlockByUsers(blockerId, blockedId);
      if (!existingBlock) {
        console.log(`Block not found for blocker ${blockerId} and blocked ${blockedId}`);
        return res.status(404).json({ message: "Block not found - this user may not be blocked" });
      }
      
      // Delete the block
      await storage.deleteUserBlock(existingBlock.id);
      console.log(`Successfully unblocked: User ${blockerId} unblocked user ${blockedId}`);
      
      // Return success response with useful data
      res.json({ 
        message: "User unblocked successfully",
        success: true, 
        blockerId: blockerId,
        unblockedUserId: blockedId 
      });
    } catch (error) {
      console.error("Error unblocking user:", error);
      res.status(500).json({ 
        message: "Failed to unblock user",
        error: error instanceof Error ? error.message : "Unknown error" 
      });
    }
  });
  
  app.get("/api/users/blocks", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const userId = req.user?.id;
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      console.log(`Fetching blocked users for user ID: ${userId}`);
      const blocks = await storage.getUserBlocksByBlocker(userId);
      console.log(`Found ${blocks.length} blocks for user ID: ${userId}`);
      
      // Get details for each blocked user
      const blockedUsers = await Promise.all(
        blocks.map(async (block) => {
          const user = await storage.getUser(block.blockedId);
          return {
            blockId: block.id,
            user: user ? {
              id: user.id,
              displayName: user.displayName,
              profilePicture: user.profilePicture,
              role: user.role
            } : null,
            reason: block.reason,
            blockedAt: block.createdAt
          };
        })
      );
      
      const filteredBlockedUsers = blockedUsers.filter(item => item.user !== null);
      console.log(`Returning ${filteredBlockedUsers.length} valid blocked users`);
      res.json(filteredBlockedUsers);
    } catch (error) {
      console.error("Error fetching blocked users:", error);
      res.status(500).json({ 
