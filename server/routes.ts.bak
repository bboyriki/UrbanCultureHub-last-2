  // Public endpoint for creating test ticket types (for testing purposes only)
  app.post("/api/events/:eventId/test-ticket-types", async (req: Request, res: Response) => {
    try {
      const eventId = parseInt(req.params.eventId);
      const event = await storage.getEvent(eventId);
      
      if (!event) {
        return res.status(404).json({ message: "Event not found" });
      }
      
      // If the event isn't specifically marked as a test event in the title or description,
      // don't allow creating test ticket types
      const isTestEvent = 
        event.title.toLowerCase().includes('test') || 
        (event.description && event.description.toLowerCase().includes('test'));
        
      if (!isTestEvent) {
        return res.status(403).json({ 
          message: "Test ticket types can only be created for events marked as test events" 
        });
      }
      
      const ticketTypeData = insertEventTicketTypeSchema.parse({
        ...req.body,
        eventId
      });

      const ticketType = await storage.createEventTicketType(ticketTypeData);
      res.status(201).json(ticketType);
    } catch (error) {
      if (error instanceof z.ZodError) {
        return res.status(400).json({ message: "Invalid ticket type data", errors: error.errors });
      }
      console.error("Error creating test ticket type:", error);
      res.status(500).json({ message: "Failed to create test ticket type" });
    }
  });

