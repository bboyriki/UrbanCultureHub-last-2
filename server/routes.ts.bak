  // Company name search endpoint for auto-suggestion
  app.get("/api/kvk/search", async (req: Request, res: Response) => {
    try {
      // Use proper parameters according to KVK API documentation
      // Support both 'naam' (KVK API v2) and legacy 'q'/'query' parameters
      const query = req.query.naam || req.query.q || req.query.query;
      
      if (!query || typeof query !== 'string' || query.length < 2) {
        return res.status(400).json({ 
          success: false, 
          message: "Search query must be at least 2 characters",
          results: []
        });
      }
      
      // Get pagination parameters
      const pagina = req.query.pagina ? parseInt(req.query.pagina as string, 10) : 1;
      const resultatenPerPagina = req.query.resultatenPerPagina ? 
        parseInt(req.query.resultatenPerPagina as string, 10) : 10;
      
      const results = await searchCompaniesByName(query, { 
        pagina, 
        resultatenPerPagina 
      });
      res.json(results);
    } catch (error: any) {
      console.error("Error searching for companies:", error);
      res.status(500).json({ 
        success: false, 
        message: error.message || "Failed to search for companies",
        results: []
      });
    }
  });

  // Enhanced test endpoint for KVK API diagnostics
  app.get("/api/kvk/test", async (req: Request, res: Response) => {
    try {
      console.log("KVK API Test endpoint called");

      // Get environment variables
      const apiKey = process.env.KVK_API_KEY;
      const apiUrl = process.env.KVK_API_URL || 'https://api.kvk.nl/api/v1/zoeken';
      const testKvkNumber = req.query.kvk || '63567180'; // Use provided KVK or default

      console.log(`Testing KVK API with URL: ${apiUrl}`);
      console.log(`Using KVK number: ${testKvkNumber}`);
      console.log(`API key configured: ${apiKey ? 'Yes (starts with ' + apiKey.substring(0, 4) + '...)' : 'No'}`);

      // Make a direct API request with parameter in URL
      try {
        // Create a direct URL with q parameter to match our other endpoints
        const testUrl = `${apiUrl}?q=${encodeURIComponent(testKvkNumber)}`;
        console.log(`Making direct request to ${testUrl}`);

        // Use direct URL approach
        const response = await axios.get(testUrl, {
          headers: {
            'apikey': apiKey!,
            'Accept': 'application/json',
            // Add username if available
            ...(process.env.KVK_API_USERNAME ? {'username': process.env.KVK_API_USERNAME} : {})
          },
          timeout: 10000
        });

        // Log result details
        console.log(`Direct KVK API response status: ${response.status}`);
        console.log(`Response headers:`, JSON.stringify(response.headers, null, 2));

        // Return diagnostic info and data summary
        res.json({
          success: true,
          diagnostics: {
            apiUrl,
            apiKeyProvided: !!apiKey,
            testKvkNumber,
            responseStatus: response.status,
            responseTime: 'calculated in server logs',
            responseHeaders: response.headers,
          },
          dataSummary: {
            received: !!response.data,
            dataSize: JSON.stringify(response.data).length,
            dataKeys: Object.keys(response.data || {}),
          },
          data: response.data // Full data for inspection
        });
      } catch (apiError: any) {
        console.error("KVK API test request failed:", apiError.message);

        // Return diagnostic error info
        res.status(500).json({
          success: false,
          diagnostics: {
            apiUrl,
            apiKeyProvided: !!apiKey,
            testKvkNumber,
            errorCode: apiError.code,
            errorMessage: apiError.message,
          },
          responseDetails: apiError.response ? {
            status: apiError.response.status,
            statusText: apiError.response.statusText,
            headers: apiError.response.headers,
            data: apiError.response.data
          } : null
        });
      }
    } catch (error: any) {
      console.error("Error in KVK API test endpoint:", error);
      res.status(500).json({ 
        success: false,
        message: "Failed to run KVK API test",
        error: error.message
      });
    }
  });
  
