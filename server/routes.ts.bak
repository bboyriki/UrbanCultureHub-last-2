  app.post("/api/subscriptions/create", async (req: Request, res: Response) => {
    try {
      const { userId, tier, period } = req.body;

      // Get user information
      const user = await storage.getUser(userId);
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }

      // Check if user already has an active membership
      const existingMembership = await storage.getMembershipByUser(userId);
      if (existingMembership && existingMembership.isActive) {
        return res.status(400).json({ 
          message: "User already has an active membership",
          membership: existingMembership
        });
      }

      // Create or retrieve Stripe customer
      let stripeCustomerId = user.stripeCustomerId;
      if (!stripeCustomerId) {
        const customer = await createCustomer(user.email, user.displayName);
        stripeCustomerId = customer.id;

        // Update user with Stripe customer ID if needed
        if (user.stripeCustomerId !== stripeCustomerId) {
          await storage.updateUser(userId, { stripeCustomerId });
        }
      }

      // Determine price ID based on tier and period
      let priceId;
      let price;
      if (tier === "premium") {
        if (period === "monthly") {
          priceId = SUBSCRIPTION_PRICES.PREMIUM_MONTHLY;
          price = SUBSCRIPTION_TIERS.PREMIUM.monthlyPrice.toString();
        } else if (period === "yearly") {
          priceId = SUBSCRIPTION_PRICES.PREMIUM_YEARLY;
          price = SUBSCRIPTION_TIERS.PREMIUM.yearlyPrice.toString();
        } else {
          return res.status(400).json({ message: "Invalid subscription period" });
        }
      } else {
        return res.status(400).json({ message: "Invalid subscription tier" });
      }

      // Create subscription in Stripe
      const subscription = await createSubscription({
        customerId: stripeCustomerId,
        priceId,
        metadata: {
          userId: userId.toString(),
          tier,
          period
        }
      });

      // Create membership record (will be updated when payment is confirmed)
      const membership = await storage.createMembership({
        userId,
        tier,
        period,
        price,
        stripeSubscriptionId: subscription.id,
        stripeCustomerId,
        autoRenew: true,
        features: tier === "premium" ? SUBSCRIPTION_TIERS.PREMIUM.features : SUBSCRIPTION_TIERS.FREE.features,
        // isActive property is set via the status field instead
        status: "pending"
      });

      // Return necessary details for the client to complete payment
      // Cast here to access payment_intent property that may not be in the type definition
      const subscriptionAny = subscription as any;
      const clientSecret = subscriptionAny.latest_invoice?.payment_intent?.client_secret;

      res.json({
        membership,
        subscription: {
          id: subscription.id,
          clientSecret
        }
      });
    } catch (error: any) {
      console.error("Error creating subscription:", error);
      res.status(500).json({ message: "Failed to create subscription", error: error.message });
    }
  });

  // Simple membership creation for non-premium memberships or testing
  app.post("/api/memberships", async (req: Request, res: Response) => {
    try {
      const membershipData = insertMembershipSchema.parse(req.body);

      // If free tier, we allow direct creation
      if (membershipData.tier === "free") {
        const membership = await storage.createMembership({
          ...membershipData,
          price: "0",
          features: SUBSCRIPTION_TIERS.FREE.features
        });
        return res.status(201).json(membership);
      }

      // For premium memberships, use the subscription endpoint instead
      return res.status(400).json({ 
        message: "For premium memberships, use /api/subscriptions/create endpoint" 
      });
    } catch (error) {
      if (error instanceof z.ZodError) {
        return res.status(400).json({ message: "Invalid membership data", errors: error.errors });
      }
      res.status(500).json({ message: "Failed to create membership" });
    }
  });

  app.patch("/api/memberships/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const membershipData = req.body;

      const existingMembership = await storage.getMembership(id);
      if (!existingMembership) {
        return res.status(404).json({ message: "Membership not found" });
      }

      // If changing subscription period, update in Stripe
      if (membershipData.period && 
          existingMembership.stripeSubscriptionId && 
          membershipData.period !== existingMembership.period) {
        const priceId = membershipData.period === "monthly" 
          ? SUBSCRIPTION_PRICES.PREMIUM_MONTHLY 
          : SUBSCRIPTION_PRICES.PREMIUM_YEARLY;

        await updateSubscription(existingMembership.stripeSubscriptionId, priceId);

        // Update price based on new period
        if (membershipData.period === "monthly") {
          membershipData.price = SUBSCRIPTION_TIERS.PREMIUM.monthlyPrice.toString();
        } else if (membershipData.period === "yearly") {
          membershipData.price = SUBSCRIPTION_TIERS.PREMIUM.yearlyPrice.toString();
        }
      }

      const membership = await storage.updateMembership(id, membershipData);
      res.json(membership);
    } catch (error) {
      console.error("Error updating membership:", error);
      res.status(500).json({ message: "Failed to update membership" });
    }
  });

  app.post("/api/memberships/:id/cancel", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const membership = await storage.getMembership(id);

      if (!membership) {
        return res.status(404).json({ message: "Membership not found" });
      }

      // Cancel subscription in Stripe if exists
      if (membership.stripeSubscriptionId) {
        await cancelSubscription(membership.stripeSubscriptionId);
      }

      // Update membership status in database
      await storage.cancelMembership(id);
      const updatedMembership = await storage.getMembership(id);

      if (!updatedMembership) {
        return res.status(404).json({ message: "Membership not found" });
      }

      res.json(updatedMembership);
    } catch (error) {
      res.status(500).json({ message: "Failed to cancel membership" });
    }
  });

  // Admin check middleware
  const isAdmin = (req: Request, res: Response, next: NextFunction) => {
    if (!(req as any).user) {
      return res.status(401).json({ message: "Authentication required" });
    }

    if ((req as any).user.role !== 'admin' && (req as any).user.role !== 'super_admin') {
      return res.status(403).json({ message: "Admin privileges required" });
    }

    next();
  };

  // Admin middleware to check admin permissions
  const requireAdmin = async (req: Request, res: Response, next: NextFunction) => {
    try {
      // Check for admin ID in request headers (multiple formats), body, params, or query (in that order of preference)
      const adminId = 
        req.headers['x-admin-id'] || 
        req.headers['admin-id'] ||  // Add alternate header format
        req.body.adminId || 
        req.body.reviewerId || 
        req.params.adminId || 
        req.query.adminId;

      if (!adminId) {
        console.log("Admin authentication failed: No adminId provided");
        console.log("Headers:", req.headers);
        console.log("Body:", req.body);
        console.log("Query:", req.query);
        return res.status(401).json({ message: "Admin authentication required" });
      }

      console.log(`Authenticating admin with ID: ${adminId}`);
      const admin = await storage.getUser(parseInt(adminId as string));

      if (!admin) {
        console.log(`Admin authentication failed: User with ID ${adminId} not found`);
        return res.status(403).json({ message: "Admin not found" });
      }

      if (admin.role !== 'admin' && admin.role !== 'moderator' && admin.role !== 'super_admin') {
        console.log(`Admin authentication failed: User ${adminId} has role ${admin.role} which is not admin/moderator/super_admin`);
        return res.status(403).json({ message: "Admin privileges required" });
      }

      // Store admin in the request object for use in route handlers
      (req as any).admin = admin;
      console.log(`Admin authenticated successfully: ${admin.displayName} (${admin.role})`);
      next();
    } catch (error) {
      console.error("Admin authentication error:", error);
      res.status(500).json({ message: "Admin authentication failed" });
    }
  };

