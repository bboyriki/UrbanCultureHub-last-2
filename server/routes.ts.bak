  app.post("/api/tickets/create", async (req: Request, res: Response) => {
    try {
      const { userId, eventId, paymentIntentId, purchaseAmount, ticketQuantity, guestInfo } = req.body;

      if (!eventId || !paymentIntentId) {
        return res.status(400).json({ message: "Missing required fields" });
      }

      // Check if a ticket with this payment intent already exists
      const existingTicket = await storage.getTicketByPaymentIntentId(paymentIntentId);
      if (existingTicket) {
        // Ticket already exists, return it with event info
        const event = await storage.getEvent(existingTicket.eventId);
        return res.json({ 
          ...existingTicket, 
          event,
          message: "Ticket already exists" 
        });
      }

      // Get event details
      const event = await storage.getEvent(eventId);
      if (!event) {
        return res.status(404).json({ message: "Event not found" });
      }

      // If a userId is provided, use it
      // Otherwise, look up or create a user based on guest info
      let user;
      let actualUserId = userId;

      if (!actualUserId && guestInfo) {
        // Try to look up user by email
        const existingUser = await storage.getUserByEmail(guestInfo.email);

        if (existingUser) {
          actualUserId = existingUser.id;
          user = existingUser;
        } else {
          // Create a temporary guest user
          console.log(`Creating guest user for email: ${guestInfo.email}`);
          const newUser = await storage.createUser({
            email: guestInfo.email,
            displayName: guestInfo.name || guestInfo.email.split('@')[0],
            password: null,
            role: "guest",
            status: "active"
          });
          actualUserId = newUser.id;
          user = newUser;
        }
      } else if (actualUserId) {
        // Look up the user by ID
        user = await storage.getUser(actualUserId);
        if (!user) {
          return res.status(404).json({ message: "User not found" });
        }
      } else {
        return res.status(400).json({ message: "Either userId or guestInfo must be provided" });
      }

      console.log(`Creating ticket for user: ${user.id}, event: ${eventId}`);

      // Create the ticket with QR code
      await createTicketWithQR({
        userId: actualUserId,
        eventId,
        paymentIntentId,
        purchaseAmount,
        ticketQuantity
      });

      // Fetch the newly created ticket
      const ticket = await storage.getTicketByPaymentIntentId(paymentIntentId);

      if (!ticket) {
        return res.status(500).json({ message: "Failed to create ticket" });
      }

      // Send email confirmation to the user
      try {
        // Get the user (might have been created after the ticket)
        const ticketUser = await storage.getUser(ticket.userId);
        if (ticketUser && event) {
          const finalQrCode = ticket.qrCode; // Get QR code from the ticket
          await sendTicketConfirmationEmail(ticketUser, event, ticket.id, finalQrCode);
          console.log(`Sent ticket confirmation email to ${ticketUser.email}`);
        }
      } catch (emailError) {
        console.error("Failed to send ticket confirmation email:", emailError);
        // Don't fail the request if email sending fails
      }

      // Return the ticket with event info
      res.status(201).json({ 
        ...ticket, 
        event,
        message: "Ticket created successfully" 
      });
    } catch (error) {
      console.error("Error creating ticket:", error);
      res.status(500).json({ message: "Failed to create ticket" });
    }
  });

  app.get("/api/users/:userId/tickets", async (req: Request, res: Response) => {
