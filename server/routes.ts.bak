  // Admin Actions Log
  app.get("/api/admin/actions", requireAdmin, async (req: Request, res: Response) => {
    try {
      const adminId = req.query.adminId ? parseInt(req.query.adminId as string) : undefined;
      const actionType = req.query.actionType as string | undefined;
      const actionTypePrefix = req.query.actionTypePrefix as string | undefined;

      let actions;
      if (adminId) {
        actions = await storage.getAdminActionsByAdmin(adminId);
        
        // Apply additional filtering for action type prefix if specified
        if (actionTypePrefix) {
          actions = actions.filter(action => action.actionType.startsWith(actionTypePrefix));
        }
      } else if (actionType) {
        actions = await storage.getAdminActionsByType(actionType);
      } else if (actionTypePrefix) {
        // Get all actions and filter by prefix
        const allActions = await storage.getAllAdminActions();
        actions = allActions.filter(action => action.actionType.startsWith(actionTypePrefix));
      } else {
        actions = await storage.getAllAdminActions();
      }

      res.json(actions);
    } catch (error) {
      console.error("Error fetching admin actions:", error);
      res.status(500).json({ message: "Failed to fetch admin actions" });
    }
  });

  // System Stats
  app.get("/api/admin/stats", requireAdmin, async (req: Request, res: Response) => {
    try {
      const latestStats = await storage.getLatestSystemStats();
      if (!latestStats) {
        // If no stats available, create them now
        await storage.updateDailyStats();
        const freshStats = await storage.getLatestSystemStats();
        if (freshStats) {
          // Map database fields to what the frontend expects
          const mappedStats = {
            totalUsers: freshStats.userCount || 0,
            newUsers: 0, // We don't have this info yet
            activeEvents: freshStats.eventCount || 0,
            pendingEvents: 0, // We don't have this info yet
            totalPosts: freshStats.postCount || 0,
            flaggedContent: freshStats.flaggedContent || 0,
            totalRevenue: parseFloat(freshStats.revenue || "0"),
            revenueChange: 0,
            processingTime: parseFloat(freshStats.processingTime || "0"),
          };
          return res.json(mappedStats);
        }
      } else {
        // Map database fields to what the frontend expects
        const mappedStats = {
          totalUsers: latestStats.userCount || 0,
          newUsers: 0, // We don't have this info yet
          activeEvents: latestStats.eventCount || 0,
          pendingEvents: 0, // We don't have this info yet
          totalPosts: latestStats.postCount || 0,
          flaggedContent: latestStats.flaggedContent || 0,
          totalRevenue: parseFloat(latestStats.revenue || "0"),
          revenueChange: 0,
          processingTime: parseFloat(latestStats.processingTime || "0"),
        };
        return res.json(mappedStats);
      }
      
      // Fallback if all else fails
      res.json({
        totalUsers: 0,
        newUsers: 0,
        activeEvents: 0,
        pendingEvents: 0,
        totalPosts: 0,
        flaggedContent: 0,
        totalRevenue: 0,
        revenueChange: 0,
      });
    } catch (error) {
      console.error("Failed to fetch system stats:", error);
      res.status(500).json({ message: "Failed to fetch system stats" });
    }
  });

