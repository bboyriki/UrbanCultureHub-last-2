// Helper function to get user from request for authentication middleware
async function getUserFromRequest(req: Request) {
  return await getCurrentUser(req);
}

export async function registerRoutes(app: Express): Promise<Server> {
  // Configure multer for handling file uploads
  const upload = multer({
    storage: multer.memoryStorage(),
    limits: {
      fileSize: 5 * 1024 * 1024, // 5MB limit
    },
  });
  // Users routes
  app.get("/api/users", async (req: Request, res: Response) => {
    try {
      const role = req.query.role as string | undefined;
      let users;

      if (role) {
        users = await storage.getUsersByRole(role);
      } else {
        users = await storage.getAllUsers();
      }

      res.json(users);
    } catch (error) {
      res.status(500).json({ message: "Failed to fetch users" });
    }
  });

  app.get("/api/users/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const user = await storage.getUser(id);

      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }

      res.json(user);
    } catch (error) {
      res.status(500).json({ message: "Failed to fetch user" });
    }
  });

  app.post("/api/users", async (req: Request, res: Response) => {
    try {
      const userData = insertUserSchema.parse(req.body);
      const existingUser = await storage.getUserByEmail(userData.email);

      if (existingUser) {
        return res.status(409).json({ message: "Email already in use" });
      }

      const user = await storage.createUser(userData);
      res.status(201).json(user);
    } catch (error) {
      if (error instanceof z.ZodError) {
        return res.status(400).json({ message: "Invalid user data", errors: error.errors });
      }
      res.status(500).json({ message: "Failed to create user" });
    }
  });

  app.patch("/api/users/:id", async (req: Request, res: Response) => {
    try {
      const id = parseInt(req.params.id);
      const userData = req.body;
      
      // Check if KVK/BTW info is being updated
      const isUpdatingBusinessInfo = 
        userData.hasOwnProperty('organizationName') || 
        userData.hasOwnProperty('kvkNumber') || 
        userData.hasOwnProperty('btwNumber');
      
      // If updating business info, set verification status
      if (isUpdatingBusinessInfo && !userData.hasOwnProperty('kvkVerificationStatus')) {
        userData.kvkVerificationStatus = 'pending';
      }
      
      // Get the current user data before update
      const currentUser = await storage.getUser(id);
      if (!currentUser) {
        return res.status(404).json({ message: "User not found" });
      }
      
      // Check if this is a new business verification submission
      const isNewVerificationSubmission = 
        isUpdatingBusinessInfo && 
        userData.kvkVerificationStatus === 'pending' && 
        (currentUser.kvkVerificationStatus !== 'pending');
      
      // Handle special case for kvkVerifiedAt with 'NOW()' value
      if (userData.kvkVerifiedAt === 'NOW()') {
        // Set to current timestamp
        userData.kvkVerifiedAt = new Date();
        console.log(`Setting kvkVerifiedAt to current timestamp: ${userData.kvkVerifiedAt}`);
      }
      
      // Perform the user update
      const updatedUser = await storage.updateUser(id, userData);
      
      if (!updatedUser) {
        return res.status(404).json({ message: "User not found" });
      }
      
      // If this is a new business verification submission, create notifications for all admins
      if (isNewVerificationSubmission) {
        try {
          console.log(`Creating admin notifications for new business verification from user ${id}`);
          
          // Get all admin users
          const adminUsers = await storage.getUsersByRole('admin');
          
          // Create a notification for each admin
          for (const adminUser of adminUsers) {
            await storage.createAdminNotification({
              toUserId: adminUser.id,
              title: "New Business Verification",
              message: `${currentUser.displayName} has submitted business information for verification: ${userData.organizationName || currentUser.organizationName} (KVK: ${userData.kvkNumber || currentUser.kvkNumber}).`,
              type: "business_verification",
              actionLink: "/admin/business-verification",
              actionText: "Review Request"
            });
          }
          
          console.log(`Sent notifications to ${adminUsers.length} admins`);
        } catch (notifyError) {
          console.error("Error creating admin notifications:", notifyError);
          // Continue even if notification creation fails
        }
      }
      
      res.json(updatedUser);
    } catch (error) {
      console.error("Error updating user:", error);
      res.status(500).json({ message: "Failed to update user" });
    }
  });

  app.get("/api/users/firebase/:uid", async (req: Request, res: Response) => {
    try {
      const uid = req.params.uid;
      const user = await storage.getUserByFirebaseUid(uid);

      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }

      res.json(user);
    } catch (error) {
      res.status(500).json({ message: "Failed to fetch user" });
