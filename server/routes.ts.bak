  app.get("/api/admin/stats/range", requireAdmin, async (req: Request, res: Response) => {
    try {
      const startDate = req.query.startDate ? new Date(req.query.startDate as string) : new Date(Date.now() - 30 * 24 * 60 * 60 * 1000); // Default to last 30 days
      const endDate = req.query.endDate ? new Date(req.query.endDate as string) : new Date();

      // If no stats data exists, create some now
      const latestStats = await storage.getLatestSystemStats();
      if (!latestStats) {
        await storage.updateDailyStats();
      }

      const stats = await storage.getSystemStatsByDateRange(startDate, endDate);
      
      // Map database fields to what the frontend expects
      const mappedStats = stats.map(stat => ({
        timestamp: stat.statDate,
        totalUsers: stat.userCount || 0,
        newUsers: 0, // We don't track this yet
        totalEvents: stat.eventCount || 0,
        activeEvents: stat.eventCount || 0, // We assume all events are active for now
        totalPosts: stat.postCount || 0,
        totalComments: 0, // We don't track this in stats yet
        totalLikes: 0, // We don't track this in stats yet
        totalRsvps: 0, // We don't track this in stats yet
        flaggedContent: stat.flaggedContent || 0,
        revenue: parseFloat(stat.revenue || "0"),
        processingTime: parseFloat(stat.processingTime || "0")
      }));
      
      res.json(mappedStats);
    } catch (error) {
      console.error("Failed to fetch stats range:", error);
      res.status(500).json({ message: "Failed to fetch stats range" });
    }
  });

  // Ticket management endpoints
  app.get("/api/admin/tickets", requireAdmin, async (req: Request, res: Response) => {
    try {
      // Get query params for filtering if needed
      const eventId = req.query.eventId ? parseInt(req.query.eventId as string) : undefined;
      const userId = req.query.userId ? parseInt(req.query.userId as string) : undefined;
      
      let tickets;
      if (eventId) {
        tickets = await storage.getTicketsByEvent(eventId);
      } else if (userId) {
        tickets = await storage.getTicketsByUser(userId);
      } else {
        // Default to getting all tickets
        // We need to enrich the tickets with event and user info
        const allTickets = await storage.getAllTickets();
        // Enhance tickets with event and user info
        tickets = await Promise.all(allTickets.map(async (ticket) => {
          const event = await storage.getEvent(ticket.eventId);
          const user = await storage.getUser(ticket.userId);
          return {
            ...ticket,
            eventName: event?.name || 'Unknown Event',
            userName: user?.displayName || 'Unknown User'
          };
        }));
      }
      
      res.json(tickets);
    } catch (error) {
      console.error("Error fetching tickets:", error);
      res.status(500).json({ message: "Failed to fetch tickets" });
    }
  });
  
