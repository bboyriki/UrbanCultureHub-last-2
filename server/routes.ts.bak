  // Posts routes
  app.get("/api/posts", async (req: Request, res: Response) => {
    try {
      // Get all posts
      let posts = await storage.getAllPosts();
      
      // Check if we need to apply content filtering - get user ID from various sources
      const userId = parseInt((req as any).user?.id || 
                     req.headers['x-user-id'] as string || 
                     req.query.userId as string || 
                     (req.session as any)?.userId) || null;
      
      if (!userId) {
        // If no authenticated user, return all posts
        return res.json(posts);
      }
      
      // Filter out posts from blocked users
      try {
        // Get list of users that this user has blocked
        const userBlocks = await storage.getUserBlocksByBlocker(userId);
        const blockedUserIds = userBlocks.map(block => block.blockedId);
        
        console.log(`[DEBUG] User ${userId} has blocked ${blockedUserIds.length} users:`, blockedUserIds);
        
        if (blockedUserIds.length > 0) {
          // Filter out posts from blocked users
          const originalCount = posts.length;
          posts = posts.filter(post => !blockedUserIds.includes(post.userId));
          console.log(`[DEBUG] After blocking filter: ${posts.length} posts remain (removed ${originalCount - posts.length})`);
        }
      } catch (blockError) {
        console.error("Error filtering blocked users' posts:", blockError);
        // Continue with content filtering even if block filtering fails
      }
      
      try {
        // Get user's content filter settings
        const filterSettings = await storage.getContentFilterByUser(userId);
        
        console.log(`[DEBUG] Content filtering for user ${userId}:`, {
          hasFilterSettings: !!filterSettings,
          settings: filterSettings
        });
        
        // Initialize filtering variables
        let filterLevel = ContentFilterLevel.NONE;
        let shouldFilter = false;
        
        // If no settings, create default medium settings
        if (!filterSettings) {
          try {
            const defaultFilter = {
              userId,
              level: ContentFilterLevel.MEDIUM,
              filterProfanity: true,
              filterViolence: true,
              filterHateSpeech: true,
              filterExplicit: true,
              filterSpam: true
            };
            
            await storage.createContentFilter(defaultFilter);
            console.log(`Created default content filter settings for user ${userId}`);
            
            // Set filtering variables for this request
            filterLevel = ContentFilterLevel.MEDIUM;
            shouldFilter = true;
          } catch (createError) {
            console.error(`Failed to create default filter settings for user ${userId}:`, createError);
            // Still apply medium filtering even if we can't save it
            filterLevel = ContentFilterLevel.MEDIUM;
            shouldFilter = true;
          }
        } else {
          // User has existing filter settings
          // Check if any filtering is enabled
          shouldFilter = 
            filterSettings.filterProfanity || 
            filterSettings.filterViolence || 
            filterSettings.filterHateSpeech || 
            filterSettings.filterExplicit || 
            filterSettings.filterSpam;
            
          filterLevel = filterSettings.level;
        }
        
        // If filtering is disabled, return all posts
        console.log(`[DEBUG] Content filtering decision for user ${userId}:`, {
          filterLevel,
          shouldFilter,
          filtersEnabled: {
            filterProfanity: filterSettings?.filterProfanity,
            filterViolence: filterSettings?.filterViolence,
            filterHateSpeech: filterSettings?.filterHateSpeech,
            filterExplicit: filterSettings?.filterExplicit,
            filterSpam: filterSettings?.filterSpam
          }
        });
        
        if (!shouldFilter) {
          console.log(`[DEBUG] Skipping content filtering for user ${userId} - filtering is disabled`);
          return res.json(posts);
        }
        
        // Apply content filtering based on user's preferences
        const filteredPosts = [];
        
        for (const post of posts) {
          // Skip if post has no content
          if (!post.content) {
            filteredPosts.push(post);
            continue;
          }
          
          // Check if content passes the filter
          console.log(`[DEBUG] Checking post ${post.id} content against filter level: ${filterLevel}`);
          console.log(`[DEBUG] Post content to check: "${post.content.substring(0, 100)}${post.content.length > 100 ? '...' : ''}"`);
          
          const isAllowed = await storage.isContentAllowed(post.content, filterLevel);
          
          console.log(`[DEBUG] Content filtering result for post ${post.id}:`, {
            postId: post.id,
            filterLevel,
            passed: isAllowed,
            action: isAllowed ? 'including post' : 'filtering out post'
          });
          
          if (isAllowed) {
            filteredPosts.push(post);
          }
        }
        
        return res.json(filteredPosts);
      } catch (filterError) {
        console.error("Error applying content filters:", filterError);
        // If there's an error with filtering, return all posts
        return res.json(posts);
      }
    } catch (error) {
      console.error("Failed to fetch posts:", error);
      res.status(500).json({ message: "Failed to fetch posts" });
    }
  });

  app.post("/api/posts", async (req: Request, res: Response) => {
    try {
      const postData = insertPostSchema.parse(req.body);
      const post = await storage.createPost(postData);
      res.status(201).json(post);
    } catch (error) {
      if (error instanceof z.ZodError) {
        return res.status(400).json({ message: "Invalid post data", errors: error.errors });
      }
      res.status(500).json({ message: "Failed to create post" });
    }
  });
  
  app.patch("/api/posts/:id", async (req: Request, res: Response) => {
    try {
      const postId = parseInt(req.params.id);
      const updateData = req.body;
      
      // Get the post
      const post = await storage.getPost(postId);
      if (!post) {
        return res.status(404).json({ message: "Post not found" });
      }
      
      // Authorization check - the client side should also handle this
      // but we add a server-side check for security
      const userId = req.body.userId || (req.session as any)?.userId;
      const userRole = req.body.userRole || (req.session as any)?.userRole;
      
      // Only allow the post owner or admins to edit the post
      if (post.userId !== userId && userRole !== "admin") {
        return res.status(403).json({ message: "You don't have permission to edit this post" });
      }
      
      // Only update allowed fields
      const allowedFields = ["title", "content", "image", "tags", "artType"];
      const updateFields: Partial<Post> = {};
      
      allowedFields.forEach(field => {
        if (field in updateData) {
          updateFields[field as keyof Post] = updateData[field];
        }
      });
      
      // Update the post
      const updatedPost = await storage.updatePost(postId, updateFields);
      
      if (!updatedPost) {
        return res.status(500).json({ message: "Failed to update post" });
      }
      
      res.status(200).json(updatedPost);
    } catch (error) {
      console.error("Post update error:", error);
      res.status(500).json({ message: "Failed to update post" });
    }
  });

  app.delete("/api/posts/:id", async (req: Request, res: Response) => {
    try {
      const postId = parseInt(req.params.id);
      
      // Get the post
      const post = await storage.getPost(postId);
      if (!post) {
        return res.status(404).json({ message: "Post not found" });
      }
      
      // Try to get user auth from multiple sources (body, query, headers, session)
      // Body is preferred since we just updated the client to send it there
      const userId = req.body?.userId || 
                     req.query.userId || 
                     req.headers['x-user-id'] || 
                     (req.session as any)?.userId;
                     
      const userRole = req.body?.userRole || 
                      req.query.userRole || 
                      req.headers['x-user-role'] || 
                      (req.session as any)?.userRole;
      
      // Add detailed logging to debug permission issues
      console.log("Post deletion request:", {
        requestUserId: userId,
        userIdType: typeof userId,
        parsedUserId: parseInt(userId as string),
        postUserId: post.userId,
        userRole: userRole,
        body: req.body,
        query: req.query,
        headers: {
          'x-user-id': req.headers['x-user-id'],
          'x-user-role': req.headers['x-user-role']
        }
      });
      
      // Only allow the post owner or admins to delete the post
      // Properly handle type conversion and comparison
      const requestUserId = parseInt(userId as string);
      const isAdmin = userRole === "admin";
      const isPostOwner = post.userId === requestUserId;
      
      if (!isPostOwner && !isAdmin) {
        console.log("Permission denied:", { isPostOwner, isAdmin, userId, userRole });
        return res.status(403).json({ message: "You don't have permission to delete this post" });
      }
      
      console.log("Post deletion authorized:", { isPostOwner, isAdmin, userId, userRole });
      
      // Delete the post
      await storage.deletePost(postId);
      
      res.status(200).json({ message: "Post deleted successfully" });
    } catch (error) {
      console.error("Post deletion error:", error);
      res.status(500).json({ message: "Failed to delete post" });
    }
  });

