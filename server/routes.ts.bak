  // Simplified self-unblock endpoint - for current user to unblock a specific user they've blocked
  app.delete("/api/users/block/:blockedId", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const userId = req.user?.id; // Current user's ID
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      // Validate blockedId parameter
      let blockedId: number;
      try {
        blockedId = parseInt(req.params.blockedId);
        if (isNaN(blockedId)) {
          return res.status(400).json({ message: "Invalid blocked user ID format" });
        }
      } catch (parseError) {
        console.error("Error parsing blockedId:", parseError);
        return res.status(400).json({ message: "Invalid blocked user ID format" });
      }
      
      console.log(`Self-unblock request: User ${userId} attempting to unblock user ${blockedId}`);
      
      // Find the block entry
      const existingBlock = await storage.getUserBlockByUsers(userId, blockedId);
      if (!existingBlock) {
        console.log(`Block not found for blocker ${userId} and blocked ${blockedId}`);
        return res.status(404).json({ message: "Block not found - this user may not be blocked" });
      }
      
      // Delete the block
      await storage.deleteUserBlock(existingBlock.id);
      console.log(`Successfully unblocked: User ${userId} unblocked user ${blockedId}`);
      
      // Return success response with useful data
      res.json({ 
        message: "User unblocked successfully",
        success: true,
        unblockedUserId: blockedId 
      });
    } catch (error) {
      console.error("Error unblocking user:", error);
      res.status(500).json({ 
        message: "Failed to unblock user",
        error: error instanceof Error ? error.message : "Unknown error" 
      });
    }
  });
  
