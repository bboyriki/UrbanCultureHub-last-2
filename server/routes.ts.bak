      if (existingConsent) {
        // Update existing consent record
        consentRecord = await storage.updateUserConsent(userId, {
          termsAccepted: true,
          termsAcceptedAt: new Date(),
          ipAddress: ipAddress as string,
          userAgent: userAgent as string,
          updatedAt: new Date()
        });
      } else {
        // Create new consent record
        consentRecord = await storage.recordUserConsent({
          userId,
          termsAccepted: true,
          privacyAccepted: false,  // Default for new record
          termsAcceptedAt: new Date(),
          ipAddress: ipAddress as string,
          userAgent: userAgent as string
        });
      }
      
      // Try to get the user details for the email notification
      const user = await storage.getUser(userId);
      
      // Send notification email to admin about the terms acceptance
      try {
        const { sendTermsAcceptanceNotification } = await import('./email');
        await sendTermsAcceptanceNotification(user, userId, ipAddress as string, userAgent as string);
        console.log("Terms acceptance notification email sent to admin");
      } catch (emailError) {
        console.error("Failed to send terms acceptance notification:", emailError);
      }
      
      return res.json(consentRecord);
    } catch (error) {
      console.error("Error recording terms acceptance:", error);
      res.status(500).json({ message: "Failed to record terms acceptance" });
    }
  });
  
  app.post("/api/legal/accept-privacy", async (req: Request, res: Response) => {
    try {
      // Get user ID from multiple sources (session, headers, query params, request body)
      let userId: number | undefined;
      
      // Try to get from session (primary source)
      if (req.session && (req.session as any).userId) {
        userId = (req.session as any).userId;
      }
      
      // Try to get from Firebase auth user object
      if (!userId && (req as any).user && (req as any).user.id) {
        userId = (req as any).user.id;
      }
      
      // Try to get from authorization header (Firebase token)
      if (!userId && req.headers.authorization) {
        try {
          const authHeader = req.headers.authorization;
          if (authHeader.startsWith('Bearer ')) {
            const token = authHeader.substring(7);
            
            // Check if this is a Firebase token
            if (token.length > 100) {
              console.log(`Processing Firebase token for privacy policy acceptance (length: ${token.length})`);
              try {
                // Try to decode base64 sections of the JWT to extract the payload
                const tokenParts = token.split('.');
                if (tokenParts.length === 3) {
                  // Try to decode the payload (middle part)
                  const payloadBase64 = tokenParts[1];
                  // Make base64 URL safe by replacing chars and adding padding
                  const base64 = payloadBase64.replace(/-/g, '+').replace(/_/g, '/');
                  const padding = '='.repeat((4 - base64.length % 4) % 4);
                  const paddedBase64 = base64 + padding;
                  
                  try {
                    // Decode the payload
                    const decodedPayload = Buffer.from(paddedBase64, 'base64').toString('utf8');
                    const payload = JSON.parse(decodedPayload);
                    
                    // Extract the sub (subject) field which contains the Firebase UID
                    if (payload && payload.sub) {
                      console.log("Found Firebase UID in token for privacy policy acceptance:", payload.sub);
                      
                      // Look up the user by Firebase UID
                      const user = await storage.getUserByFirebaseUid(payload.sub);
                      if (user) {
                        console.log("Authenticated user via Firebase token for privacy policy acceptance:", user.id);
                        userId = user.id;
                      }
                    } else if (payload && payload.user_id) {
                      // Some Firebase tokens might use user_id instead of sub
                      console.log("Found Firebase UID in token (user_id) for privacy policy acceptance:", payload.user_id);
                      
                      // Look up the user by Firebase UID
                      const user = await storage.getUserByFirebaseUid(payload.user_id);
                      if (user) {
                        console.log("Authenticated user via Firebase token for privacy policy acceptance:", user.id);
                        userId = user.id;
                      }
                    }
                  } catch (decodeError) {
                    console.error("Error decoding token payload for privacy policy acceptance:", decodeError);
                  }
                }
              } catch (tokenError) {
                console.error("Error processing Firebase token for privacy policy acceptance:", tokenError);
              }
            }
          }
        } catch (error) {
          console.error("Error parsing authorization header for privacy policy acceptance:", error);
        }
      }
      
      // Try to get from headers (sent by client for auth)
      if (!userId && req.headers['x-user-id']) {
        userId = parseInt(req.headers['x-user-id'] as string);
      }
      
      // Try to get from request body (explicit inclusion)
      if (!userId && req.body && req.body.userId) {
        userId = parseInt(req.body.userId.toString());
      }
      
      // If still no userId, authentication has failed
      if (!userId) {
        return res.status(401).json({ 
          message: "User not authenticated",
          details: {
            sessionExists: !!req.session,
            headerUserId: req.headers['x-user-id'],
            bodyUserId: req.body?.userId
          }
        });
      }
      
      console.log(`Processing privacy policy acceptance for user ID: ${userId}`);
      
      // Get the IP and user agent for audit purposes
      const ipAddress = req.headers['x-forwarded-for'] || req.socket.remoteAddress;
      const userAgent = req.headers['user-agent'];
      
      // Fetch user data for email notification
      const user = await storage.getUser(userId);
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }
      
      // Check if consent already exists
      const existingConsent = await storage.getUserConsent(userId);
      
      let consentRecord;
      
      if (existingConsent) {
        // Update existing consent record
        consentRecord = await storage.updateUserConsent(userId, {
          privacyAccepted: true,
          privacyAcceptedAt: new Date(),
          ipAddress: ipAddress as string,
          userAgent: userAgent as string,
          updatedAt: new Date()
        });
      } else {
        // Create new consent record
        consentRecord = await storage.recordUserConsent({
          userId,
          termsAccepted: false,  // Default for new record
          privacyAccepted: true,
          privacyAcceptedAt: new Date(),
          ipAddress: ipAddress as string,
          userAgent: userAgent as string
        });
      }
      
      // Send notification email to admin with user acceptance details
      try {
        const emailSent = await sendPrivacyPolicyAcceptanceNotification(
          user,
          ipAddress as string, 
          userAgent as string
        );
        
        if (emailSent) {
          console.log(`Privacy policy acceptance notification email sent for user ${userId}`);
        } else {
          console.warn(`Failed to send privacy policy acceptance notification email for user ${userId}`);
        }
      } catch (emailError) {
        console.error("Error sending privacy policy acceptance notification:", emailError);
        // Continue despite email error (don't block the consent recording)
      }
      
      return res.json({
        ...consentRecord,
        notificationSent: true
      });
    } catch (error) {
      console.error("Error recording privacy acceptance:", error);
      res.status(500).json({ message: "Failed to record privacy acceptance", error });
    }
  });

  // Data Deletion Routes for legal section
  app.get("/api/legal/data-deletion-requests", async (req: Request, res: Response) => {
    try {
      let userId: number | undefined;
      let isAdmin = false;
      
      // Try to get user ID from various sources
      if (req.session && req.session.userId) {
        userId = req.session.userId;
      } else if (req.user && req.user.id) {
        userId = req.user.id;
      } else if (req.headers.authorization) {
        try {
          const authHeader = req.headers.authorization;
          if (authHeader.startsWith('Bearer ')) {
            const token = authHeader.substring(7);
            
            // Check if this is a Firebase token
            if (token.length > 100) {
              try {
                // Decode the JWT payload
                const tokenParts = token.split('.');
                if (tokenParts.length === 3) {
                  const payload = JSON.parse(Buffer.from(tokenParts[1], 'base64').toString());
                  
                  if (payload.user_id) {
                    // Look up user by Firebase UID
                    const user = await storage.getUserByFirebaseUid(payload.user_id);
                    if (user) {
                      userId = user.id;
                      isAdmin = user.role === 'admin';
                    }
                  }
                }
              } catch (error) {
                console.error("Error processing token for data deletion requests:", error);
              }
            }
          }
        } catch (error) {
          console.error("Error parsing authorization header for data deletion requests:", error);
        }
      }
      
      // Use default admin for testing/debugging if needed
      if (!userId) {
        console.log("No userId found for data deletion requests - using default admin account");
        userId = 1; // Default admin account
        isAdmin = true;
      }
      
      // Check if user is requesting all data deletion requests (admin only)
      const { all } = req.query;
      
      if (all === 'true' && isAdmin) {
        // For admins, return all requests
        const requests = await storage.getAllDataDeletionRequests();
        return res.json(requests);
      } else {
        // For regular users, only return their own requests
        const requests = await storage.getDataDeletionRequestsByUser(userId);
        return res.json(requests);
      }
    } catch (error) {
      console.error("Error fetching data deletion requests:", error);
      res.status(500).json({ message: "Failed to fetch data deletion requests" });
    }
  });
  
  app.post("/api/legal/request-data-deletion", async (req: Request, res: Response) => {
    try {
      let userId: number | undefined;
      
      // Try to get user ID from various sources
      if (req.session && req.session.userId) {
        userId = req.session.userId;
      } else if (req.user && req.user.id) {
        userId = req.user.id;
      } else if (req.headers.authorization) {
        try {
          const authHeader = req.headers.authorization;
          if (authHeader.startsWith('Bearer ')) {
            const token = authHeader.substring(7);
            
            // Check if this is a Firebase token
            if (token.length > 100) {
              try {
                // Decode the JWT payload
                const tokenParts = token.split('.');
                if (tokenParts.length === 3) {
                  const payload = JSON.parse(Buffer.from(tokenParts[1], 'base64').toString());
                  
                  if (payload.user_id) {
                    // Look up user by Firebase UID
                    const user = await storage.getUserByFirebaseUid(payload.user_id);
                    if (user) {
                      userId = user.id;
                    }
                  }
                }
              } catch (error) {
                console.error("Error processing token for data deletion request:", error);
              }
            }
          }
        } catch (error) {
          console.error("Error parsing authorization header for data deletion request:", error);
        }
      }
      
      // Use default admin for testing/debugging if needed
      if (!userId) {
        console.log("No userId found for data deletion request - using default admin account");
        userId = 1; // Default admin account
      }
      
      // Validate user exists
      const user = await storage.getUser(userId);
      if (!user) {
        return res.status(404).json({ message: "User not found" });
      }
      
      // Check if there is already a pending or processing request
      const existingRequests = await storage.getDataDeletionRequestsByUser(userId);
      const activeRequest = existingRequests.find(
        req => req.status === "pending" || req.status === "processing"
      );
      
      if (activeRequest) {
        return res.status(409).json({ 
          message: "A data deletion request is already in progress",
          requestId: activeRequest.id,
          status: activeRequest.status
        });
      }
      
      // Create new deletion request with reason from the form
      const request = await storage.createDataDeletionRequest({
        userId,
        reason: req.body.reason || "User requested data deletion",
        additionalInfo: req.body.additionalNotes || null
      });
      
      // Create notifications for all admins
      const adminUsers = await storage.getUsersByRole('admin');
      
      for (const adminUser of adminUsers) {
        await storage.createAdminNotification({
          toUserId: adminUser.id,
          title: "New Data Deletion Request",
          message: `User ${user.displayName} has requested their data to be deleted. Reason: ${request.reason}`,
          type: "data_deletion_request",
          actionLink: "/admin/data-deletion-requests",
          actionText: "Review Request"
        });
      }
      
      res.status(201).json(request);
    } catch (error) {
      console.error("Error creating data deletion request:", error);
      res.status(500).json({ message: "Failed to create data deletion request" });
    }
  });
  
  // Process data deletion request (for admins)
  app.patch("/api/legal/data-deletion-requests/:id", async (req: Request, res: Response) => {
    try {
      let userId: number | undefined;
      let isAdmin = false;
      
      // Try to get user ID from various sources
      if (req.session && req.session.userId) {
        userId = req.session.userId;
      } else if (req.user && req.user.id) {
        userId = req.user.id;
      } else if (req.headers.authorization) {
        try {
          const authHeader = req.headers.authorization;
          if (authHeader.startsWith('Bearer ')) {
            const token = authHeader.substring(7);
            
            // Check if this is a Firebase token
            if (token.length > 100) {
              try {
                // Decode the JWT payload
                const tokenParts = token.split('.');
                if (tokenParts.length === 3) {
                  const payload = JSON.parse(Buffer.from(tokenParts[1], 'base64').toString());
                  
                  if (payload.user_id) {
                    // Look up user by Firebase UID
                    const user = await storage.getUserByFirebaseUid(payload.user_id);
                    if (user) {
                      userId = user.id;
                      isAdmin = user.role === 'admin';
                    }
                  }
                }
              } catch (error) {
                console.error("Error processing token for data deletion processing:", error);
              }
            }
          }
        } catch (error) {
          console.error("Error parsing authorization header for data deletion processing:", error);
        }
      }
      
      // Use default admin for testing/debugging if needed
      if (!userId) {
        console.log("No userId found for data deletion processing - using default admin account");
        userId = 1; // Default admin account
        isAdmin = true;
      }
      
      // Check if user is admin
      if (!isAdmin) {
        return res.status(403).json({ message: "Only administrators can process data deletion requests" });
      }
      
      // Get request ID from path params
      const requestId = parseInt(req.params.id);
      if (isNaN(requestId)) {
        return res.status(400).json({ message: "Invalid request ID" });
      }
      
      // Get request data from body
      const { approved, adminNotes } = req.body;
      if (typeof approved !== 'boolean') {
        return res.status(400).json({ message: "The 'approved' field must be a boolean" });
      }
      
      // Process the request
      const updatedRequest = await storage.processDataDeletionRequest(
        requestId,
        userId,
        approved,
        adminNotes
      );
      
      if (!updatedRequest) {
        return res.status(404).json({ message: "Data deletion request not found" });
      }
      
      // If request was approved, create notification for the user
      if (approved) {
        // Create notification for the user
        await storage.createUserNotification({
          userId: updatedRequest.userId,
          title: "Data Deletion Request Approved",
          message: "Your request to delete your data has been approved. Your account and data will be permanently deleted from our systems.",
          type: "data_deletion_approved"
        });
        
        // Start the actual deletion process (in a background job or immediately)
        try {
          // Perform the actual data deletion here
          // This would involve deleting all user data, posts, comments, etc.
          console.log(`STARTING DATA DELETION FOR USER ${updatedRequest.userId}`);
          
          // TODO: In a production environment, this would typically be done in a background job
          // For now, we'll mark the user as deleted in the database
          const user = await storage.getUser(updatedRequest.userId);
          if (user) {
            await storage.updateUser(user.id, {
              status: "deleted",
              email: `deleted-${user.id}@deleted.com`, // Anonymize email
              displayName: "Deleted User",
              profilePicture: null,
              bio: null,
              firebaseUid: null // Remove Firebase association
            });
            
            // Log activity
            await storage.createAdminActivity({
              adminId: userId,
              actionType: AdminActionType.USER_DELETION,
              targetId: user.id,
              targetType: "user",
              details: `User data deleted as requested. Original email: ${user.email}`
            });
          }
        } catch (deletionError) {
          console.error("Error during user data deletion:", deletionError);
          // We still return success to the admin, but log the error
          // In a production system, this would trigger a retry mechanism
        }
      } else {
        // Request was rejected, notify the user
        await storage.createUserNotification({
          userId: updatedRequest.userId,
          title: "Data Deletion Request Rejected",
          message: adminNotes ? 
            `Your request to delete your data has been rejected. Reason: ${adminNotes}` :
            "Your request to delete your data has been rejected. Please contact customer support for more information.",
          type: "data_deletion_rejected"
        });
      }
      
      // Return the updated request
      res.json(updatedRequest);
    } catch (error) {
      console.error("Error processing data deletion request:", error);
      res.status(500).json({ message: "Failed to process data deletion request" });
    }
  });

  // Content Moderation Routes
  
  // Report content (create a content flag)
  app.post("/api/content/report", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const userId = req.user?.id;
      if (!userId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      const { contentType, contentId, reason } = req.body;
      
      if (!contentType || !contentId || !reason) {
        return res.status(400).json({ message: "Content type, ID, and reason are required" });
      }
      
      // Create the content flag
      const flag = await storage.createContentFlag({
        contentType,
        contentId,
        reason,
        reporterId: userId,
        status: ContentFlagStatus.PENDING
      });
      
      // Notify all administrators
      const adminUsers = await storage.getUsersByRole('admin');
      for (const admin of adminUsers) {
        await storage.createAdminNotification({
          toUserId: admin.id,
          title: "New Content Report",
          message: `A user has reported ${contentType} #${contentId} for "${reason}"`,
          type: "content_flag",
          actionLink: "/admin/moderation",
          actionText: "Review Report"
        });
      }
      
      res.status(201).json({ message: "Content reported successfully", flag });
    } catch (error) {
      console.error("Error reporting content:", error);
      res.status(500).json({ message: "Failed to report content" });
    }
  });
  
  // User block management
  app.post("/api/users/block", authenticateJWT2, async (req: Request, res: Response) => {
    try {
      const blockerId = req.user?.id;
      if (!blockerId) {
        return res.status(401).json({ message: "Authentication required" });
      }
      
      const { blockedId, reason } = req.body;
      
      if (!blockedId) {
        return res.status(400).json({ message: "User ID to block is required" });
      }
      
      // Check if block already exists
      const existingBlock = await storage.getUserBlockByUsers(blockerId, blockedId);
      if (existingBlock) {
        return res.status(400).json({ message: "User is already blocked" });
      }
      
      // Create the block
      const block = await storage.createUserBlock({
        blockerId,
        blockedId,
        reason: reason || null
      });
      
      res.status(201).json({ message: "User blocked successfully", block });
    } catch (error) {
      console.error("Error blocking user:", error);
      res.status(500).json({ message: "Failed to block user" });
    }
  });
  
