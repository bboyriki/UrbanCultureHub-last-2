        apiKeyLength: process.env.SENDGRID_API_KEY ? process.env.SENDGRID_API_KEY.length : 0
      };
      
      console.log("Email system status:", {
        isConfigured: response.isConfigured,
        isApiKeyWorking: response.isApiKeyWorking,
        totalAttempts: response.totalAttempts,
        successfulAttempts: response.successfulAttempts,
        failedAttempts: response.failedAttempts,
        validationResult: response.validationResult
      });
      
      res.json(response);
    } catch (error) {
      console.error("Error checking email system status:", error);
      res.status(500).json({ 
        message: "Error checking email system status", 
        error: error instanceof Error ? error.message : String(error) 
      });
    }
  });
  
